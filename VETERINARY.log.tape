@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite_lattice_to_real_science := "VETERINARY.tape rewritten — lattice-tautology stub → real-science SSOT" :: rewrite [ok d=2026-05-16]
  origin = "VETERINARY.tape was a 695-line lattice-tautology stub from hexa-bio mass-split 153b5a2. The stub contained: (a) Korean-language 'EXACT' rows asserting n=6 lattice constants as derivations of veterinary anatomy (dog gestation = σ*(σ-φ)-n, cervical vertebrae = σ-sopfr, dog teeth = (σ-sopfr)*n, cat blood types = n/φ, etc.); (b) fabricated BT-424–428 'breakthrough theorems' with no scientific basis; (c) Korean performance-comparison rows (품질 편차 ±3%, 폐기율 τ/J₂) with no veterinary meaning; (d) no real citations, no @F guard, no @N honest stance. This is exactly the lattice-fit derivation anti-pattern forbidden by hexa-bio AGENTS.tape @F f1 + @D g1/g2 and LATTICE_POLICY."
  rewritten-by = "wilson (claude-sonnet-4-6) 2026-05-16"
  what-deleted = "All 645 lines of stub content from @I id001 onwards: all @D row_* lattice-tautology rows, all BT-424–428 fabricated theorems, all Korean performance-comparison rows, all Mk.I–V evolution rows referencing n=6 parameters, all H-VET-1–16 'hypothesis' rows with EXACT lattice derivations."
  what-added = "Full real-science SSOT rewrite: §1 comparative anatomy/pharmacology (acetaminophen cats, xylitol dogs, theobromine dogs, lily nephrotoxicity cats — species-specific enzymatic basis); §2 vaccinology history (Pasteur 1885 rabies, CDV, CPV-2 Carmichael ~1978, FeLV, FIP, FMD, rinderpest eradication OIE/FAO 2011); §3 companion animal medicine (WSAVA core vaccines, dental disease, feline CKD IRIS staging, canine obesity/OA, spay/neuter debate); §4 production animal medicine (mastitis, lameness, AI, AMR stewardship WHO/FAO/WOAH tripartite); §5 One Health/zoonoses (rabies ~59,000 human deaths/year WHO, brucellosis, leptospirosis, H5N1/H5N8 spillover, BSE/vCJD/Prusiner 1982 Nobel, MERS dromedary reservoir, COVID-19 origin); §6 welfare (Five Domains Mellor replacing Five Freedoms; equine anesthesia risk; species-specific opioid pharmacology); §7 regulatory (USDA/APHIS, FDA/CVM, EMA, OIE/WOAH); §8 five real-limits (AMR evolutionary wall, owner-cost floor, cat UGT acetaminophen deficit HARD WALL, welfare-standards heterogeneity, Plowright 2017 zoonotic-emergence ecological constraint); §9 @F f_lattice_fit + @N n6_honest_stance (explicit: veterinary medicine has no natural n=6 invariant); §10 three falsifiable predictions (CPV-2 vaccine efficacy, dog-rabies 70%-coverage threshold, AGP→AMR emergence); §11 cross-link to hexa-bio AGENTS.tape governance; §12 eleven real @X :: literature citations."
  citations-summary = "Real citations included: Pasteur 1885 (C R Acad Sci 101:765-774); Prusiner 1982 (Science 216:136-144); Plowright et al 2017 (Nat Rev Microbiol 15:502-510); WHO rabies fact sheet (institutional); WHO/FAO/WOAH AMR tripartite framework (institutional); WHO One Health Joint Plan of Action 2022; OIE/FAO rinderpest eradication 2011 (institutional); WSAVA Vaccination Guidelines (Day/Horzinek/Schultz/Squires era); Plumb's Veterinary Drug Handbook (9th ed. 2018); IRIS CKD Guidelines (institutional); Mellor 2016 (Animals 6:59)."
  author-era-flagged = "CPV-2 emergence (~1978, Carmichael era — primary author/era, exact volume cautiously noted); CDV vaccine (Laidlaw/Dunkin era, early-mid 20th century); Hatch/Slack, Stern, Karlen pattern applied: named primary author + era where exact volume not asserted with confidence."
  n6-stance = "Declined as derivation tool. @F f_lattice_fit + @N n6_honest_stance state explicitly: veterinary medicine has no natural n=6 invariant. Prior 'EXACT' derivations (dog gestation, cervical vertebrae, dental counts, blood group counts, pregnancy durations expressed as lattice arithmetic) are post-hoc coincidence-engineering on approximate means — not scientific derivations."
  governance = "Complies with hexa-bio AGENTS.tape g1 (real-limits-first; 5 @D lim_* anchors), g2 (lattice-is-tool; declined), g3 (honesty-obligation-external; external entities cited on their own terms), g8 (in-silico-only-claim-scope; scope_disclaimer added), f1 (lattice-fit forbidden; @F guard present), f2 (no wet-lab/clinical claim from in-silico)."
  lint-result = "python3 selftest/tape_lattice_honesty_lint.py VETERINARY.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true)"
