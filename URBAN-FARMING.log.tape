#!/usr/bin/env tape

@V := "tape" :: spec [active]
  version = "1.2"

# ══════════════════════════════════════════════════════════════
# URBAN-FARMING.log.tape — append-only event history (v1.2 split)
# Sibling: URBAN-FARMING.tape (architecture-current, editable)
# Repo-of-record: dancinlab/hexa-bio
# ══════════════════════════════════════════════════════════════

# §Log — entries chronological, oldest first.

@A rewrite_from_lattice_tautology := "URBAN-FARMING.tape rewritten from lattice-tautology stub into real urban-agriculture SSOT" :: rewrite [ok d=2026-05-16]
  origin = "URBAN-FARMING.tape was a fabricated lattice-tautology stub from the hexa-bio mass-split (commit 153b5a2): ~80 lines, almost entirely banner + 3 @D b_* entries asserting lattice connection ('Hoagland 6 macronutrients · 6 vertical-farm tiers · 6-band grow-LED spectrum') with zero real science. Two @D entries cited real sources (Hoagland & Arnon 1950; Kozai et al.) but without actual content — citations without claims. No real-limits anchors, no falsifiers, no economic honesty about vertical farming's scope. Deleted in full."
  authored = "Hand-written with real urban-agriculture / CEA / vertical-farming science + landmark literature. Replaced the stub with: urban-agriculture typology (rooftop/community gardens/aquaponics/CEA/vertical farming; FAO Urban Food Agenda); definitions of CEA and vertical farming (Despommier 2010 concept origin); hydroponic systems (NFT — Cooper 1979 era; DWC; drip; ebb-flow; Hoagland solution Hoagland & Arnon 1938/1950); aeroponics (misting systems); aquaponics (fish-plant integration, Lennard & Leonard 2006 era); CEA LED lighting (Massa et al. 2008 era — narrow-band red+blue characterisation for plant factories); crop-scope economic honesty (what works: leafy greens/herbs/microgreens; what does NOT work: staples/cereals/root crops — explicitly stated); food-security context (FAO Urban Food Agenda; food deserts); urban soil contamination (Pb legacy; Brown & Chaney 2011/2016 era); pollinator urban beekeeping cross-link. Four @D :: real-limit anchors (vertical-farm energy economics; crop-scope economic barrier; urban land economics; soil contamination legacy). Three falsifiable @D :: prediction entries with explicit falsifiers. @F f_lattice_fit + @N n6_honest_stance with full explicit honesty on the stub's fabricated lattice connections."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: urban farming exposes NO natural n=6 invariant — Hoagland nutrient ions, vertical-farm tier counts, LED spectral bands, and hydroponic system typologies are all determined by plant photobiology, agronomy, and engineering — not by σ/τ/φ/J₂. This honesty is the corrective for the audited stub's 'Hoagland 6 macronutrients · 6 vertical-farm tiers · 6-band grow-LED spectrum' fabrications."
  governance = "Complies with hexa-bio AGENTS.tape @D g1 (real-limits-first — every @D |>-grounded to a real @X), @D g2 (lattice-is-tool — declined here), @D g8 (in-silico-only-claim-scope — @N scope_disclaimer: knowledge SSOT, NOT farming protocol / food-safety guarantee / regulatory claim), @F f1 (no lattice-fit). No fabricated numbers or citations: yield/economic figures are paraphrased from cited literature with explicit uncertainty framing; author/era citations used where exact bibliographic detail is not asserted with full confidence (Cooper 1979, Massa 2008, Avgoustaki & Xydis 2020, FAO institutional, Brown & Chaney 2016) — flagged as such in each @X ref field."
  vertical-farm-economic-honesty-discipline = "Vertical farming is hype-prone (Despommier 2010 book generated significant popular-media overclaiming in the 2010s). This tape applies explicit economic-honesty discipline — mirroring the THERAPEUTIC-NANOBOT and AGRICULTURE honesty-downgrade catalog pattern: (1) crop-scope limit stated as HARD WALL: staples (cereals, root crops) are not economical in sole-source vertical farms at current electricity prices; (2) energy economics treated as a real techno-economic limit, not a marketing qualifier; (3) climate-positive claims qualified — indoor vertical farming is NOT inherently lower-carbon than field production without cheap renewable electricity; (4) food-desert/food-security claims qualified — premium produce from vertical farms is not automatically accessible to low-income residents; (5) the stub's '6 vertical-farm tiers = lattice' fabrication rejected outright as having no basis in the CEA engineering literature."
  lint = "python3 selftest/tape_lattice_honesty_lint.py URBAN-FARMING.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true; deriv_warnings = guard/stance provenance lines only, no genuine lattice-derivation lines)."
