{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hexa-bio/_python_bridge/spec/aptamer_capsid_modulator_cross_v1.schema.json",
  "title": "aptamer_capsid_modulator_cross_v1 — aptamer-occupancy → capsid-assembly ΔG_contact perturbation row",
  "description": "Cross-axis bridge row: an aptamer raised against a capsid inter-subunit interface (APTAMER sub-axis :> RIBOZYME core — Nussinov fold + 1:1 Langmuir Kd) acts as a capsid-assembly modulator. Its Langmuir fraction-bound θ at a given aptamer concentration scales an effective per-contact ΔG perturbation fed VERBATIM into the CAPSID-ASSEMBLY-MODULATOR sub-axis (:> VIROCAPSID core — Zlotnick mean-field equilibrium + exact Caspar-Klug geometry). Both parent sims are imported, never re-implemented (AGENTS.tape f3). An aptamer AS a capsid-assembly modulator is a RESEARCH-STAGE modality combination (no FDA-approved capsid-targeting aptamer); the aptamer modality and the capsid-assembly-modulator drug class each have their OWN separate precedent (g3/f1), reported NOT lattice-derived. In-silico simulator-consistency scope ONLY (g8/f2) — NOT a structural/binding/assembly/therapeutic/regulatory claim. A cross is NOT a new axis: hexa-bio core-5 set UNCHANGED.",
  "type": "object",
  "required": [
    "schema", "device_id", "device_note",
    "aptamer_name", "aptamer_sequence", "aptamer_length_nt", "capsid_target",
    "aptamer_paper_ref", "kd_nM", "kd_M",
    "aptamer_conc_x_kd", "aptamer_conc_M", "fraction_bound_theta",
    "modulator_dg_max_kcal", "effective_delta_dg_contact_kcal",
    "reference_t_number", "caspar_klug_geometry",
    "baseline_c_star", "baseline_assembled_fraction",
    "modulated_c_star", "modulated_assembled_fraction",
    "assembled_fraction_shift", "kinetic_trap_regime",
    "modulator_sign", "kcat_per_s",
    "aptamer_subaxis_source", "capsid_modulator_subaxis_source",
    "research_stage_modality", "creates_a_new_axis", "illustrative_only"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {"const": "aptamer_capsid_modulator_cross_v1"},
    "device_id": {"type": "string", "minLength": 1},
    "device_note": {"type": "string"},
    "aptamer_name": {"type": "string", "minLength": 1},
    "aptamer_sequence": {"type": "string", "minLength": 1},
    "aptamer_length_nt": {"type": "integer", "minimum": 1},
    "capsid_target": {"type": "string", "minLength": 1},
    "aptamer_paper_ref": {"type": "string", "minLength": 1},
    "kd_nM": {"type": "number", "exclusiveMinimum": 0},
    "kd_M": {"type": "number", "exclusiveMinimum": 0},
    "aptamer_conc_x_kd": {"type": "number", "minimum": 0},
    "aptamer_conc_M": {"type": "number", "minimum": 0},
    "fraction_bound_theta": {"type": "number", "minimum": 0, "maximum": 1},
    "modulator_dg_max_kcal": {"type": "number"},
    "effective_delta_dg_contact_kcal": {"type": "number"},
    "reference_t_number": {"type": "integer", "minimum": 1},
    "caspar_klug_geometry": {
      "type": "object",
      "required": ["t_number", "n_subunits", "n_pentamers", "n_hexamers", "euler_invariant_ok"],
      "properties": {
        "t_number": {"type": "integer", "minimum": 1},
        "n_subunits": {"type": "integer", "minimum": 60},
        "n_pentamers": {"type": "integer", "const": 12},
        "n_hexamers": {"type": "integer", "minimum": 0},
        "euler_invariant_ok": {"const": true}
      }
    },
    "baseline_c_star": {"type": "number", "exclusiveMinimum": 0},
    "baseline_assembled_fraction": {"type": "number", "minimum": 0, "maximum": 1},
    "modulated_c_star": {"type": "number", "exclusiveMinimum": 0},
    "modulated_assembled_fraction": {"type": "number", "minimum": 0, "maximum": 1},
    "assembled_fraction_shift": {"type": "number", "minimum": -1, "maximum": 1},
    "kinetic_trap_regime": {"type": "boolean"},
    "modulator_sign": {"type": "string", "enum": ["stabilizer", "destabilizer", "neutral"]},
    "kcat_per_s": {"type": "number", "const": 0.0},
    "aptamer_subaxis_source": {"type": "string"},
    "capsid_modulator_subaxis_source": {"type": "string"},
    "research_stage_modality": {"const": true},
    "creates_a_new_axis": {"const": false},
    "illustrative_only": {"const": true}
  }
}
