{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hexa-bio/_python_bridge/spec/capsid_modulator_weave_cross_v1.schema.json",
  "title": "capsid_modulator_weave_cross_v1 — natural vs designed cage row",
  "description": "Cross-axis comparison row: a single modulator-style ΔG_contact perturbation applied to a natural protein-capsid assembly (CAPSID-ASSEMBLY-MODULATOR sub-axis :> VIROCAPSID core) AND a designed-cage assembly (WEAVE core). The cross imports both axis sims (no fork, AGENTS.tape f3) and emits one row per perturbation under a shared Caspar-Klug T-number geometry. In-silico simulator-consistency scope only (g8/f2); modalities by own precedent (g3/f1); no n=6-lattice derivation (f_lattice_fit). Comparison reports magnitudes only — NOT a superiority verdict.",
  "type": "object",
  "required": [
    "schema", "perturbation_id", "perturbation_note", "delta_dg_contact_kcal",
    "reference_t_number", "caspar_klug_geometry", "c_total",
    "natural_side", "designed_side",
    "natural_axis", "designed_axis"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {"const": "capsid_modulator_weave_cross_v1"},
    "perturbation_id": {"type": "string", "minLength": 1},
    "perturbation_note": {"type": "string"},
    "delta_dg_contact_kcal": {"type": "number"},
    "reference_t_number": {"type": "integer", "minimum": 1},
    "caspar_klug_geometry": {
      "type": "object",
      "required": ["t_number", "n_subunits", "n_pentamers", "n_hexamers", "euler_invariant_ok"],
      "properties": {
        "t_number": {"type": "integer", "minimum": 1},
        "n_subunits": {"type": "integer", "minimum": 60},
        "n_pentamers": {"type": "integer", "const": 12},
        "n_hexamers": {"type": "integer", "minimum": 0},
        "euler_invariant_ok": {"const": true}
      }
    },
    "c_total": {"type": "number", "exclusiveMinimum": 0},
    "natural_side": {"$ref": "#/definitions/sideState"},
    "designed_side": {"$ref": "#/definitions/sideState"},
    "natural_axis": {"type": "string"},
    "designed_axis": {"type": "string"},
    "weave_axis_source": {"type": "string"},
    "weave_assembly_basis": {"type": "string"},
    "weave_reference_target": {"type": "string"},
    "comparison": {
      "type": "object",
      "additionalProperties": true
    },
    "illustrative_only": {"type": "boolean", "const": true}
  },
  "definitions": {
    "sideState": {
      "type": "object",
      "required": ["baseline_c_star", "baseline_assembled_fraction",
                   "perturbed_c_star", "perturbed_assembled_fraction",
                   "assembled_fraction_shift", "kinetic_trap_regime"],
      "properties": {
        "baseline_c_star": {"type": "number", "exclusiveMinimum": 0},
        "baseline_assembled_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "perturbed_c_star": {"type": "number", "exclusiveMinimum": 0},
        "perturbed_assembled_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "assembled_fraction_shift": {"type": "number", "minimum": -1, "maximum": 1},
        "kinetic_trap_regime": {"type": "boolean"}
      }
    }
  }
}
