{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/virocapsid/spec/pdb_corpus_subclause_audit_v1.schema.json",
  "title": "F-VIROCAPSID-1 sub-clause closure audit witness v1",
  "description": "Aggregate witness emitted by virocapsid_corpus_subclause_audit.py. Per-sub-clause verdicts (-genus / -1-b / -1-c / -1-d) on the n=10 corpus.",
  "type": "object",
  "required": [
    "schema",
    "audited_at",
    "n_corpus",
    "f_virocapsid_1_subclauses",
    "overall_pass",
    "witness_ref"
  ],
  "properties": {
    "schema": {"type": "string", "const": "raw_77_virocapsid_pdb_corpus_subclause_audit_v1"},
    "audited_at": {"type": "string", "format": "date-time"},
    "n_corpus": {"type": "integer", "minimum": 1},
    "f_virocapsid_1_subclauses": {
      "type": "object",
      "required": ["f_virocapsid_1_genus", "f_virocapsid_1_b", "f_virocapsid_1_c", "f_virocapsid_1_d"],
      "properties": {
        "f_virocapsid_1_genus": {"type": "object"},
        "f_virocapsid_1_b": {"type": "object"},
        "f_virocapsid_1_c": {"type": "object"},
        "f_virocapsid_1_d": {"type": "object"}
      }
    },
    "overall_pass": {"type": "boolean"},
    "raw_91_c3_disclose": {"type": "string"},
    "raw_77_append_only": {"type": "boolean"},
    "witness_ref": {
      "type": "string",
      "pattern": "^state/discovery_absorption/registry\\.jsonl#raw_77_virocapsid_pdb_corpus_subclause_audit_v1$"
    }
  }
}
