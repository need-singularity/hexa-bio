{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/virocapsid/spec/kinetic_trap_v1.schema.json",
  "title": "F-VIROCAPSID-4 kinetic-trap audit witness v1",
  "description": "Aggregate witness emitted by virocapsid_kinetic_trap_audit.py. Sub-clause results (-kinetic-trap / -4-b / -4-c) computed from cage_assembly_simulation trajectory.",
  "type": "object",
  "required": [
    "schema",
    "audited_at",
    "audit_kind",
    "trajectory_summary",
    "f_virocapsid_4_subclauses",
    "witness_ref"
  ],
  "properties": {
    "schema": {"type": "string", "const": "raw_77_virocapsid_kinetic_trap_v1"},
    "audited_at": {"type": "string", "format": "date-time"},
    "audit_kind": {"type": "string"},
    "trajectory_summary": {
      "type": "object",
      "required": ["params", "c0", "t_end"],
      "properties": {
        "params": {"type": "object"},
        "c0": {"type": "number"},
        "t_end": {"type": "number"},
        "y_aberrant_max": {"type": "number"},
        "y_aberrant_final": {"type": "number"},
        "y_closed_final": {"type": "number"},
        "ratio_aberrant_to_closed": {"type": ["number", "null"]},
        "ratio_aberrant_sentinel": {"type": ["string", "null"]}
      }
    },
    "f_virocapsid_4_subclauses": {
      "type": "object",
      "required": ["f_virocapsid_4_kinetic_trap", "f_virocapsid_4_b", "f_virocapsid_4_c"]
    },
    "raw_91_c3_disclose": {"type": "string"},
    "raw_77_append_only": {"type": "boolean"},
    "witness_ref": {
      "type": "string",
      "pattern": "^state/discovery_absorption/registry\\.jsonl#raw_77_virocapsid_kinetic_trap_v1$"
    }
  }
}
