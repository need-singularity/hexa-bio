#!hexa strict
// virocapsid/module/virocapsid.hexa — VIROCAPSID verb (HEXA-family axis 4/4)
//
// STATUS: STUB v1.0.0 + F-VIROCAPSID-3 calibration (cycle 24).
//          C0b deliverable closed via _python_bridge/module/
//          virocapsid_calibration.py — lifts cage MVP yield from 0.68
//          plateau to ≥ 0.85 at the backward_euler stability corner.
//
// HEXA-family role: assembly (large-scale self-organizing protein
// supramolecular complexes — T=1/3/7/13 cages, sister to weave
// (composition), nanobot (actuation), ribozyme (catalysis)).
//
// n=6 invariant binding (T=1 PARTIALLY verified via weave's audit):
//   σ(6) = 12  STRUCTURAL-EXACT for T=1 cage (vertex count, posterior 0.97
//                                              — see weave Bayesian audit).
//              UNVERIFIED for T>1 capsids — V-R2 stretch (cycle 25+).
//   τ(6) = 4   4 assembly stages (nucleation / elongation /
//              closure / maturation).
//   φ(6) = 2   assembled vs disassembled dichotomy.
//   J₂   = 24  octahedral O ⊂ icosahedral I (geometric, exact for T=1).
//
// Falsifiers (.roadmap.virocapsid §10):
//   F-VIROCAPSID-1   — live-PDB scrape n ≥ 100 cages →
//                       posterior(STRUCTURAL-EXACT) ≥ 0.95 reproduce
//                       (deadline 2027-04-28).
//   F-VIROCAPSID-2   — RESOLVED cycle 22 (Bayesian audit posterior 0.9668
//                       on n=34 corpus, log Bayes factor 3.37 decisive).
//   F-VIROCAPSID-3   — calibration fit closes cage MVP yield 0.68 → 0.85+
//                       on STNV (T=1) reference (deadline 2026-07-28;
//                       C0b PASS via virocapsid_calibration.py).
//   F-VIROCAPSID-COLLISION — sister-axis boundary vs life/virology/ +
//                       life/vaccine/ (PASS clean — declared in V-R3,
//                       audit 2026-05-05).
//
// raw#10 honest C3:
//   - Calibration confined to T=1 (60-subunit cage, cycle-22 baseline).
//     T=3/T=4 (CCMV/HBV) need per-system rate-constant re-derivation due
//     to K_n × C(0)^n scaling (5th and 12th powers) — V-R2 stretch.
//   - Calibrated params at backward_euler stability corner (K_CLOSE=1e-7,
//     K12=1e-6); higher values cause fixed-point divergence at dt=0.01.
//   - Yield asymptote ~0.855 at t=10000s — narrowly clears 0.85 target.

let VERSION = "1.0.0-stub-c0b"
let MODULE  = "virocapsid"

fn _root() -> str {
    let r = env("HEXA_BIO_ROOT")
    if r.len() > 0 { return r }
    let inferred = exec("dirname \"$(dirname \"$(dirname \"$0\")\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return env("HOME") + "/.hexa-bio"  // @allow-devpath
}

fn _shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _python_path(script: str) -> str {
    let root = _root()
    return root + "/_python_bridge/module/" + script
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + _shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _print_n6_lattice() {
    println("  n=6 invariant lattice (virocapsid):")
    println("    σ(6) = 12  STRUCTURAL-EXACT for T=1 cage (posterior 0.97 via weave)")
    println("                UNVERIFIED for T>1 (T=3/7/13) — V-R2 stretch")
    println("    τ(6) = 4   4 assembly stages")
    println("    φ(6) = 2   assembled vs disassembled")
    println("    J₂   = 24  octahedral O ⊂ icosahedral I")
}

fn _print_falsifiers() {
    println("  falsifiers (.roadmap.virocapsid):")
    println("    F-VIROCAPSID-1            live-PDB n≥100 posterior ≥ 0.95     (deadline 2027-04-28)")
    println("    F-VIROCAPSID-2            RESOLVED cycle 22 (posterior 0.9668)")
    println("    F-VIROCAPSID-3            yield 0.68→0.85+ on T=1 (STNV)      (deadline 2026-07-28, C0b)")
    println("    F-VIROCAPSID-COLLISION    PASS clean (sister-axis declared in V-R3)")
}

fn _print_status() {
    println("  status: STUB v1.0.0 + C0b calibration (cycle 24)")
    println("          T=1 path empirically grounded via weave + virocapsid_calibration")
    println("          T>1 + live-PDB sandbox deferred to V-R2 stretch (cycle 25+)")
}

fn run_calibration(reference: str, mode: str) -> str {
    // Opt-in gate (weave precedent): HEXA_BIO_WITH_NUMPY=1 enables Python
    // bridge execution. Calibration script is stdlib-only (no numpy/scipy)
    // but the env flag is the canonical signal that local python3 is
    // available — it skips the Python path under docker hard-landing.
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[virocapsid] HEXA_BIO_WITH_NUMPY != 1 — calibration skipped")
        println("[virocapsid] (set HEXA_BIO_WITH_NUMPY=1 to run virocapsid_calibration.py)")
        println("[virocapsid] cached F-VIROCAPSID-3 result (cycle 24, --mode verify):")
        println("[virocapsid]   reference: STNV (T=1, 60-subunit)")
        println("[virocapsid]   yield_t10000 = 0.8546  (>= 0.85 PASS)")
        println("[virocapsid]   params: K12=1e-6 K21=1e-4 K_CLOSE=1e-7 K_OPEN=1e-14")
        println("[virocapsid]   integrator: backward_euler (stiffness-stable)")
        return "skipped-no-opt-in"
    }
    let script = _python_path("virocapsid_calibration.py")
    if _file_exists(script) == false {
        eprintln("[virocapsid] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let cmd = ("python3 " + _shq(script)
               + " --reference " + _shq(reference)
               + " --mode " + _shq(mode)
               + " 2>&1")
    let raw = exec(cmd)
    println(raw.trim())
    return "ran"
}

fn run_multi_t(t_number: str) -> str {
    // V-R2 stretch (cycle 25): multi-T calibration extension to T=3/T=4.
    // Same opt-in gate as run_calibration — HEXA_BIO_WITH_NUMPY=1 enables
    // the Python bridge. Stdlib-only script, so the env var is signaling
    // python3 availability rather than numpy specifically.
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[virocapsid] HEXA_BIO_WITH_NUMPY != 1 — multi-T calibration skipped")
        println("[virocapsid] (set HEXA_BIO_WITH_NUMPY=1 to run virocapsid_multi_t_calibration.py)")
        println("[virocapsid] cached V-R2 result (cycle 25, --t-number all):")
        println("[virocapsid]   T=3 (CCMV, 180-subunit): yield_t10000 = 0.8546  (>= 0.85 PASS)")
        println("[virocapsid]   T=4 (HBV,  240-subunit): yield_t10000 = 0.8545  (>= 0.85 PASS)")
        println("[virocapsid]   scaling: K12 / (c0/60)^4, K_CLOSE / (c0/60)^11")
        println("[virocapsid]   integrator: backward_euler (stiffness-stable)")
        return "skipped-no-opt-in"
    }
    let script = _python_path("virocapsid_multi_t_calibration.py")
    if _file_exists(script) == false {
        eprintln("[virocapsid] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let cmd = ("python3 " + _shq(script)
               + " --t-number " + _shq(t_number)
               + " 2>&1")
    let raw = exec(cmd)
    println(raw.trim())
    return "ran"
}

fn run_c2_aml() -> str {
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[virocapsid] HEXA_BIO_WITH_NUMPY != 1 — C2 V·α candidate skipped")
        println("[virocapsid] (set HEXA_BIO_WITH_NUMPY=1 to run virocapsid_aml_loop_annotation_candidate.py)")
        println("[virocapsid] cached cycle-25 result (C2 cell V·α):")
        println("[virocapsid]   peptide marker (public open-access lit catalogued): WT1")
        println("[virocapsid]   cage class: T=1 60-subunit icosahedral polyhedron")
        println("[virocapsid]   surface-loop annotation: RMFPNAPYL (sequence-level metadata only)")
        println("[virocapsid]   modeled_by_simulator: False (sequence-level field, no MHC/immune modeling)")
        println("[virocapsid]   verification: F-VIROCAPSID-3 PASS (yield=0.8546 at t=10000)")
        println("[virocapsid]   in-silico-only — no clinical / immunological / therapeutic claim")
        return "skipped-no-opt-in"
    }
    let script = _python_path("virocapsid_aml_loop_annotation_candidate.py")
    if _file_exists(script) == false {
        eprintln("[virocapsid] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let cmd = "python3 " + _shq(script) + " 2>&1"
    let raw = exec(cmd)
    println(raw.trim())
    return "ran"
}

