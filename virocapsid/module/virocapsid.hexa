    let script = _python_path("virocapsid_scd_loop_annotation_candidate.py")
    if _file_exists(script) == false { eprintln("[virocapsid] ERROR: " + script); return "error-missing-script" }
    let raw = exec("python3 " + _shq(script) + " 2>&1")
    println(raw.trim())
    return "ran"
}

