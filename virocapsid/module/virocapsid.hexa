fn cmd_virocapsid(args: [str]) {
    println("hexa-bio " + MODULE + " " + VERSION + " — viral capsid assembly primitive")
    println("")

    let mut mode = "skeleton"
    let mut reference = "stnv"
    let mut calib_mode = "verify"
    let mut t_number = "all"
    let mut i = 0
    while i < args.len() {
        let a = args[i]
        if a == "--calibrate" { mode = "calibrate" }
        if a == "--multi-t" { mode = "multi-t" }
        if a == "--c2-aml" { mode = "c2-aml" }
        if a == "--c2-scd" { mode = "c2-scd" }
        if a == "--c2-pancov" { mode = "c2-pancov" }
        if a == "--c2-senolytic" { mode = "c2-senolytic" }
        if a == "--reference" {
            if i + 1 < args.len() { reference = args[i + 1] }
        }
        if a == "--mode" {
            if i + 1 < args.len() { calib_mode = args[i + 1] }
        }
        if a == "--t-number" {
            if i + 1 < args.len() { t_number = args[i + 1] }
        }
        i = i + 1
    }

    if mode == "skeleton" {
        _print_status()
        println("")
        _print_n6_lattice()
        println("")
        _print_falsifiers()
        println("")
        println("usage: hexa-bio virocapsid [--calibrate [--reference {stnv|ccmv|hbv|all}] [--mode {verify|search}]]")
        println("                            [--multi-t [--t-number {3|4|all}]]   # V-R2 stretch (cycle 25)")
        println("[virocapsid] no action specified — printed lattice + falsifier table only")
        println("__HEXA_BIO_VIROCAPSID__ PASS")
        return
    }

    if mode == "calibrate" {
        println("--- F-VIROCAPSID-3 calibration (reference=" + reference + ", mode=" + calib_mode + ") ---")
        run_calibration(reference, calib_mode)
        println("")
        _print_n6_lattice()
        println("")
        println("__HEXA_BIO_VIROCAPSID__ PASS")
        return
    }

    if mode == "multi-t" {
        println("--- V-R2 stretch multi-T calibration (t-number=" + t_number + ") ---")
        run_multi_t(t_number)
        println("")
        _print_n6_lattice()
        println("")
        println("__HEXA_BIO_VIROCAPSID__ PASS")
        return
    }

    if mode == "c2-aml" {
        println("--- C2 cell V·α (VIROCAPSID × α=AML, surface-loop annotation candidate) ---")
        run_c2_aml()
        println("")
        _print_n6_lattice()
        println("")
        println("__HEXA_BIO_VIROCAPSID__ PASS")
        return
    }
    if mode == "c2-scd" {
        println("--- C2 cell V·β (VIROCAPSID × β=SCD) ---")
        run_c2_scd()
        println("")
        println("__HEXA_BIO_VIROCAPSID__ PASS")
        return
    }
    if mode == "c2-pancov" {
        println("--- C2 cell V·γ (VIROCAPSID × γ=pancov) ---")
        run_c2_pancov()
        println("")
        println("__HEXA_BIO_VIROCAPSID__ PASS")
        return
    }
    if mode == "c2-senolytic" {
        println("--- C2 cell V·δ (VIROCAPSID × δ=senolytic) ---")
        run_c2_senolytic()
        println("")
        println("__HEXA_BIO_VIROCAPSID__ PASS")
    }
}

fn main() {
    let raw = args()
    let mut user: [str] = []
    let mut sidx = -1
    let mut i = 0
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut start = 1
    if sidx >= 0 { start = sidx + 1 }
    let mut k = start
    while k < raw.len() {
        user = user + [raw[k]]
        k = k + 1
    }
    cmd_virocapsid(user)
}
