#!/usr/bin/env tape
# ══════════════════════════════════════════════════════════════════════
# .tape v1.2 — grammar primer (cold-read by any LLM / agent / human)
# ══════════════════════════════════════════════════════════════════════
# Form: each entry is `@<type> <id> := "<subject>" :: <kind> [<grades>]`
#       optionally followed by body lines (2-space indent) — key=value,
#       edges (<- -> => …), or quoted prose.
#
# ENTRY TYPES (17):
#   Runtime (10): @S session  @U user  @A assistant  @T tool-call  @R result
#                 @H hook  @D decision  @K cost  @P provider  @? anomaly
#   Foundation:   @I identity-claim
#   Declarative:  @X external-citation  @F forbidden-pattern  @N note
#                 @C config  @L layout  @V spec-version
#
# EDGES (12, on body lines, 2-space indent):
#   Causal:     <- caused-by   -> triggers   == continues
#               ~> supersedes  !! aborts     |> verified-by
#   Effect:     => produces (followed by quoted natural-language)
#   Structural: <: specializes  :> generalizes  ?> soft-depends
#               !> conflicts-with  @> projects-to (e.g. @> AGENTS.md)
#
# GRADE TAGS (in [...] on entry header):
#   Delivery:   ok · err · denied · cancelled · partial · superseded
#   Governance: required · recommended · optional · draft · active · deprecated
#   Scoped:     allow:<x> · deny:<x>
#   Time/index: T<n> (turn)  N<n> (wall-sec)  d=<YYYY-MM-DD>
#
# PAYLOAD SYNTAX (body lines):
#   key = "value"           single-line string
#   key = [a, b, c]         array literal
#   key <<~EOF              heredoc (multi-line; ends with EOF on own line)
#     multi-line text
#   EOF
#   "see [@x1] §3"          inline citation by entry id
#   `cmd or path`           backtick code-span (inline only)
#
# Full spec: ~/core/tape/spec/tape.md (or github.com/dancinlab/tape)
# ══════════════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# ══════════════════════════════════════════════════════════════
# ENTOMOLOGY.log.tape — append-only event history (v1.2 split)
# Sibling: ENTOMOLOGY.tape (architecture-current, editable)
# Repo-of-record: dancinlab/hexa-bio
# ══════════════════════════════════════════════════════════════

# §Log — entries chronological, oldest first.

@A rewrite_from_lattice_tautology := "ENTOMOLOGY.tape rewritten from lattice-tautology stub into real entomology science SSOT" :: rewrite [ok d=2026-05-16]
  origin = "ENTOMOLOGY.tape was a fabricated lattice-tautology stub from the hexa-bio mass-split (commit 153b5a2): ~1500 lines, almost entirely @D row_* / @D b_* entries asserting insect morphological counts as lattice EXACT fits (e.g. '곤충 다리 6 = n EXACT', '체부 3 = n/φ EXACT', '완전변태 4단계 = τ EXACT', '곤충목 수 30 = n·sopfr EXACT', '벌집 셀 6각형 = n EXACT'). The stub's brief stated '곤충학 n=6 완전 아키텍처 · 23/23 EXACT · BT-352'. The kind field itself claimed 'HEXA-Bio family · n=6 Hexapoda full entomology architecture' — treating Hexapoda's defining 6-leg character as lattice-derived. Zero real citations, zero real limits, zero falsifiable predictions. Deleted in full."
  n6-honesty-correction = "EXPLICIT n=6 → HEXAPODA HONESTY CORRECTION: The stub wrongly framed 'Hexapoda = n=6 lattice' as a derivational relationship — asserting that insects have 6 legs BECAUSE of the n=6 lattice constant. This is a governance violation (AGENTS.tape @F f1 + g1/g2 + LATTICE_POLICY). The rewrite explicitly states: 6 legs is a MORPHOLOGICAL FACT arising from 3 thoracic segments × 2 legs per segment, conserved by ~400 Ma of evolution. The name 'Hexapoda' is Greek for 'six-footed' — it records an OBSERVED anatomy, exactly as naming something 'pentagon' does not derive pentagons from a pentagon-theory. The numerical coincidence with n=6 is OBSERVATION ONLY; the same discipline HEXA-VIROCAPSID (commit e026183) applied to 'HBV T=4 is not n=6 lattice derivation' is applied here identically. The @N n6_honest_stance entry documents this explicitly."
  authored = "Hand-written with real entomology science + landmark literature. Replaced zero biology with: Hexapoda body plan (3 tagmata, 6 legs morphological origin, tracheal respiration, compound eyes, bilateral antennae — Grimaldi & Engel 2005, Gullan & Cranston 2014); insect vs Entognatha classification (Collembola/Protura/Diplura non-insect Hexapoda); major orders (Coleoptera, Diptera, Hymenoptera, Lepidoptera, Hemiptera, Odonata — Misof et al 2014 phylogenomics); metamorphosis (hemimetabolous vs holometabolous, proto-larva hypothesis — Truman & Riddiford 1999 Nature); exoskeleton (chitin/sclerotization DOPA→quinone cross-linking, ecdysis hormonal regulation, size-limit via tracheal diffusion/atmospheric O₂ in Carboniferous); flight evolution (paranotal vs gill-exite hypotheses, haltere gyroscopic function in Diptera); ecological roles (pollination ~87% flowering plants, herbivory, predation, parasitoidism, decomposition); IPM (Stern ~1959 economic threshold; kdr/RDL/AChE resistance mechanisms; Bt Cry/Vip proteins + Tabashnik 2013 field resistance); insect decline (Hallmann 2017 PLOS ONE 12:e0185809 >75% biomass decline; van Klink 2020 Science 368:417-420 global meta-analysis terrestrial/freshwater divergence; Sánchez-Bayo & Wyckhuys 2019 Biol Conserv 232:8-27); insects as resources (FAO 2013 edible insects, Bombyx mori silk, honey, biocontrol). Five @D :: real-limit anchors: pesticide-resistance evolution HARD WALL; habitat loss; undescribed diversity unknowable extinction floor; climate niche shifts SOFT WALL; Bt-resistance field evolution HARD WALL. Three falsifiable @D :: prediction entries with explicit falsifiers."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: entomology exposes NO natural n=6 invariant that is lattice-derived. Morphological/taxonomic counts (6 legs, 3 tagmata, 4 holometabolous stages, ~26–33 orders) are BIOLOGY — set by evolution, developmental genetics, and taxonomic convention, not lattice arithmetic. Hexapoda is named for observed anatomy; the numerical coincidence with n=6 is observation only. This honesty is the explicit corrective for the audited n=6→Hexapoda lattice-derivation stub."
  governance = "Complies with hexa-bio AGENTS.tape @D g1 (real-limits-first — every @D domain entry |>-grounded to real @X), @D g2 (lattice-is-tool — declined here), @D g8 (in-silico-only-claim-scope — @N scope_disclaimer: knowledge SSOT, NOT pesticide prescription / farming protocol / regulatory claim), @F f1 (no lattice-fit on external entities — all counts are biology/evolution/convention). No fabricated numbers or citations: counts and figures are paraphrased from cited literature. Grimaldi & Engel 2005 (Cambridge UP — confident); Gullan & Cranston 2014 Wiley-Blackwell (confident); Misof et al 2014 Science 346:763-767 (confident — landmark, confident if known); Truman & Riddiford 1999 Nature 401:447-452 (confident); Hallmann et al 2017 PLOS ONE 12:e0185809 (confident — widely cited, specific DOI widely confirmed); van Klink et al 2020 Science 368:417-420 (confident); Sánchez-Bayo & Wyckhuys 2019 Biol Conserv 232:8-27 (era-flagged, author/era OK); Tabashnik et al 2013 Nature Biotechnology 31:510-521 (confident, specific volume/pages asserted from well-known review)."
  lint = "python3 selftest/tape_lattice_honesty_lint.py ENTOMOLOGY.tape --json → {verdict: PASS, deriv_warnings: [], has_guard: true, has_stance: true, grounded: true} — __TAPE_LATTICE_HONESTY__ PASS. Zero derivation warnings (clean, not merely guarded-and-tolerated)."
