#!/usr/bin/env tape
# ══════════════════════════════════════════════════════════════════════
# .tape v1.2 — grammar primer (cold-read by any LLM / agent / human)
# ══════════════════════════════════════════════════════════════════════
# Form: each entry is `@<type> <id> := "<subject>" :: <kind> [<grades>]`
#       optionally followed by body lines (2-space indent) — key=value,
#       edges (<- -> => …), or quoted prose.
#
# ENTRY TYPES (17):
#   Runtime (10): @S session  @U user  @A assistant  @T tool-call  @R result
#                 @H hook  @D decision  @K cost  @P provider  @? anomaly
#   Foundation:   @I identity-claim
#   Declarative:  @X external-citation  @F forbidden-pattern  @N note
#                 @C config  @L layout  @V spec-version
#
# EDGES (12, on body lines, 2-space indent):
#   Causal:     <- caused-by   -> triggers   == continues
#               ~> supersedes  !! aborts     |> verified-by
#   Effect:     => produces (followed by quoted natural-language)
#   Structural: <: specializes  :> generalizes  ?> soft-depends
#               !> conflicts-with  @> projects-to (e.g. @> AGENTS.md)
#
# GRADE TAGS (in [...] on entry header):
#   Delivery:   ok · err · denied · cancelled · partial · superseded
#   Governance: required · recommended · optional · draft · active · deprecated
#   Scoped:     allow:<x> · deny:<x>
#   Time/index: T<n> (turn)  N<n> (wall-sec)  d=<YYYY-MM-DD>
#
# PAYLOAD SYNTAX (body lines):
#   key = "value"           single-line string
#   key = [a, b, c]         array literal
#   key <<~EOF              heredoc (multi-line; ends with EOF on own line)
#     multi-line text
#   EOF
#   "see [@x1] §3"          inline citation by entry id
#   `cmd or path`           backtick code-span (inline only)
#
# Full spec: ~/core/tape/spec/tape.md (or github.com/dancinlab/tape)
# ══════════════════════════════════════════════════════════════════════


# ══════════════════════════════════════════════════════════════
# GASTROINTESTINAL-MEDICINE.log.tape — append-only event history (v1.2 split)
# Sibling: GASTROINTESTINAL-MEDICINE.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite := "GASTROINTESTINAL-MEDICINE.tape rewritten from lattice-tautology stub to real-science SSOT" :: rewrite [ok d=2026-05-16]
  origin = "GASTROINTESTINAL-MEDICINE.tape was a fabricated lattice-tautology stub (created in the hexa-bio mass-split, commit 153b5a2). It carried only three lattice-fit assertions ('6 GI segments — endoscopy staging primitive', '6 dominant gut-microbiome phyla', '6 fps capsule-endoscopy baseline') under @D :: gastrointestinal-medicine rows, plus three prose 'source' rows naming Sleisenger & Fordtran, HMP and FDA capsule-endoscopy standards without any structured @X citations — a direct LATTICE_POLICY g1/g2 + f1 violation (counts derived from / aligned to n=6 without underlying-biology grounding). Every b_* stub entry deleted."
  authored = "Hand-written with real GI medicine + landmark clinical citations. Replaces ZERO biology with: GI anatomy + physiology (parietal-cell H+/K+-ATPase + Black 1988 Nobel H2-receptor pharmacology era + Lindberg 1990-era omeprazole/PPI development; chief/G/ECL/D/mucous cell roles; ENS motility; pancreatobiliary + enterohepatic), acid-related disease (PUD + Marshall & Warren 1984 Lancet H. pylori discovery / 2005 Nobel, test-and-treat, eradication regimen class names without dosing, MALT-lymphoma reversibility; GERD + Barrett's; PPI class names + H2-blocker class), IBD (Crohn's transmural/skip/terminal-ileum vs UC mucosal/continuous/rectal; NOD2 — Hugot 2001 Nature; biologics era — anti-TNF infliximab Hanauer 2002 ACCENT-I Lancet, anti-α4β7 vedolizumab, anti-IL-12/23 ustekinumab, newer IL-23p19 / JAK / S1P classes), IBS (Rome IV institutional criteria; brain-gut axis; visceral hypersensitivity; microbiota), microbiome (Bäckhed/Gordon gnotobiotic era; 16S vs shotgun methods; HMP/MetaHIT institutional consortia; Bacteroidetes+Firmicutes phylum-level dominance), C. difficile + FMT (van Nood 2013 NEJM landmark RCT stopped early for efficacy), hepatology overview (HBV/HCV with VIROLOGY cross-link; MASLD/MASH renaming — Rinella 2023 era; cirrhosis; HCC with CANCER-THERAPY cross-link), and colorectal cancer screening (adenoma-carcinoma sequence; colonoscopy operator-dependent benefit; FIT; sDNA Cologuard with NDRG4/BMP3/KRAS markers). 5 real-limit anchors: IBD relapse + biologic loss-of-response (HARD), IBS pathophysiologic heterogeneity (HARD), microbiome causality vs correlation (SOFT, evolving), colonoscopy operator/ADR variability (HARD process), no universal GI cure (HARD current science). 3 falsifiable predictions with falsifiers + sourced (MALT regression on H. pylori eradication; FMT superiority over vancomycin in recurrent CDI; ACCENT-I scheduled vs episodic anti-TNF maintenance). 10 real @X :: literature citations."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: GI medicine exposes NO natural n=6 invariant. GI tract segment count is a descriptive-granularity convention (not lattice). Gut-microbiome phylum dominance is two (Bacteroidetes+Firmicutes) plus a long-tail — not 'six'. Capsule-endoscopy frame rate is device-specific engineering, not lattice-derived. IBD entities (CD/UC + indeterminate), IBS Rome subtypes, AJCC stage groups (GI cancers), and hepatology severity scores (Child-Pugh, MELD) are clinical ordinals revised across editions — not closed n-tuples. Coincidence is observation-only, never derivation. This honesty IS the corrective for the audited lattice-tautology stub."
  governance = "Complies with hexa-bio AGENTS.tape g1 (real-limits-first — 5 real-limit anchors), g2 (lattice-is-tool — declined as derivation), g8 (in-silico-only-claim-scope — @N scope_disclaimer added; explicit 'NOT clinical advice' identity scope), f1 (no lattice-fit), f2 (no in-silico→clinical/efficacy claim — drug class names without dosing, regimen choices deferred to clinicians, no comparative-efficacy assertions). Provenance recorded in @I id001 rewritten-from key."
  honesty-caveats = "No fabricated numbers/citations. Four confident landmark refs with full citation: Marshall & Warren 1984 Lancet 1:1311–1315 (H. pylori); Hugot et al 2001 Nature 411:599–603 (NOD2 Crohn's); Hanauer et al 2002 Lancet 359:1541–1549 (ACCENT-I infliximab); van Nood et al 2013 NEJM 368:407–415 (FMT recurrent CDI). Six author/era-flagged refs (volume/journal not asserted, only well-known anchor stated): x_black_era (J. W. Black H2-receptor pharmacology, 1988 Nobel context); x_lindberg_era (Astra/AstraZeneca omeprazole, late-1980s/1990 era); x_rome_iv_era (Rome Foundation Rome IV institutional criteria, 2016-era); x_backhed_gordon_era (Bäckhed/Gordon gnotobiotic-mouse paradigm); x_hmp_metahit_era (HMP/MetaHIT consortia institutional catalogues); x_rinella_2023_era (MASLD/MASH renaming consensus). Drug-class names listed without dosing (PPI class, H2-blocker class, anti-TNF/vedolizumab/ustekinumab/IL-23p19/JAK/S1P). Mirrors gold-tape (ANDROGENETIC-ALOPECIA / CANCER-THERAPY) and CANCER-THERAPY.log.tape audit discipline."
  lint = "python3 selftest/tape_lattice_honesty_lint.py GASTROINTESTINAL-MEDICINE.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true, deriv_warnings as expected for guard/stance provenance only; zero live lattice-derivation lines; all b_* garbage deleted)."
