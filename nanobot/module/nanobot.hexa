fn cmd_nanobot(args: [str]) {
    println("hexa-bio " + MODULE + " " + VERSION + " — molecular actuation primitive")
    println("")

    let mut mode = "skeleton"
    let mut cycles = "10000"
    let mut T_k = "310"
    let mut skeleton = "truncated_icosahedron"
    let mut seed = "42"
    let mut audit_no_emit = false
    let mut audit_quiet = false
    let mut i = 0
    while i < args.len() {
        let a = args[i]
        if a == "--actuation" { mode = "actuation" }
        if a == "--bayesian-audit" { mode = "bayesian-audit" }
        if a == "--c2-aml" { mode = "c2-aml" }
        if a == "--c2-scd" { mode = "c2-scd" }
        if a == "--c2-pancov" { mode = "c2-pancov" }
        if a == "--c2-senolytic" { mode = "c2-senolytic" }
        if a == "--no-emit" { audit_no_emit = true }
        if a == "--quiet" { audit_quiet = true }
        if a == "--cycles" {
            if i + 1 < args.len() { cycles = args[i + 1] }
        }
        if a == "--T" {
            if i + 1 < args.len() { T_k = args[i + 1] }
        }
        if a == "--skeleton" {
            if i + 1 < args.len() { skeleton = args[i + 1] }
        }
        if a == "--seed" {
            if i + 1 < args.len() { seed = args[i + 1] }
        }
        i = i + 1
    }

    if mode == "skeleton" {
        _print_status()
        println("")
        _print_n6_lattice()
        println("")
        _print_falsifiers()
        println("")
        println("usage: hexa-bio nanobot [--actuation [--cycles N] [--T K] [--skeleton {truncated_icosahedron|cuboctahedron}] [--seed N]]")
        println("                        [--bayesian-audit [--no-emit] [--quiet]]")
        println("[nanobot] no action specified — printed lattice + falsifier table only")
        println("__HEXA_BIO_NANOBOT__ PASS")
        return
    }

    if mode == "actuation" {
        println("--- F-NB-4 actuation MVP (4-state 12-vertex DNA-origami, cycles=" + cycles
                + ", T=" + T_k + "K, skeleton=" + skeleton + ", seed=" + seed + ") ---")
        run_actuation(cycles, T_k, skeleton, seed)
        println("")
        _print_n6_lattice()
        println("")
        println("__HEXA_BIO_NANOBOT__ PASS")
    }

    if mode == "bayesian-audit" {
        println("--- F-NB-2 Bayesian audit (n=30 architectural primitives, C0c deadline 2026-09-28) ---")
        run_bayesian_audit(audit_no_emit, audit_quiet)
        println("")
        _print_n6_lattice()
        println("")
        println("__HEXA_BIO_NANOBOT__ PASS")
    }

    if mode == "c2-aml" {
        println("--- C2 cell N·α (NANOBOT × α=AML, decorated 12-vertex skeleton candidate) ---")
        run_c2_aml()
        println("")
        _print_n6_lattice()
        println("")
        println("__HEXA_BIO_NANOBOT__ PASS")
    }
    if mode == "c2-scd" {
        println("--- C2 cell N·β (NANOBOT × β=SCD) ---")
        run_c2_scd()
        println("")
        println("__HEXA_BIO_NANOBOT__ PASS")
    }
    if mode == "c2-pancov" {
        println("--- C2 cell N·γ (NANOBOT × γ=pancov) ---")
        run_c2_pancov()
        println("")
        println("__HEXA_BIO_NANOBOT__ PASS")
    }
    if mode == "c2-senolytic" {
        println("--- C2 cell N·δ (NANOBOT × δ=senolytic) ---")
        run_c2_senolytic()
        println("")
        println("__HEXA_BIO_NANOBOT__ PASS")
    }
}

fn main() {
    let raw = args()
    let mut user: [str] = []
    let mut sidx = -1
    let mut i = 0
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut start = 1
    if sidx >= 0 { start = sidx + 1 }
    let mut k = start
    while k < raw.len() {
        user = user + [raw[k]]
        k = k + 1
    }
    cmd_nanobot(user)
}
