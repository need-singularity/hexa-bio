{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hexa-bio/nanobot/spec/proposed_l7_l9_witness_schemas/raw_77_therapeutic_nanobot_l9_biodistribution_v1.schema.json",
  "title": "raw_77_therapeutic_nanobot_l9_biodistribution_v1 — L9 biodistribution witness (CONSUMER-PROPOSED draft, hexa-bio → canon)",
  "description": "CONSUMER-PROPOSED draft (hexa-bio → canon). The canonical handoff JSON (canon@mk1:domains/life/therapeutic-nanobot/handoff/2026-05-28_hexa-nanobot-therapeutic-nanobot-boundary.json, raw_77_therapeutic_nanobot_l7_acceptance_v1, DECLARED v1.0.0-stub) names this schema as a placeholder; this file is hexa-bio's proposed field-set, derived from that handoff JSON's per-layer `responsibility` + `primitives` + `consumes_from_l6`. Canon adopts/edits and the file's source-of-truth becomes canon/domains/life/therapeutic-nanobot/spec/. raw_91 C3: a contract draft — boundary acknowledgment level; NO wet-lab/clinical claim; wet-lab + IP/contract review = canon cycle-30+. L9 = tissue-targeting kinetics + clearance-pathway selection; consumes_from_l6 = {actuator_id}.",
  "type": "object",
  "required": [
    "schema",
    "actuator_id",
    "l6_witness_ref",
    "clearance_kinetics",
    "tissue_targeting",
    "excretion_pathway"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "raw_77_therapeutic_nanobot_l9_biodistribution_v1"
    },
    "actuator_id": {
      "type": "string"
    },
    "l6_witness_ref": {
      "type": "string"
    },
    "consumed_from_l6": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "actuator_id"
        ]
      }
    },
    "clearance_kinetics": {
      "type": "object",
      "required": [
        "renal_hepatic_ratio",
        "residence_time_h"
      ],
      "properties": {
        "renal_hepatic_ratio": {
          "type": "number",
          "minimum": 0,
          "description": "Renal-vs-hepatic clearance ratio."
        },
        "residence_time_h": {
          "type": "number",
          "minimum": 0,
          "description": "Target-tissue residence time (h)."
        }
      },
      "additionalProperties": false
    },
    "tissue_targeting": {
      "type": "object",
      "required": [
        "organ_uptake_percent_id_per_g",
        "active_targeting_ligand_kd_M"
      ],
      "properties": {
        "organ_uptake_percent_id_per_g": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Organ uptake (%ID·g^-1)."
        },
        "active_targeting_ligand_kd_M": {
          "type": "number",
          "minimum": 0,
          "description": "Active-targeting-ligand dissociation constant (M)."
        }
      },
      "additionalProperties": false
    },
    "excretion_pathway": {
      "type": "object",
      "required": [
        "eGFR_threshold_ml_min",
        "bile_clearance_fraction"
      ],
      "properties": {
        "eGFR_threshold_ml_min": {
          "type": "number",
          "minimum": 0,
          "description": "Renal-clearance eGFR threshold (mL·min^-1)."
        },
        "bile_clearance_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of dose cleared via bile."
        }
      },
      "additionalProperties": false
    },
    "raw_91_c3_disclose": {
      "type": "string"
    }
  },
  "additionalProperties": false
}