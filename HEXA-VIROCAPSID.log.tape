#!/usr/bin/env tape


# ══════════════════════════════════════════════════════════════
# HEXA-VIROCAPSID.log.tape — append-only event history (v1.2 split)
# Sibling: HEXA-VIROCAPSID.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite_lattice_tautology_to_real_virology := "HEXA-VIROCAPSID.tape full rewrite — lattice-tautology stub → real virology SSOT" :: rewrite [ok d=2026-05-16]
  origin = "Pre-rewrite HEXA-VIROCAPSID.tape was a lattice-tautology stub (hexa-bio mass-split 153b5a2): @D entries asserting σ(6)=12 vertex / τ(6)=4 assembly states / J₂=24 octahedral subgroup / φ(6)=2 closed-open binary as DERIVATIONS of capsid architecture, with VERIFY axes (CONSTANTS / DIMENSIONS / SCALING / SENSITIVITY) reading as lattice-tautology checks rather than real-science verification. Violated hexa-bio AGENTS.tape g1 (real-limits-first) / g2 (lattice-is-tool) / f1 (lattice-fit-forbidden)."
  user-decision = "2026-05-16: rewrite as a CORE-AXIS, citation-grounded, virology-specialized SSOT. Mirrors the HEXA-WEAVE precedent (commit 6d9eb32) for axis rewrite pattern but distinguishes VIROCAPSID from WEAVE by specialization, not duplication."
  specialization-vs-weave = "HEXA-WEAVE owns general icosahedral capsid & cage geometry / assembly thermodynamics (Caspar–Klug + Zlotnick). HEXA-VIROCAPSID specializes WEAVE to virology: (1) viral life cycle context, (2) genome packaging motors (phi29 / terminase), (3) post-assembly maturation (HK97 chainmail, HIV protease), (4) gene-therapy vector use (AAV / lentivirus / adenovirus), (5) capsid-mediated immunity (anti-AAV NAbs as clinical exclusion criterion), (6) VLP vaccines (HPV Gardasil, HBV). Caspar–Klug T-number theory and Zlotnick nucleation–elongation are CROSS-REFERENCED to HEXA-WEAVE via [@x_hexa_weave_sibling], NOT re-derived. f3 (no-shadow-impl-of-sister-repo) generalized to sibling axes."
  authored = "Hand-written with real virology literature: Caspar & Klug 1962 (foundational), Wikoff et al 2000 Science 289:2129-2133 (HK97 chainmail — paradigm of capsid maturation), Smith et al 2001 Nature 413:748-752 (phi29 ≥50 pN stall force, single-molecule virology), Moffitt et al 2009 Nature 457:446-450 (phi29 motor stepping bursts), Simpson et al 2000 Nature 408:745-750 (phi29 connector structure), Rossmann et al 1985 Nature 317:145-153 (picornavirus pseudo-T=3 atomic-resolution — primary-author/era cited), Fane & Prevelige 2003 Adv Protein Chem (scaffolding assembly review — primary-authors/era cited, also cross-referenced from HEXA-WEAVE), Mingozzi & High 2013 Blood 122:23-36 + Nature-Reviews-class AAV immunology reviews (anti-AAV NAbs as clinical exclusion criterion — primary-authors/era cited)."
  real-limits-anchored = "5 @D :: real-limit entries: lim_aav_cargo (AAV ~4.7 kb cargo HARD WALL — set by capsid interior volume + DNA packaging density), lim_immune_redose (pre-existing anti-AAV NAbs + post-dose NAb induction — HARD WALL preventing redosing per serotype), lim_t_quantization (geometric T-number quantization — delegated to HEXA-WEAVE), lim_manufacturing_empty_capsid (empty-capsid contamination — SOFT WALL manufacturing-process limit), lim_in_silico_boundary (epistemic HARD WALL — no clinical/immunogenicity/efficacy claim from in-silico simulator-consistency). Honest qualitative phrasing where exact percentages depend on assay/cohort (NAb seroprevalence figures NOT asserted as single numbers to avoid fabrication)."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit (lattice-fit-on-viral-capsid-biology) + @N n6_honest_stance state plainly: viral-capsid biology has NO natural n=6 invariant. 12 pentamers is the Euler χ=2 closed-surface constraint (Euler's polyhedron formula), NUMERICALLY COINCIDING with σ(6)=12 but the cause is Euler not the lattice — observation, not derivation. T-number diversity (T=1 AAV / T=3 TBSV / T=4 HBV / T=7 HPV all-pentamer / T=13 reovirus / T=16 herpes / T=25 adenovirus) is governed by viral coat-protein evolution under genetic-economy and assembly-energetics constraints. AAV cargo cap, phi29 force, NAb seroprevalence, vaccine protective immunity are virological / mechanochemical / immunological quantities, none n=6-derived."
  governance = "Complies with hexa-bio AGENTS.tape g1 (real-limits-first), g2 (lattice-is-tool), g8_in_silico_only (in-silico simulator consistency only, NOT therapeutic / clinical / immunogenicity / vaccine-platform claim), f1 (lattice-fit-forbidden), f3 (no-shadow-impl-of-sister-repo — extended here to sibling AXES: HEXA-WEAVE content cross-referenced, not duplicated). @N scope_disclaimer added explicitly. Author/era-only citations honestly flagged where exact volumes not asserted (Fane & Prevelige 2003 review; Mingozzi & High AAV immunology body of work)."
  delete-actions = "All 18 lattice-tautology @D rows from the pre-rewrite stub deleted: row_object_0, row_direction_1, row_primary_quantity_2, row_primary_oracle_3, row_primary_constraint_4, row_bond_regime_5, row_verdict_horizon_6 (4-sister-comparison rows); row_*_*_prerequisite (REQUIRES rows); b_axis_a/b/c/d (the σ/τ/J₂/φ STRUCT rows asserting lattice as derivation); row_l0..row_l_omega_19 (EVOLVE ladder rows); row_constants/dimensions/cross/scaling/sensitivity/limits/chi2/counter (VERIFY rows reading as lattice-tautology checks); row_*_metric rows; b_f_virocapsid_* falsifier rows; row_*_dependency rows; row_*_timeline rows; b_tool_* rows; row_*_team rows. Replaced with 41 evidence-grounded @D / @N / @F / @X entries organized as §0 Identity / §1 specialization-vs-WEAVE / §2 geometry-delegated / §3 viral families & T-numbers / §4 HK97 maturation / §5 viral scaffolding / §6 packaging motors / §7 AAV vector / §8 capsid immunity / §9 real-limits / §10 n=6 stance / §11 predictions / §12 cross-links / §13 literature."
  validated = "selftest/tape_lattice_honesty_lint.py HEXA-VIROCAPSID.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true)."
  honesty-caveat = "Some figures (specific seroprevalence percentages, exact empty-capsid fractions, exact subunit stoichiometries) are NOT asserted as single numbers to avoid fabrication — qualitative statements ('non-trivial fraction', 'majority in crude harvest', '~415 coat / ~250–300 scaffolding') are used instead, with the citation given. Approved-product approval years are described as 'recent regulatory history' rather than asserted as specific years. Reovirus-shell layer T-numbers are stated as literature-standard simplifications with the actual pseudo-T situation flagged. Adenovirus 'T=25' is flagged as a simplification of a more complex architecture."
