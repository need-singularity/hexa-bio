#!/usr/bin/env tape
# ══════════════════════════════════════════════════════════════════════
# .tape v1.2 — grammar primer (cold-read by any LLM / agent / human)
# ══════════════════════════════════════════════════════════════════════
# Form: each entry is `@<type> <id> := "<subject>" :: <kind> [<grades>]`
#       optionally followed by body lines (2-space indent) — key=value,
#       edges (<- -> => …), or quoted prose.
#
# ENTRY TYPES (17):
#   Runtime (10): @S session  @U user  @A assistant  @T tool-call  @R result
#                 @H hook  @D decision  @K cost  @P provider  @? anomaly
#   Foundation:   @I identity-claim
#   Declarative:  @X external-citation  @F forbidden-pattern  @N note
#                 @C config  @L layout  @V spec-version
#
# EDGES (12, on body lines, 2-space indent):
#   Causal:     <- caused-by   -> triggers   == continues
#               ~> supersedes  !! aborts     |> verified-by
#   Effect:     => produces (followed by quoted natural-language)
#   Structural: <: specializes  :> generalizes  ?> soft-depends
#               !> conflicts-with  @> projects-to (e.g. @> AGENTS.md)
#
# GRADE TAGS (in [...] on entry header):
#   Delivery:   ok · err · denied · cancelled · partial · superseded
#   Governance: required · recommended · optional · draft · active · deprecated
#   Scoped:     allow:<x> · deny:<x>
#   Time/index: T<n> (turn)  N<n> (wall-sec)  d=<YYYY-MM-DD>
#
# PAYLOAD SYNTAX (body lines):
#   key = "value"           single-line string
#   key = [a, b, c]         array literal
#   key <<~EOF              heredoc (multi-line; ends with EOF on own line)
#     multi-line text
#   EOF
#   "see [@x1] §3"          inline citation by entry id
#   `cmd or path`           backtick code-span (inline only)
#
# Full spec: ~/core/tape/spec/tape.md (or github.com/dancinlab/tape)
# ══════════════════════════════════════════════════════════════════════


# ══════════════════════════════════════════════════════════════
# HERBALISM.log.tape — append-only event history (v1.2 split)
# Sibling: HERBALISM.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite_lattice_to_real_science := "HERBALISM.tape full rewrite — lattice-tautology stub to real phytopharmacology SSOT" :: rewrite [ok d=2026-05-16]
  origin = "HERBALISM.tape was a lattice-tautology stub (~379 lines of @D row_* entries mapping n=6 σ/τ/φ/J₂ values to fabricated 'herbalism' efficacy percentages: '약효 재현성 95% because σ·sopfr/10', '12종 소스 because σ(6)=12', etc.). Zero real phytopharmacology, zero real citations. The stub was generated by the hexa-bio mass-split commit 153b5a2 and replicated the same lattice-tautology pattern found in AGRICULTURE.tape (pre-rewrite) and CANCER-THERAPY.tape (pre-rewrite)."
  rewrite-date = "2026-05-16"
  authored = "Full real-science rewrite grounded in landmark phytopharmacology and pharmacognosy literature. All stub entries deleted."
  evidence-grade-discipline = "The herbalism domain is hype-prone. The rewrite explicitly enforces three evidence grades throughout: (A) Proven phytopharmacology = plant-derived compounds that became approved drugs with RCT-level validation: digitalis/digoxin (Withering 1785 → modern cardiac pharmacology), quinine (Pelletier & Caventou 1820 isolation; antimalarial), salicylates/aspirin (Salix ethnobotanical; Hoffmann/Bayer 1897 synthesis; modern RCT evidence), artemisinin (Tu Youyou Nobel 2015; WHO first-line malaria treatment), paclitaxel (Wani & Wall 1971 J Am Chem Soc 93:2325-2327; FDA-approved oncology), vincristine/vinblastine (Catharanthus roseus; CHOP/ABVD/ALL backbone), galantamine (Galanthus/Leucojum; FDA-approved Alzheimer's AChEI). (B) Moderate evidence = controlled-trial support but heterogeneous or modest: St John's Wort / Hypericum perforatum (Linde et al 2008 Cochrane Syst Rev — mild-to-moderate depression vs placebo; CYP3A4 induction is a HARD pharmacokinetic interaction, not a 'potential' concern); Ginkgo biloba (large RCTs GEM/GEMS negative for prevention; borderline B/C). (C) Traditional-use only = ethnobotanical record without adequate RCT support: echinacea, valerian, milk thistle, ashwagandha, curcumin (canonical bioavailability-gap example). All B/C claims are labeled explicitly as such. Traditional use ≠ efficacy is stated plainly."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: herbalism has NO natural n=6 invariant. Plant secondary metabolite chemical classes, WHO herb monograph counts, traditional-system organ correspondences, and validated-drug counts are all determined by biochemistry, evolutionary history, and clinical evidence — not by σ/τ/φ/J₂. Any numeric coincidence is observation only, never derivation."
  real-limits-added = "6 @D lim_* entries anchored to real pharmacological/regulatory/methodological limits: (1) lim_standardization — whole-plant active-compound variability up to 10× across commercial preparations (chemistry/agronomy HARD WALL); (2) lim_herb_drug_interaction — CYP3A4/PGP-mediated pharmacokinetic interactions (Roby et al 2000; Piscitelli et al 2000) — not theoretical; (3) lim_contamination — documented heavy-metal/adulterant contamination + DSHEA 1994 regulatory asymmetry; (4) lim_placebo_control — placebo response 30–50% in subjective-outcome trials; methodological LIMIT for traditional-use evidence; (5) lim_bioavailability — curcumin canonical in-vitro-to-human PK translation failure; (6) lim_regulatory_dshea — DSHEA 1994 structure; supplements need no pre-market efficacy proof vs pharmaceutical drugs."
  citations-added = "@X :: literature entries: x_withering_1785 (Withering monograph, 1785 Birmingham); x_pelletier_caventou_1820 (alkaloid isolation, 1820, primary-author/era); x_hoffmann_bayer_1897 (aspirin synthesis, Bayer 1897, primary-author/era, historical debate acknowledged); x_hippocratic_willow (Hippocratic-era ethnobotanical, ancient, primary-author/era, ancient-world records only); x_tu_youyou_2015 (Nobel Prize 2015, Nobel Lecture archive); x_wani_wall_1971 (J Am Chem Soc 1971;93:2325-2327 CONFIRMED); x_linde_cochrane_2008 (Cochrane Database Syst Rev 2008;(4):CD000448 CONFIRMED); x_cyp3a4_stjohnswort (Roby 2000 Clin Pharmacol Ther 67:451-457; Piscitelli 2000 Lancet 355:547-548); x_dshea_1994 (Public Law 103-417, US Federal Register)."
  lint = "python3 selftest/tape_lattice_honesty_lint.py HERBALISM.tape --json → {verdict: PASS, deriv_warnings: [], has_guard: true, has_stance: true, grounded: true} · __TAPE_LATTICE_HONESTY__ PASS · zero derivation warnings."
  governance = "Complies with hexa-bio AGENTS.tape g1 (real-limits-first), g2 (lattice-is-tool), g8 (in-silico-only-claim-scope), f1 (no lattice-fit-on-external-entity), f2 (no in-silico→clinical claim). scope_disclaimer and evidence-grade labels explicitly prevent misuse as therapeutic advice."
