#!/usr/bin/env tape
# ══════════════════════════════════════════════════════════════════════
# .tape v1.2 — grammar primer (cold-read by any LLM / agent / human)
# ══════════════════════════════════════════════════════════════════════
# Form: each entry is `@<type> <id> := "<subject>" :: <kind> [<grades>]`
#       optionally followed by body lines (2-space indent) — key=value,
#       edges (<- -> => …), or quoted prose.
#
# ENTRY TYPES (17):
#   Runtime (10): @S session  @U user  @A assistant  @T tool-call  @R result
#                 @H hook  @D decision  @K cost  @P provider  @? anomaly
#   Foundation:   @I identity-claim
#   Declarative:  @X external-citation  @F forbidden-pattern  @N note
#                 @C config  @L layout  @V spec-version
#
# EDGES (12, on body lines, 2-space indent):
#   Causal:     <- caused-by   -> triggers   == continues
#               ~> supersedes  !! aborts     |> verified-by
#   Effect:     => produces (followed by quoted natural-language)
#   Structural: <: specializes  :> generalizes  ?> soft-depends
#               !> conflicts-with  @> projects-to (e.g. @> AGENTS.md)
#
# GRADE TAGS (in [...] on entry header):
#   Delivery:   ok · err · denied · cancelled · partial · superseded
#   Governance: required · recommended · optional · draft · active · deprecated
#   Scoped:     allow:<x> · deny:<x>
#   Time/index: T<n> (turn)  N<n> (wall-sec)  d=<YYYY-MM-DD>
#
# PAYLOAD SYNTAX (body lines):
#   key = "value"           single-line string
#   key = [a, b, c]         array literal
#   key <<~EOF              heredoc (multi-line; ends with EOF on own line)
#     multi-line text
#   EOF
#   "see [@x1] §3"          inline citation by entry id
#   `cmd or path`           backtick code-span (inline only)
#
# Full spec: ~/core/tape/spec/tape.md (or github.com/dancinlab/tape)
# ══════════════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# ══════════════════════════════════════════════════════════════
# NEURO.log.tape — append-only event history (v1.2 split)
# Sibling: NEURO.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

# §Log — entries chronological, oldest first.

@A rewrite := "NEURO.tape rewritten from lattice-tautology stub to real-science SSOT" :: rewrite [ok d=2026-05-16]
  origin = "NEURO.tape was a fabricated lattice-tautology stub (created in the hexa-bio mass-split, commit 153b5a2; the '궁극의 AI 웨어러블 뇌-기계 인터페이스' / 8단 체인 / 6⁸=1,679,616 / 202/202 EXACT file). It 'derived' BCI claims (channel counts, decoder accuracies, SNR multipliers, '뇌질환 τ=4 보편성', '시각피질 V1~V6 = n=6', sensorimotor universality, '청각피질 σ-φ=10 옥타브', etc.) from n=6 lattice tokens (σ=12/τ=4/φ=2/J₂=24/sopfr=5) with x=\"EXACT\" — a direct LATTICE_POLICY g1/g2 + f1 violation, and an f2 violation (in-silico → therapeutic / device claim). Every row_* / b_* / fabricated tp_* stub deleted."
  authored = "Hand-written with real neuroscience + BCI engineering + landmark clinical citations. Replaces ZERO biology with: Hodgkin-Huxley action-potential foundation, neural coding (rate / temporal / population), Georgopoulos motor-cortex population vector, recording-modality landscape (EEG / ECoG / intracortical Utah-array & BrainGate / Neuropixels-class / endovascular Stentrode / flexible-probe frontier / sensory neuroprostheses), decoder evolution (linear/Kalman → RNN/deep), clinical milestones (BrainGate Hochberg 2006 + 2012; Collinger 2013 7-DOF arm; Flesher 2016 ICMS feedback; Pandarinath 2017 communication BCI; Willett 2021 handwriting + 2023 speech; Moses 2021 NEJM speech via ECoG; Oxley 2021 Stentrode), stimulation & closed-loop integration (ICMS feedback, DBS scope-note, retinal/cortical visual prostheses, closed-loop sensorimotor & responsive neurostimulation). Qualitative source-grounded §4b modality comparison (EEG vs ECoG vs intracortical vs Stentrode). 7 real-limit anchors: chronic-recording longevity / glial encapsulation (HARD), SNR-bandwidth-channel trade-off (PHYSICAL/INFORMATIONAL), biocompatibility & infection (HARD), surgical risk (HARD), decoder non-stationarity (SOFT), neural-data privacy & autonomy (ETHICAL), evidence-grade discipline (EPISTEMIC). 3 falsifiable predictions with falsifiers + sourced. 16 real @X :: literature citations (Hodgkin-Huxley 1952; Georgopoulos 1986; Wessberg 2000; Hochberg 2006 + 2012; Collinger 2013; Flesher 2016; Pandarinath 2017; Willett 2021 + 2023; Moses 2021; Oxley 2021; Jun-Neuropixels 2017; Wu/Black Kalman; Polikov 2005; Lebedev/Nicolelis 2006; Yuste 2017)."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: neuroscience / BCI exposes NO natural n=6 invariant (visual cortex is open hierarchical V1/V2/V3/V4/MT/IT — NOT a closed n=6 set; Brodmann ≈52 areas; Utah-array typical 96 channels and high-density probes reach thousands — engineering choices, not lattice values; SE(3) rigid-body 6-DOF is Euclidean kinematics, not the n=6 hexa lattice). Coincidence is observation-only, never derivation. This honesty IS the corrective for the audited lattice-tautology stub."
  governance = "Complies with hexa-bio AGENTS.tape g1 (real-limits-first — 7 real-limit anchors), g2 (lattice-is-tool — declined as derivation), g3 (honesty-obligation-external — no claims about external companies / device-makers / regulators are made via lattice-fit; e.g. Argus II commercial discontinuation, Stentrode-program early stage, and PR-vs-peer-review evidence-grade flagged honestly), g8 (in-silico-only-claim-scope — @N scope_disclaimer added; BCI surgery framed as high-risk, requires neurosurgical/IRB oversight), f1 (no lattice-fit), f2 (no in-silico→clinical/surgical/device-regulatory claim — figures paraphrased from peer-reviewed literature for modeling context only), f3 (no shadow-implementation of sister-repo logic — this is a knowledge SSOT, not a re-implementation). Provenance recorded in @I id001 rewritten-from key."
  honesty-caveats = "No fabricated numbers/citations — exact accuracies / words-per-minute / channel counts kept qualitative where uncertain (directions + relative ordering + landmark trial). Press-release-only claims explicitly NOT cited as evidence (see @D lim_evidence_grade); Neuralink-class flexible-thread work flagged 'emerging / partly preclinical' rather than treated as a clinical landmark. Three references flagged primary-author/era only with paraphrased exact volume: x_willett_2023 (Nature 2023 speech neuroprosthesis), x_oxley_2021 (J NeuroInterv Surg 2021 Stentrode first-in-human), x_wu_black_2006 (Kalman-decoder lineage — exact volume not asserted) — mirroring the gold tape's x_goren_2014 / cancer-therapy x_ebctcg_2005 + x_vogelstein_2013 discipline."
  lint = "python3 selftest/tape_lattice_honesty_lint.py NEURO.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true, deriv_warnings=[] — zero lattice-derivation lines remain; all row_* / b_* fabricated stub content deleted)."
