#!/usr/bin/env tape


# ══════════════════════════════════════════════════════════════
# APICULTURE.log.tape — append-only event history (v1.2 split)
# Sibling: APICULTURE.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite_lattice_to_real_science := "APICULTURE.tape rewritten from lattice-tautology stub to real-science SSOT" :: rewrite [ok d=2026-05-16]
  origin = "Stub (hexa-bio mass-split 153b5a2) contained ~330 lines of @D row_*/b_* entries with x='EXACT' deriving apiculture figures (honey yield, mite loss %, cycle periods, monitor counts) from σ/τ/φ/J₂/sopfr lattice tautologies. No real citations, no real biology. Deleted in full."
  approach = "Full replacement from @I id001 onward following AGRICULTURE.tape archetype (commit ac8f441) + ANDROGENETIC-ALOPECIA.tape honesty discipline."
  content = "12 real @D entries covering: Apis mellifera biology + caste system; swarming/queen-mating; von Frisch dance language (1973 Nobel); honeycomb geometry (Hales 1999 Honeycomb Conjecture proof — geometric, NOT lattice); pollination ecology + economic value (Klein 2007 PRSB, Calderone 2012 PLoS ONE); Varroa destructor + DWV viral axis (Rosenkranz 2010); Nosema ceranae (Higes 2009); neonicotinoid sublethal effects (Henry 2012 Science RFID homing impairment); Colony Collapse Disorder multifactorial (vanEngelsdorp 2009, Goulson 2015 Science); insect biomass decline (Hallmann 2017 PLoS ONE). 4 real-limit anchors (Varroa HARD WALL; neonicotinoid SOFT WALL; CCD multifactorial structural limit; pollinator habitat/timing mismatch). 3 falsifiable predictions. 12 @X :: literature entries (all real, landmark literature)."
  n6-stance = "Lattice declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: apiculture has no natural n=6 invariant. Crucially: honeycomb hexagonal cells are geometric (Hales 1999 close-packing proof), NOT lattice-derived — six-sidedness emerges from Euclidean geometry (6 equilateral triangles around a point), not from n=6 being a perfect number or σ(6)=12."
  citations-flagged = "Seeley 2010 ('Honeybee Democracy') — primary author/era asserted, exact ISBN/edition not independently verified. vanEngelsdorp 2009/2010 — primary survey papers primary-author/era cited; companion-paper volumes not independently asserted. All other citations (von Frisch 1967, Winston 1987, Hales 1999, Klein 2007, Calderone 2012, Henry 2012, Rosenkranz 2010, Goulson 2015, Hallmann 2017, Higes 2009) are confident full references."
  lint = "python3 selftest/tape_lattice_honesty_lint.py APICULTURE.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true; 2 deriv_warnings = honesty-refutation lines inside @D dom_castes and @D dom_honeycomb_geometry that quote the bad pattern to reject it — tolerated provenance, not live claims)."
  governance = "Complies with hexa-bio AGENTS.tape @D g1 (real-limits-first), @D g2 (lattice-is-tool), @D g8 (in-silico-only-claim-scope), @F f1 (lattice-fit-on-external-entity). Scope disclaimer added (@N scope_disclaimer) — in-silico knowledge SSOT, not agronomic/veterinary advice (g8/f2)."
