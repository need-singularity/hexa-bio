@D b_6_n_exact_0 :: entomology [ok]
  text = "다리: **6개** = n **EXACT**"

@D b_hexapoda_hex_6_pous_6_1 :: entomology [ok]
  text = "\"Hexapoda\" = 그리스어 hex(6) + pous(발) = 6다리"

@D b_3_1_2_n_n_6_2 :: entomology [ok]
  text = "흉부 체절 3개 × 각 1쌍(φ=2) = n/φ × φ = n = 6"

