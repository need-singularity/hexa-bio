#!/usr/bin/env tape


# ══════════════════════════════════════════════════════════════
# ECOLOGY.log.tape — append-only event history (v1.2 split)
# Sibling: ECOLOGY.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite_lattice_tautology_stub := "ECOLOGY.tape full real-science rewrite from lattice-tautology stub" :: rewrite [ok d=2026-05-16]
  origin = "ECOLOGY.tape was a lattice-tautology stub generated by the hexa-bio mass-split (commit 153b5a2). The stub contained ~130 lines of @D row_* entries with fields x=\"σ=12\" / x=\"EXACT\" / hexa=\"**12**\" / n_6=\"n=6\" / n_6=\"σ·sopfr=60\" — all fabricated lattice-derivations with zero ecological-science content. No real citations, no real limits, no honest n=6 stance, no @F guard. Would have FAILed tape_lattice_honesty_lint.py on all three contracts."
  rewrite = "Full rewrite 2026-05-16. Preserved: top .tape v1.2 grammar primer, banner, @V :: spec. Replaced all stub @D row_* with real ecology science (§1-§11) and real citations (§12-§13). Zero stub lines retained."
  content = "13 sections: §1 population ecology (exponential/logistic growth; Verhulst 1838; r/K selection); §2 species interactions (Lotka-Volterra 1925/1926; competitive exclusion Gause 1934; Hutchinson niche 1957); §3 community ecology (keystone species Paine 1966; foundation species; trophic cascades Estes 1974/Power 1990); §4 island biogeography MacArthur&Wilson 1967; §5 biodiversity (Elton 1958; information-theoretic indices); §6 ecosystem services MEA 2005; §7 conservation biology (Hanski 1999 metapopulation; Soulé era); §8 Anthropocene (Crutzen&Stoermer 2000; planetary boundaries Rockström 2009 + Steffen 2015); §9 five real-limits (biodiversity loss Ceballos 2015; climate niche shift; invasive species Elton/Simberloff; nutrient overloading/eutrophication; carrying-capacity/MSY tradeoff); §10 @F f_lattice_fit + @N n6_honest_stance; §11 three falsifiable predictions (Lotka-Volterra oscillation; keystone removal; species-area power law); §12-§13 cross-links and 16 @X :: literature entries."
  citations = "Confident (full bibliographic detail asserted): Verhulst 1838 Corresp Math Phys; Lotka 1925 Elements of Physical Biology book; Volterra 1926 Nature 118:558-560; Hutchinson 1957 Cold Spring Harbor Symp Quant Biol 22:415-427; Paine 1966 Am Nat 100:65-75; MacArthur&Wilson 1967 Island Biogeography book; Power 1990 Science 250:811-814; Rockström et al 2009 Nature 461:472-475; Steffen et al 2015 Science 347:1259855; Ceballos et al 2015 Sci Adv 1:e1400253; MEA 2005 Ecosystems and Human Well-being book."
  author-era-only = "Gause 1934 competitive exclusion (primary author/era — exact journal not asserted); Estes&Palmisano 1974 sea otter/urchin/kelp (primary author/era); Elton 1958 Ecology of Invasions book (primary author/era — monograph title asserted); Hanski 1999 Metapopulation Ecology book (primary author/era); Crutzen&Stoermer 2000 IGBP Newsletter (primary author/era, newsletter not primary literature); Galloway N-cycling (~2003 era, body of work, not single article)."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: ecology has no natural n=6 invariant. Planetary boundaries = 9 (Rockström, not lattice), trophic levels = 3-5 (food-web topology), Hutchinson niche = n-dimensional (species-specific), Lotka-Volterra parameters = 4 (ODE structure). This honesty IS the corrective for the audited lattice-tautology stub."
  governance = "Complies with hexa-bio AGENTS.tape @D g1 (real-limits-first), @D g2 (lattice-is-tool), @D g8 (in-silico-only-claim-scope), @F f1 (lattice-fit-on-external-entity). Knowledge-scope disclaimer (@N scope_disclaimer) added — knowledge SSOT, not field-ecology advice."
  lint = "python3 selftest/tape_lattice_honesty_lint.py ECOLOGY.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true; no live derivation lines — all @D entries cite real @X literature via |> edges or explicit citation text)."
