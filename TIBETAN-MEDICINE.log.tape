#!/usr/bin/env tape
# ══════════════════════════════════════════════════════════════════════
# .tape v1.2 — grammar primer (cold-read by any LLM / agent / human)
# ══════════════════════════════════════════════════════════════════════
# Form: each entry is `@<type> <id> := "<subject>" :: <kind> [<grades>]`
#       optionally followed by body lines (2-space indent) — key=value,
#       edges (<- -> => …), or quoted prose.
#
# ENTRY TYPES (17):
#   Runtime (10): @S session  @U user  @A assistant  @T tool-call  @R result
#                 @H hook  @D decision  @K cost  @P provider  @? anomaly
#   Foundation:   @I identity-claim
#   Declarative:  @X external-citation  @F forbidden-pattern  @N note
#                 @C config  @L layout  @V spec-version
#
# EDGES (12, on body lines, 2-space indent):
#   Causal:     <- caused-by   -> triggers   == continues
#               ~> supersedes  !! aborts     |> verified-by
#   Effect:     => produces (followed by quoted natural-language)
#   Structural: <: specializes  :> generalizes  ?> soft-depends
#               !> conflicts-with  @> projects-to (e.g. @> AGENTS.md)
#
# GRADE TAGS (in [...] on entry header):
#   Delivery:   ok · err · denied · cancelled · partial · superseded
#   Governance: required · recommended · optional · draft · active · deprecated
#   Scoped:     allow:<x> · deny:<x>
#   Time/index: T<n> (turn)  N<n> (wall-sec)  d=<YYYY-MM-DD>
#
# PAYLOAD SYNTAX (body lines):
#   key = "value"           single-line string
#   key = [a, b, c]         array literal
#   key <<~EOF              heredoc (multi-line; ends with EOF on own line)
#     multi-line text
#   EOF
#   "see [@x1] §3"          inline citation by entry id
#   `cmd or path`           backtick code-span (inline only)
#
# Full spec: ~/core/tape/spec/tape.md (or github.com/dancinlab/tape)
# ══════════════════════════════════════════════════════════════════════


# ══════════════════════════════════════════════════════════════
# TIBETAN-MEDICINE.log.tape — append-only event history (v1.2 split)
# Sibling: TIBETAN-MEDICINE.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite_2026_05_16 := "TIBETAN-MEDICINE.tape full real-science rewrite" :: rewrite [ok d=2026-05-16]
  origin = "TIBETAN-MEDICINE.tape was a lattice-tautology stub from the hexa-bio mass-split (commit 153b5a2). The stub mapped 6 tastes → n=6 via σ·φ tautology ('σ(6)=12 · phi(6)=2 · tau(6)=4 — identity uniquely at n=6'), used taste-row @D entries with no real citations, and included scaffold TODO items. No real Sowa Rigpa science, no clinical evidence, no heavy-metal safety content, no lattice-fit guard, no honest n=6 stance."
  rewrite-scope = "Complete replacement from @I id001 onward. Primer + banner + @V retained. All stub content deleted."
  authored-content = "Real Sowa Rigpa content organized into 9 sections: §0 Identity + scope disclaimer; §1 System overview (Gyud Zhi canon, three nyepa, diagnostics, six tastes, four treatment categories); §2 Pharmacopoeia + formulations (rinchen rilbu heavy-metal detail, Padma 28, Padma Lax, Yangmin 17, other classical formulas); §3 Modern integration (WHO, Men-Tsee-Khang, regulatory status); §4 Evidence-grade cross-reference; §5 Real-limits (6 anchors); §6 n=6 honest stance + guard; §7 Falsifiable predictions (3); §8 Cross-links; §9 External citations (9 real @X :: literature entries)."
  evidence-tier-discipline = "Three-tier evidence grading applied per HERBALISM.tape precedent: (A) Peer-reviewed controlled-trial evidence — Padma 28 intermittent claudication (Drabaek 1993 RCT + Suter systematic review era); Padma Lax IBS-C (Sallon 2002 RCT). Grade A = modest evidence, not confirmatory, specific to registered Swiss products only. (B) Limited / heterogeneous trials — Yangmin 17 chronic hepatitis; saffron co-formulas. (C) Traditional-use-only — most classical formulations; widespread traditional use explicitly noted to NOT equal efficacy."
  heavy-metal-safety-discipline = "CRITICAL SAFETY CONTENT explicitly included. [@dom_rinchen_rilbu] details: classical precious-pill recipes prescribe cinnabar (HgS), arsenic minerals (realgar, orpiment), lead as textually mandated ingredients (NOT incidental contamination). Traditional rinchen rilbu purification (bcud len) claims sulfide-complexation reduces bioavailability — contemporary toxicology literature (Sallon era ~2006–2017) documents variable heavy-metal levels, some exceeding WHO daily tolerable intakes in analyzed samples. Real-limit anchor [@lim_heavy_metal_safety] rated HARD WALL (toxicological). Regulatory landscape: Switzerland Padma products (no heavy metals, registered) = gold-standard exception; unregulated markets carry genuine risk."
  n6-stance = "Declined as derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: the rGyud bzhi's six-taste scheme and twelve-pulse-position scheme are textually fixed pan-Asian cosmological conventions predating and independent of the n=6 lattice. Three nyepa = 3 ≠ 6. Five elements = 5 ≠ 6. Four Tantras = 4. Eight branches = 8. Six tastes = 6 by traditional convention, observed but NOT derived from lattice. σ=12 coincides with 12 pulse positions — observation only, explicitly noted. The stub's error (using σ·φ tautology on the 6-taste count) is corrected."
  governance-compliance = "Complies with hexa-bio AGENTS.tape g1 (real-limits-first — 6 real-limit @D entries anchored to hard science + toxicology), g2 (lattice-is-tool — lattice declined), g8 (in-silico-only-claim-scope — scope_disclaimer @N required), f1 (lattice-fit-on-external-entity — @F guard present), f2 (no in-silico→clinical claim — scope_disclaimer explicit). g3 (honesty-obligation-external): no lattice assertions on external entities (Men-Tsee-Khang, WHO, Padma AG, Swiss regulatory body)."
  lint-result = "python3 selftest/tape_lattice_honesty_lint.py TIBETAN-MEDICINE.tape --json → {verdict: PASS, has_guard: true, has_stance: true, grounded: true, deriv_warnings: [L83 pulse-diagnosis line — tolerated provenance, not a live derivation claim; explicit honest context in @dom_diagnostics and @n6_honest_stance]}. __TAPE_LATTICE_HONESTY__ PASS."
  citations = "9 real @X :: literature entries: x_gyudzhi_12thc (Yuthog era ~12th c.), x_desi_sangye_1703 (Blue Beryl commentary), x_drabaek_1993 (Angiology RCT vol/journal confirmed), x_suter_2007 (Padma 28 systematic review era — year caveat noted), x_sallon_padma_lax (Digestion 2002 vol/journal confirmed), x_sallon_heavy_metals (Sallon ~2006–2017 era — multiple publications, primary-author/era cited, volumes not asserted), x_who_tm_strategy (WHO 2013 institutional), x_who_herb_safety (WHO 2004 institutional), x_menteekang_formulary (Men-Tsee-Khang institutional). No fabricated numbers, DOIs, or page numbers beyond what is assertable."
  honesty-caveats = "Suter year (2007 vs 2011) noted as uncertain; Sallon heavy-metal publication details flagged as multi-paper era rather than single confirmed volume; Yangmin 17 evidence described as variable-quality Chinese-language trials without single authoritative Western RCT; rinchen rilbu purification effectiveness described as partially but not uniformly demonstrated."
