        q + "status" + q + ": " + q + "clinical-trial-stage; CBER-regulated" + q + ", " +
        q + "reason" + q + ": " + q + "CBER-regulated biologic; out of repo CDER scope per criterion #4 drug-only/CDER discipline (same pattern as Zolgensma in case_studies/sma_portfolio/). Honest UNPLACED." + q + ", " +
        q + "in_scope" + q + ": false, " +
        q + "reported_not_run" + q + ": true, " +
        q + "unplaced_precedent_in_repo" + q + ": " + q + "AXIS/HIERARCHY.tape @N genetic_medicine_status" + q + "}"

    let touch1 = "{" +
        q + "id" + q + ": " + q + "A4" + q + ", " +
        q + "module" + q + ": " + q + "_python_bridge/module/capsid_modulator_pdb_anchor_cross.py" + q + ", " +
        q + "note" + q + ": " + q + "HIV-1 capsids classified honest 'T-number N/A — non-icosahedral fullerene cone'; the cross refuses to fabricate a T-number" + q + "}"
    let touch2 = "{" +
        q + "id" + q + ": " + q + "G2" + q + ", " +
        q + "module" + q + ": " + q + "_python_bridge/module/allosteric_cryptic_pocket_cross.py" + q + ", " +
        q + "note" + q + ": " + q + "MWC and cryptic-pocket are identical 2-state equilibria under R↔open mapping; the general framework this case study draws on" + q + "}"

    let honesty_json = "{" +
        q + "in_silico_only" + q + ": true, " +
        q + "core_5_unchanged" + q + ": true, " +
