        q + "one_disease_pilot_not_200_disease_remap" + q + ": true, " +
        q + "research_stage_negatives_listed_honestly" + q + ": true, " +
        q + "statement" + q + ": " + q + "Per-disease IN-SILICO composition of two existing axis sims for two FDA-approved CDER drugs (lenacapavir, maraviroc). Research-stage negatives (anti-HIV ASOs, HIV-PROTACs) and CBER negatives (gene-editing curatives) are recorded honestly, not modeled. NEVER a therapeutic / clinical / efficacy / regulatory / portfolio-recommendation claim (g8 / f2). The 200-disease re-mapping remains deferred per AXIS/HIERARCHY.tape Log." + q + "}"

    let witness = "{" +
        q + "schema_version" + q + ": " + q + SCHEMA_VERSION + q + ", " +
        q + "case_study_id" + q + ": " + q + CASE_STUDY_ID + q + ", " +
        q + "ts" + q + ": " + q + TS_FIXED + q + ", " +
        q + "disease" + q + ": {" +
            q + "name" + q + ": " + q + "Human Immunodeficiency Virus 1 infection" + q + ", " +
            q + "abbreviation" + q + ": " + q + "HIV-1" + q + "}, " +
        q + "in_scope_drugs" + q + ": [" + lenacapavir + ", " + maraviroc + "], " +
        q + "research_stage_negatives" + q + ": [" + neg1 + ", " + neg2 + ", " + neg3 + "], " +
        q + "cross_axis_touch_points" + q + ": [" + touch1 + ", " + touch2 + "], " +
        q + "honesty" + q + ": " + honesty_json + ", " +
