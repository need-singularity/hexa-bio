#!hexa strict
// hexa-bio/_hexa_bridge/selftest/nanobot_l6_l7_contract_test.hexa
//
// hexa-native port of `_python_bridge/module/nanobot_l6_l7_contract_test.py`
// (T3; io/json/os/sys — deterministic, no float-fmt/network/time/random).
// Consumer-driven (Pact-style) contract test for the N-R2 nanobot
// L6 → L7-L9 boundary. Loads 5 JSON specs (runtime json_parse), checks
// L6 lock + emitter-field coverage + canon handoff ref + per-layer
// consumed_from_l6 ⊆ L6-emitted AND == canon consumes_from_l6 (modulo
// the work_per_cycle_kT alias) + collision_overlap_target. Python-repr
// formatting reproduced exactly (!r single-quote, sorted() list-repr,
// bool str, float via json_stringify = CPython-parity).

fn shq(s: string) -> string { return "'" + s.replace("'", "'\\''") + "'" }

let L6_SCHEMA = "nanobot/spec/handoff_l6_emission_v0.schema.json"
let CANON_REF = "nanobot/spec/canon_l7_acceptance_handoff_ref.json"
let L7L9_DIR = "nanobot/spec/proposed_l7_l9_witness_schemas"

// the L6 fields the hexa-bio emitter actually produces
let L6_EMITTED = ["actuator_id", "n6_invariant", "work_per_cycle_kT", "vertex_decorations",
                  "pose_canonical_form", "brownian_collapse_detected", "l6_layer",
                  "expected_consumer_layers", "joint_witness_path"]

fn reprstr(s: string) -> string { return "'" + s + "'" }
fn pybool(b: bool) -> string { if b { return "True" } return "False" }

fn mem(arr: array, x: string) -> bool {
    let mut i = 0
    while i < len(arr) { if arr[i] == x { return true }; i = i + 1 }
    return false
}

fn uniq_sorted(arr: array) -> array {
    let mut u: array = []
    let mut i = 0
    while i < len(arr) { if !mem(u, arr[i]) { u.push(arr[i]) }; i = i + 1 }
    // insertion sort (ASCII, like Python sorted() on str)
    let mut p = 1
    while p < len(u) {
        let cur = u[p]
        let mut q = p - 1
        while q >= 0 && u[q] > cur { u[q + 1] = u[q]; q = q - 1 }
        u[q + 1] = cur
        p = p + 1
    }
    return u
}

fn listrepr(arr: array) -> string {
    let mut s = "["
    let mut i = 0
    while i < len(arr) {
        if i > 0 { s = s + ", " }
        s = s + "'" + arr[i] + "'"
        i = i + 1
    }
    return s + "]"
}

fn norm_field(f: string) -> string {
    if f == "work_per_cycle_kT_units" { return "work_per_cycle_kT" }
    return f
}

fn load(root: string, rel: string) -> any {
    return json_parse(exec("cat " + shq(root + "/" + rel) + " 2>/dev/null"))
}

fn main() {
    let root = exec("pwd").trim()
    println("nanobot_l6_l7_contract_test — N-R2 L6 → L7-L9 consumer-driven contract test")
    println("")
    let mut fails: array = []

    // 1. L6 producer schema present + LOCKED v1.0.0 + emission unblocked
    let l6 = load(root, L6_SCHEMA)
    let lockmd = if l6.has("lock_metadata") { l6["lock_metadata"] } else { json_parse("{}") }
    let lock_ver = if lockmd.has("version") { lockmd["version"] } else { "" }
    let l6props = l6["properties"]
    let eb = l6props["emission_blocked_until_schema_lock"]
    let eb_default = eb["default"]
    let locked = lock_ver == "v1.0.0" && eb_default == false
    let lock_ver_repr = if lockmd.has("version") { reprstr(lock_ver) } else { "None" }
    println("  [" + (if locked { "PASS" } else { "FAIL" }) + "] L6 producer schema (" + L6_SCHEMA + ") LOCKED v1.0.0, emission unblocked  " +
            "(lock_metadata.version=" + lock_ver_repr + ", emission_blocked default=" + pybool(eb_default) + ")")
    if !locked { fails.push("L6 not locked v1.0.0") }

    // L6 schema enumerates all emitter fields
    let mut missing: array = []
    let mut mi = 0
    while mi < len(L6_EMITTED) {
        if !l6props.has(L6_EMITTED[mi]) { missing.push(L6_EMITTED[mi]) }
        mi = mi + 1
    }
    let miss_repr = if len(missing) == 0 { "none" } else { listrepr(uniq_sorted(missing)) }
    println("  [" + (if len(missing) == 0 { "PASS" } else { "FAIL" }) + "] L6 schema enumerates all emitter fields  (" +
            str(len(L6_EMITTED)) + " fields; missing in schema: " + miss_repr + ")")
    if len(missing) > 0 { fails.push("L6 schema missing fields") }

    // 2. canon handoff ref present + DECLARED
    let canon = load(root, CANON_REF)
    let c_schema = if canon.has("schema") { canon["schema"] } else { "" }
    let c_status = if canon.has("acceptance_status") { canon["acceptance_status"] } else { "" }
    let c_version = if canon.has("version") { canon["version"] } else { "" }
    let canon_ok = c_schema == "raw_77_therapeutic_nanobot_l7_acceptance_v1" && c_status == "DECLARED"
    println("  [" + (if canon_ok { "PASS" } else { "FAIL" }) + "] canon handoff ref (" + CANON_REF + ") — schema=" +
            reprstr(c_schema) + " status=" + reprstr(c_status) + " version=" + reprstr(c_version))
    if !canon_ok { fails.push("canon handoff ref bad") }

    // canon_consumes_norm: key "{layer}_{name}" → consumes_from_l6 list
    let layers = canon["therapeutic_nanobot_l7_to_l9_layers"]
    let mut cc_keys: array = []
    let mut cc_vals: array = []
    let mut li = 0
    while li < len(layers) {
        let lay = layers[li]
        cc_keys.push(str(lay["layer"]) + "_" + str(lay["name"]))
        cc_vals.push(lay["consumes_from_l6"])
        li = li + 1
    }

    // 3. each L7-L9 draft schema
    let LK = ["L7_drug_load", "L8_immune_evasion", "L9_biodistribution"]
    let LF = ["raw_77_therapeutic_nanobot_l7_drug_load_v1.schema.json",
              "raw_77_therapeutic_nanobot_l8_immune_evasion_v1.schema.json",
              "raw_77_therapeutic_nanobot_l9_biodistribution_v1.schema.json"]
    let LC = ["raw_77_therapeutic_nanobot_l7_drug_load_v1",
              "raw_77_therapeutic_nanobot_l8_immune_evasion_v1",
              "raw_77_therapeutic_nanobot_l9_biodistribution_v1"]
    let mut si = 0
    while si < len(LK) {
        let layer_key = LK[si]
        let sch = load(root, L7L9_DIR + "/" + LF[si])
        let sp = sch["properties"]
        let scon = if sp.has("schema") && sp["schema"].has("const") { sp["schema"]["const"] } else { "" }
        if scon != LC[si] {
            fails.push(layer_key + " schema const mismatch")
            println("  [FAIL] " + layer_key + ": schema const != " + LC[si])
            si = si + 1
            continue
        }
        let cf6_raw = sp["consumed_from_l6"]["items"]["enum"]
        let mut cf6_arr: array = []
        let mut ci = 0
        while ci < len(cf6_raw) { cf6_arr.push(str(cf6_raw[ci])); ci = ci + 1 }
        let cf6 = uniq_sorted(cf6_arr)

        // canon_cf6 = { norm(f) for f in canon_consumes_norm[layer_key] }
        let mut canon_raw: array = []
        let mut ki = 0
        while ki < len(cc_keys) {
            if cc_keys[ki] == layer_key {
                let lst = cc_vals[ki]
                let mut xi = 0
                while xi < len(lst) { canon_raw.push(norm_field(str(lst[xi]))); xi = xi + 1 }
            }
            ki = ki + 1
        }
        let canon_cf6 = uniq_sorted(canon_raw)

        // subset_ok = cf6 <= L6_EMITTED
        let mut subset_ok = true
        let mut ti = 0
        while ti < len(cf6) { if !mem(L6_EMITTED, cf6[ti]) { subset_ok = false }; ti = ti + 1 }
        // match_canon = cf6 == canon_cf6 (both uniq+sorted → compare elementwise)
        let mut match_canon = len(cf6) == len(canon_cf6)
        if match_canon {
            let mut ei = 0
            while ei < len(cf6) { if cf6[ei] != canon_cf6[ei] { match_canon = false }; ei = ei + 1 }
        }
        let ok = subset_ok && match_canon && len(cf6) > 0
        if !ok { fails.push(layer_key + " consumed_from_l6 contract") }
        println("  [" + (if ok { "PASS" } else { "FAIL" }) + "] " + layer_key + ": consumed_from_l6 = " +
                listrepr(cf6) + "  ⊆ L6-emitted? " + pybool(subset_ok) +
                "  == canon consumes_from_l6 " + listrepr(canon_cf6) + "? " + pybool(match_canon))
        si = si + 1
    }

    // 4. F-NB-1-c collision_overlap_target
    let cot = canon["collision_overlap_target"]
    let jac = cot["expected_jaccard_ratio"]
    let thr = if cot.has("pass_threshold") { str(cot["pass_threshold"]) } else { "" }
    let thr_trim = thr.trim()
    let ratio0 = jac == 0.0 && len(thr_trim) > 0 && thr_trim.substr(0, 1) == "<"
    println("  [" + (if ratio0 { "PASS" } else { "FAIL" }) + "] F-NB-1-c collision_overlap_target — expected jaccard " +
            json_stringify(jac) + ", pass_threshold " + reprstr(thr) + "  (L0-L6 vs L7-L9 string-disjoint)")
    if !ratio0 { fails.push("collision_overlap_target") }

    let n_checks = 4 + 1 + 3
    println("")
    println("  --- " + str(n_checks - len(fails)) + "/" + str(n_checks) + " PASS → verdict: " +
            (if len(fails) == 0 { "PASS" } else { "FAIL" }) + " ---")
    println("  C3: contract-shape test (boundary-acknowledgment level) — verifies the L6 emitter provides what")
    println("        the L7-L9 layers consume; the L7-L9 schemas are hexa-bio CONSUMER-PROPOSED drafts (canon adopts → canonical copy")
    println("        moves to canon/domains/life/therapeutic-nanobot/spec/); wet-lab + IP/contract review = canon cycle-30+.")
    if len(fails) == 0 {
        println("__NANOBOT_L6_L7_CONTRACT__ PASS")
        return
    }
    println("  FAILS: " + listrepr(fails))
    println("__NANOBOT_L6_L7_CONTRACT__ FAIL")
    exit(1)
}
