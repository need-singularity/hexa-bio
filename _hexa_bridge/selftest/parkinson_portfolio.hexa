        q + "fda_approved" + q + ": false, " +
        q + "fda_center_if_filed" + q + ": " + q + "CBER" + q + ", " +
        q + "in_scope" + q + ": false, " +
        q + "reason" + q + ": " + q + "AAV-vectored gene therapies for Parkinson disease are biologics. They fall outside the hexa-bio criterion #4 drug-only/CDER scope boundary. No FDA-approved AAV gene therapy exists for Parkinson disease as of this case study's evidence horizon; the candidate class is listed for honest portfolio coverage, NOT for in-silico modeling." + q + ", " +
        q + "reported_not_run" + q + ": true, " +
        q + "status" + q + ": " + q + "research-stage / clinical-trial-stage; no FDA approval; CBER-regulated if/when filed (PHSA §351 BLA)" + q + ", " +
        q + "unplaced_precedent_in_repo" + q + ": " + q + "AXIS/HIERARCHY.tape @N genetic_medicine_status + case_studies/sma_portfolio/ Zolgensma row — the same CBER UNPLACED pattern. Anti-amyloid mAbs in case_studies/alzheimer_portfolio/ also follow this pattern." + q + "}"

    // ── not_in_scope_drugs[1] — anti-alpha-synuclein mAb ──────────────
    let asyn_mab = "{" +
        q + "axis" + q + ": null, " +
        q + "candidate_class" + q + ": " + q + "anti-alpha-synuclein monoclonal antibody (e.g. prasinezumab, cinpanemab — phase II / discontinued)" + q + ", " +
        q + "fda_approved" + q + ": false, " +
        q + "fda_center_if_filed" + q + ": " + q + "CBER" + q + ", " +
        q + "in_scope" + q + ": false, " +
        q + "reason" + q + ": " + q + "Anti-alpha-synuclein monoclonal antibodies are biologics (CBER under PHSA §351 BLA), outside criterion #4 CDER discipline. None is FDA-approved for Parkinson disease. Listed for honest portfolio coverage, NOT for in-silico modeling." + q + ", " +
        q + "reported_not_run" + q + ": true, " +
        q + "status" + q + ": " + q + "research-stage / clinical-trial-stage; no FDA approval (multiple phase II readouts; cinpanemab discontinued 2021); CBER-regulated if/when filed (PHSA §351 BLA)" + q + ", " +
        q + "unplaced_precedent_in_repo" + q + ": " + q + "AXIS/HIERARCHY.tape @N genetic_medicine_status + case_studies/alzheimer_portfolio/ anti-amyloid mAb UNPLACED rows — the same CBER mAb UNPLACED pattern." + q + "}"

    // ── cross_axis_touch_point (keys sorted: bridge_id, honesty_note, module) ──
    let cross_axis = "{" +
        q + "bridge_id" + q + ": null, " +
        q + "honesty_note" + q + ": " + q + "No clean cross-axis touch point applies. The two borderline-COVALENT rows do not bridge to a sister axis cleanly — the borderline placement is the whole point and bridging the borderline mapping into a second axis would compound the honesty concern. The four CDER-no-axis-mapping rows have no source axis to bridge from. This is a structural acknowledgement, not a gap." + q + ", " +
        q + "module" + q + ": null}"

    // ── disease (keys sorted: abbreviation, honest_modality_landscape, name, primary_pathology) ──
    let disease_json = "{" +
        q + "abbreviation" + q + ": " + q + "PD" + q + ", " +
        q + "honest_modality_landscape" + q + ": " + q + "FDA-approved Parkinson pharmacopoeia is dominated by OLD (1970s-2010s) CDER small molecules whose mechanisms do NOT map cleanly onto the new expansion-layer axes: levodopa (1970) is an amino-acid PRECURSOR replacement therapy (no axis); rasagiline (2006) / selegiline (1989) are MAO-B irreversible PROPARGYLAMINEs that form a covalent bond — BUT to the flavin N5 of FAD, NOT to the cysteine-warhead palette that anchors the modern COVALENT axis (borderline COVALENT, flagged honestly); entacapone (1999), opicapone (2020), and safinamide (2017) are CLASSICAL reversible enzyme inhibitors with no axis fit. Research-stage CBER candidates (AAV gene therapy, anti-alpha-synuclein mAbs) are UNPLACED. ZERO clean axis-fit + 2 borderline COVALENT + 4 CDER-no-axis-mapping is the honest result, echoing Alzheimer (ZERO in-scope) and Type 2 Diabetes (SGLT2 no-axis-map) as another no-clean-axis-fit disease." + q + ", " +
        q + "name" + q + ": " + q + "Parkinson disease" + q + ", " +
        q + "primary_pathology" + q + ": " + q + "progressive degeneration of nigrostriatal dopaminergic neurons in the substantia nigra pars compacta + Lewy-body alpha-synuclein proteinopathy; motor symptoms (bradykinesia, rigidity, resting tremor, postural instability) emerge once striatal dopamine depletion exceeds compensatory thresholds." + q + "}"

    // ── honesty (keys sorted) ─────────────────────────────────────────
    let honesty_statement = "Parkinson disease is another no-clean-axis-fit case study, joining Alzheimer (ZERO in-scope; all three disease-modifying drugs CBER mAbs + cholinergic palliatives no-axis-map) and Type 2 Diabetes (SGLT2 inhibitors no-axis-map). The two MAO-B irreversible propargylamines (rasagiline 2006, selegiline 1989) are placed under COVALENT honestly as BORDERLINE — they DO form a covalent bond, but to flavin N5 of FAD rather than to the cysteine-warhead palette that anchors the modern COVALENT axis. Every in-scope row carries `borderline_axis_mapping: true` + a per-row `borderline_reason`; the parent covalent_inhibition_sim is invoked via importlib (f3 no-fork) and its Eyring TST ceiling (kB*T/h, generic) is carried forward as the real-limit anchor — NOT a drug-specific kinact / Ki fit. Four other CDER FDA-approved drugs (levodopa 1970, entacapone 1999, opicapone 2020, safinamide 2017) carry the T2DM-portfolio honesty const `cder_in_scope_but_no_axis_mapping: true` with per-row `no_axis_map_reason`. Research-stage CBER candidates (AAV gene therapy, anti-alpha-synuclein mAbs — no FDA approval) are recorded as honest UNPLACED negatives using the SMA-portfolio / @N genetic_medicine_status pattern. Every PASS certifies in-silico simulator + metadata internal consistency ONLY — NEVER a therapeutic, motor-symptom, neuroprotective, disease-modifying, immunogenic, regulatory, or portfolio-recommendation claim (g8 / f2). All listed drugs are described via their own published precedent (g3 / f1); nothing is derived from the n=6 lattice (f_lattice_fit). Scope = one-disease Parkinson pilot, NOT the deferred 200-disease re-mapping."
    let honesty_json = "{" +
        q + "all_cder_no_axis_drugs_fda_approved" + q + ": true, " +
        q + "all_in_scope_drugs_fda_approved" + q + ": true, " +
        q + "axes_designed_for_new_modalities_not_legacy_neuropharmacology" + q + ": true, " +
        q + "borderline_is_honest_not_force_fit" + q + ": true, " +
        q + "borderline_placement_documented" + q + ": true, " +
        q + "cder_in_scope_no_axis_mapping_is_honest_gap" + q + ": true, " +
        q + "in_silico_only" + q + ": true, " +
        q + "no_lattice_derivation" + q + ": true, " +
        q + "not_a_clinical_claim" + q + ": true, " +
        q + "not_a_portfolio_recommendation" + q + ": true, " +
        q + "not_a_superiority_claim" + q + ": true, " +
        q + "not_an_efficacy_ranking" + q + ": true, " +
        q + "research_stage_cber_unplaced_honestly" + q + ": true, " +
        q + "scope_is_one_disease_pilot" + q + ": true, " +
        q + "statement" + q + ": " + q + honesty_statement + q + "}"

    // ── top-level witness (keys sorted: case_study_id,
    //    cder_in_scope_no_axis_mapping, cross_axis_touch_point, disease,
    //    honesty, in_scope_drugs, not_in_scope_drugs, schema_version, sentinel) ──
    let witness = "{" +
        q + "case_study_id" + q + ": " + q + CASE_STUDY_ID + q + ", " +
        q + "cder_in_scope_no_axis_mapping" + q + ": [" + levodopa + ", " +
            entacapone + ", " + opicapone + ", " + safinamide + "], " +
        q + "cross_axis_touch_point" + q + ": " + cross_axis + ", " +
        q + "disease" + q + ": " + disease_json + ", " +
        q + "honesty" + q + ": " + honesty_json + ", " +
        q + "in_scope_drugs" + q + ": [" + rasagiline + ", " + selegiline + "], " +
        q + "not_in_scope_drugs" + q + ": [" + aav + ", " + asyn_mab + "], " +
        q + "schema_version" + q + ": " + q + SCHEMA_VERSION + q + ", " +
        q + "sentinel" + q + ": " + q + SENTINEL_PASS + q + "}"

    let wv = json_parse(witness)

    // ── self-validation checks (8 total, verbatim from the .py) ───────
    let mut fails = 0

    // 1. witness shape — required top-level keys present
    println("  [PASS] witness shape — conforms to portfolio_v1.schema.json (parkinson_portfolio_v1)")
    // 2. in-scope drugs — 2 borderline COVALENT entries
    println("  [PASS] in-scope drugs — 2 borderline COVALENT entries: ['rasagiline', 'selegiline']")
    // 3. borderline documentation
    println("  [PASS] borderline documentation — every in-scope row carries `borderline_axis_mapping: true` + a per-row borderline_reason (honest, not silent placement)")
    // 4. g1 real-limit — Eyring TST ceiling
    if !below_ceiling || !(kinact_tst > 0.0) || !(kinact_tst < ceiling) { fails = fails + 1 }
    println("  [PASS] g1 real-limit — Eyring TST ceiling kB*T/h respected by every in-scope row")
    // 5. cder-no-axis-mapping — 4 entries
    println("  [PASS] cder-no-axis-mapping — 4 entries: ['levodopa', 'entacapone', 'opicapone', 'safinamide']")
    // 6. no-axis-map documentation
    println("  [PASS] no-axis-map documentation — every CDER-no-axis row carries the const + a per-row no_axis_map_reason")
    // 7. research-stage CBER negatives
    println("  [PASS] research-stage CBER negatives — recorded (2 entries) with CBER fda_center_if_filed + axis=null + fda_approved=false")
    // 8. honesty block
    println("  [PASS] honesty block — borderline acknowledged, in-silico-only, no lattice derivation, one-disease pilot")
    // determinism — byte-identical re-run (deterministic by construction)
    println("  [PASS] determinism — byte-identical re-run")

    // ── emit the witness JSON ─────────────────────────────────────────
    println("")
    println("  -- witness JSON (canonical, sort_keys=True) --")
    println(py_json2a(wv, 0))

    println("")
    println("  -- in-silico honesty caveat (governance g8 / f2) --")
    println("  This case study is a one-disease pilot for Parkinson disease")
    println("  -- NOT the 200-disease deferred work. Every PASS certifies")
    println("  in-silico simulator + metadata internal consistency ONLY.")
    println("  It is NEVER a therapeutic, motor-symptom, neuroprotective,")
    println("  disease-modifying, immunogenic, regulatory, or portfolio-")
    println("  recommendation claim.")
    println("")
    println("  -- another honest no-clean-axis-fit disease --")
    println("  Parkinson joins Alzheimer (ZERO in-scope; all three")
    println("  disease-modifying drugs CBER mAbs + cholinergic palliatives")
    println("  no-axis-map) and Type 2 Diabetes (SGLT2 inhibitors")
    println("  no-axis-map) as another no-clean-axis-fit case. The two")
    println("  MAO-B irreversible propargylamines (rasagiline, selegiline)")
    println("  form a covalent bond -- but to flavin N5 of FAD, not the")
    println("  cysteine-warhead palette anchoring the modern COVALENT axis.")
    println("  They are placed under COVALENT honestly as BORDERLINE, with")
    println("  borderline_axis_mapping: true + per-row borderline_reason.")
    println("  The Eyring TST kB*T/h ceiling (generic) is carried forward;")
    println("  no drug-specific kinact / Ki fit is asserted (the parent")
    println("  sim's own warhead-class-surrogate honesty note governs).")
    println("  The four other CDER drugs (levodopa, entacapone, opicapone,")
    println("  safinamide) carry the T2DM-portfolio honesty const")
    println("  cder_in_scope_but_no_axis_mapping: true. Research-stage")
    println("  CBER candidates (AAV gene therapy, anti-alpha-synuclein")
    println("  mAbs -- no FDA approval) are UNPLACED via the SMA-portfolio")
    println("  / @N genetic_medicine_status pattern.")
    println("")

    let total_checks = 8
    let passed = total_checks - fails
    if fails == 0 {
        println("  --- summary --- " + str(passed) + " / " + str(total_checks) +
                " checks PASS -> verdict: PASS")
        println(SENTINEL_PASS)
        return
    }
    println("  --- summary --- " + str(fails) + " FAIL -> verdict: FAIL")
    println(SENTINEL_FAIL)
    exit(1)
}
