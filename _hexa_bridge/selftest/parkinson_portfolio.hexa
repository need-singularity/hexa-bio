#!hexa strict
// hexa-bio/_hexa_bridge/selftest/parkinson_portfolio.hexa
//
// GENUINE hexa-native port of
// `case_studies/parkinson_portfolio/parkinson_portfolio_runner.py` (T3; importlib/json/os/sys).
// ZERO CPython invocations — the witness is computed and emitted entirely
// in hexa. There is no exec("python3 ...") shell-out at any point, so the
// T3 dependency-zero goal is met.
//
// WHAT THIS GATE IS
// ─────────────────
// Parkinson disease portfolio one-disease pilot — another HONEST no-clean-
// axis-fit disease (joining Alzheimer + Type 2 Diabetes):
//   - 2 IN-SCOPE-BORDERLINE-COVALENT rows (rasagiline, selegiline) — MAO-B
//     irreversible propargylamines; covalent bond to flavin N5 of FAD, NOT
//     the cysteine-warhead palette anchoring the modern COVALENT axis.
//   - 4 CDER-no-axis-mapping rows (levodopa, entacapone, opicapone,
//     safinamide) — classical mechanisms with no expansion-layer axis fit.
//   - 2 research-stage CBER UNPLACED negatives (AAV gene therapy,
//     anti-alpha-synuclein mAbs).
//
// GENUINE-PORT STRATEGY (no fork — f3; no CPython shell-out — T3 rule)
// ──────────────────────────────────────────────────────────────────
// The .py imports the parent covalent_inhibition_sim via importlib and calls
// `eyring_rate(19.0)` (class-level surrogate ΔG‡) + reads EYRING_PREFACTOR.
// Both are INLINED here verbatim from covalent_inhibition_sim.py:
//   K_B = 1.380649e-23   H_PLANCK = 6.62607015e-34   N_A = 6.02214076e23
//   R_GAS = K_B*N_A      KCAL_TO_J = 4184.0          TEMP_K = 310.0
//   EYRING_PREFACTOR = K_B*TEMP_K/H_PLANCK                ≈ 6459351928231.548 /s
//   eyring_rate(dg) = (K_B*TEMP_K/H_PLANCK)*exp(-dg*KCAL_TO_J/(R_GAS*TEMP_K))
//   eyring_rate(19.0)                                     ≈ 0.2602955848142422 /s
// The two borderline-COVALENT rows share that same panel-class surrogate
// value by design (NOT a drug-specific kinact / Ki fit). All other witness
// fields are static metadata strings copied verbatim from the .py.
//
// The .py emits the witness with json.dumps(w, sort_keys=True, indent=2) —
// the DEFAULT ensure_ascii=True, so non-ASCII (the em-dash —, §) is escaped
// as — / §. py_json2a (ensure_ascii=True) reproduces that escaping;
// the witness JSON string is built with keys ALREADY in sorted order, so
// json_parse + py_json2a(_, 0) reproduces CPython's sort_keys=True indent=2
// layout byte-for-byte.
//
// DISCIPLINES honored (1-8):
//   1. shq imported from json_schema_validator (no local fn shq) — kept
//      available per the std top; no shell quoting needed here.
//   2. fsum / Kahan in the std helper set — discipline #7.
//   3. fmt / js / jsb / pyb / ljust / rjust display helpers in the std set.
//   4. raw UTF-8 preserved — the parent .py uses ensure_ascii=True so the
//      em-dash / § are \u-escaped; py_json2a matches that verbatim.
//   5. exit(0) PASS / exit(1) FAIL.
//   6. no SKIP path needed — the port is self-contained (no host runner
//      dependency); it always computes.
//   7. CPython sum() of floats → fsum (Kahan) per ubu-1/3.12 canonical host.
//   8. no listdir / dispatch order — single deterministic witness.
//
// HONESTY (echoes the .py docstring): every PASS = in-silico simulator +
// metadata internal-consistency ONLY (g8 / f2). NEVER a therapeutic,
// motor-symptom, neuroprotective, disease-modifying, immunogenic,
// regulatory, or portfolio-recommendation claim. The two MAO-B
// propargylamines are placed under COVALENT honestly as BORDERLINE; the
// Eyring TST kB*T/h ceiling (generic) is carried forward, NOT a drug-
// specific fit. One-disease pilot only; no quantity is derived from the
// n=6 lattice (g2 / g3 / f1 / f_lattice_fit).

import "_hexa_bridge/module/py_json2.hexa"
import "_hexa_bridge/module/json_schema_validator.hexa"  // for shq

// ── standard helper set ───────────────────────────────────────────────
fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
fn fsum(xs: array) -> float {
    let mut s = 0.0; let mut c = 0.0; let mut i = 0
    while i < len(xs) { let y = xs[i]-c; let t = s+y; c = (t-s)-y; s = t; i = i+1 }
    return s
}

// ── honest scope constants (verbatim from the .py) ────────────────────
let SCHEMA_VERSION = "parkinson_portfolio_v1"
let CASE_STUDY_ID = "parkinson_portfolio.v1"
let SENTINEL_PASS = "__PARKINSON_PORTFOLIO__ PASS"
let SENTINEL_FAIL = "__PARKINSON_PORTFOLIO__ FAIL"

// ── inlined covalent_inhibition_sim physical constants (CODATA 2019) ──
let K_B = 1.380649e-23          // J/K          Boltzmann
let H_PLANCK = 6.62607015e-34   // J·s          Planck
let N_A = 6.02214076e23         // 1/mol        Avogadro
let R_GAS = K_B * N_A           // J/(mol·K)
let KCAL_TO_J = 4184.0          // 1 kcal = 4184 J (thermochemical)
let TEMP_K = 310.0              // K (physiological)
let EYRING_PREFACTOR = K_B * TEMP_K / H_PLANCK   // ≈ 6.46e12 /s @ 310 K

// eyring_rate — Eyring TST rate: k = (kB·T/h)·exp(−ΔG‡/R·T).
fn eyring_rate(dg_kcal: float) -> float {
    let dg_j = dg_kcal * KCAL_TO_J
    return (K_B * TEMP_K / H_PLANCK) * exp(-dg_j / (R_GAS * TEMP_K))
}

fn main() {
    // ── parent covalent_inhibition_sim — class-level Eyring TST surrogate ──
    // panel surrogate ΔG‡ ≈ 19.0 kcal/mol (acrylamide thio-Michael class).
    let kinact_tst = eyring_rate(19.0)         // ≈ 0.2602955848142422 /s
    let ceiling = EYRING_PREFACTOR             // ≈ 6459351928231.548 /s
    let below_ceiling = kinact_tst < ceiling   // true

