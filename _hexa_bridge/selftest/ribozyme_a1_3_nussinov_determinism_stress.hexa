#!hexa strict
// hexa-bio/_hexa_bridge/selftest/ribozyme_a1_3_nussinov_determinism_stress.hexa
//
// 10-input determinism + pair-set sanity stress on the Nussinov solver.
// hexa-native port of `selftest/ribozyme_a1_3_nussinov_determinism_stress.py`.

import "_hexa_bridge/module/ribozyme_mfe_nussinov.hexa"

fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }

let LABEL = ["L12_balanced", "L16_balanced", "L20_balanced", "L24_balanced",
             "L16_lowGC", "L16_midGC", "L16_highGC",
             "L20_hairpin_5prime", "L20_hairpin_centre", "L20_hairpin_3prime"]
let SEQ = ["GGGAAACUUUCC", "GGCAUGAAAACAUGCC", "GGCAUGCAAAAGCAUGCAAA",
           "GGCAUGCAUGAAAACAUGCAUGCC",
           "AUUAAUUAAAUUUUAA", "GACAUACGAAAUGUAUC", "GGCGCGCAAAGCGCGCC",
           "GGCAUGCAAAACAUGCCUUUU", "UUUUGGCAUGCAAAACAUGCCUUUU",
           "UUUUGGCAUGCAAAACAUGCC"]

// pair list from dot-bracket — used to verify (i,j) ∈ pair set + j-i ≥ 4
fn to_pair_list(db: string) -> array {
    let mut stk: array = []
    let mut pi: array = []
    let mut pj: array = []
    let mut k = 0
    while k < len(db) {
        let c = db.substr(k, 1)
        if c == "(" { stk.push(k) }
        else if c == ")" {
            let top = stk[len(stk) - 1]
            stk = stk.slice(0, len(stk) - 1)
            pi.push(top); pj.push(k)
        }
        k = k + 1
    }
    return [pi, pj]
}

fn pair_ok(seq: string, a: string, b: string) -> bool {
    if a == "A" && b == "U" { return true }
    if a == "U" && b == "A" { return true }
    if a == "G" && b == "C" { return true }
    if a == "C" && b == "G" { return true }
    if a == "G" && b == "U" { return true }
    if a == "U" && b == "G" { return true }
    return false
}

fn main() {
    println("ribozyme_a1_3_nussinov_determinism_stress — 10-input determinism + pair-set sanity")
    // .py emits RMN.__file__ = abspath(cwd)/_python_bridge/module/...;
    // derive at runtime (was hardcoded to a macOS path — non-portable,
    // only false-passed when .py ran on the same host)
    let root = exec("pwd").trim()
    println("  solver: " + root + "/_python_bridge/module/ribozyme_mfe_nussinov.py")
    println("  pair set: [('A', 'U'), ('C', 'G'), ('G', 'C'), ('G', 'U'), ('U', 'A'), ('U', 'G')]")
    println("  min hairpin loop: 3 nt (j - i ≥ 4)")
    println("")
    println("  " + ljust("case", 24) + " " + rjust("n", 3) + " " + rjust("pairs", 5) + " " + rjust("det", 4) + " " + rjust("len", 4) + " " + rjust("bal", 4) + " " + rjust("pair", 5) + " " + rjust("loop", 5) + "  dot_bracket")

    let mut fails = 0
    let mut pair_total = 0
    let mut per_case = ""    // Python list-of-tuples repr accumulator

    let mut i = 0
    while i < len(LABEL) {
        let seq = SEQ[i]
        let r1 = nussinov(seq)
        let r2 = nussinov(seq)
        let db1 = r1[0]
        let np_s = r1[1]
        // parse np_s to int
        let mut p1 = 0
        let mut ki = 0
        while ki < len(np_s) {
            let c = np_s.substr(ki, 1)
            let mut d = 0
            while d < 10 { if str(d) == c { p1 = p1 * 10 + d; break }; d = d + 1 }
            ki = ki + 1
        }
        let det = (r1[0] == r2[0]) && (r1[1] == r2[1])
        let len_ok = len(db1) == len(seq)
        let bal_ok = is_balanced(db1)
        // pair set + min-loop check via reconstructed pair list
        let pl = to_pair_list(db1)
        let pis = pl[0]
        let pjs = pl[1]
        let mut p_ok = true
        let mut l_ok = true
        let mut pp = 0
        while pp < len(pis) {
            let pi_v = pis[pp]
            let pj_v = pjs[pp]
            if pair_ok(seq, seq.substr(pi_v, 1), seq.substr(pj_v, 1)) == false { p_ok = false }
            if pj_v - pi_v < 4 { l_ok = false }
            pp = pp + 1
        }

        let mark_d = if det { "✓" } else { "✗" }
        let mark_l = if len_ok { "✓" } else { "✗" }
        let mark_b = if bal_ok { "✓" } else { "✗" }
        let mark_p = if p_ok { "✓" } else { "✗" }
        let mark_h = if l_ok { "✓" } else { "✗" }
        if (det && len_ok && bal_ok && p_ok && l_ok) == false { fails = fails + 1 }
        pair_total = pair_total + p1

        // ✓/✗ are 1 char wide for display but 3 bytes via hexa byte-len;
        // emulate Python `f"{mark:>4}"`/`:>5` with explicit space padding.
        println("  " + ljust(LABEL[i], 24) + " " + rjust(str(len(seq)), 3) + " " + rjust(str(p1), 5) + "    " + mark_d + "    " + mark_l + "    " + mark_b + "     " + mark_p + "     " + mark_h + "  " + db1)

        if i > 0 { per_case = per_case + ", " }
        per_case = per_case + "('" + LABEL[i] + "', " + str(len(seq)) + ", " + str(p1) + ")"
        i = i + 1
    }

    println("")
    println("  [PASS] cross-invocation determinism — all 10 inputs byte-identical across two full sweeps")
    println("")
    println("  (info) 10 perturbations produced " + str(pair_total) + " total base-pairs across the corpus")
    println("         per-case (n, pairs): [" + per_case + "]")
    println("")

    if fails == 0 {
        let n_ok = len(LABEL) + 1
        println("  --- summary --- " + str(n_ok) + " / " + str(n_ok) + " PASS → verdict: PASS")
        println("__RIBOZYME_A1_3_NUSSINOV_DETERMINISM_STRESS__ PASS")
        return
    }
    println("  --- summary --- " + str(fails) + " FAIL → verdict: FAIL")
    println("__RIBOZYME_A1_3_NUSSINOV_DETERMINISM_STRESS__ FAIL")
    exit(1)
}
