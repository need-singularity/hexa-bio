#!hexa strict
// hexa-bio/_hexa_bridge/selftest/alzheimer_portfolio.hexa
//
// GENUINE hexa-native port of `case_studies/alzheimer_portfolio/
// alzheimer_portfolio_runner.py` (T3; json/sys — pure stdlib, deterministic,
// no network/time/random/env). ZERO interpreter-shell invocations — every
// line is computed inline. ALZHEIMER PORTFOLIO case study — the HONESTY SHOWCASE
// whose truthful result is ZERO in-scope drugs:
//   in_scope_drugs             = []   (empty by design — schema enforces it)
//   not_in_scope_drugs         = 3 CBER UNPLACED anti-amyloid mAbs
//                                (lecanemab / donanemab / aducanumab)
//   legacy_palliatives_no_axis = 3 CDER AChE-inhibitor palliatives
//                                (donepezil / rivastigmine / galantamine)
//
// GENUINE STRATEGY: the .py's `build_portfolio()` assembles a fixed nested
// dict; this port re-implements it inline by constructing hexa map/array
// values programmatically (`json_parse("{}")` / `json_parse("[]")` seeds,
// then key/element assignment — `{ }` map-literal syntax is not yet a
// parser surface; `jnull()` lifts a real null out of `json_parse("[null]")`
// since `null` is not an assignable literal). The canonical witness block
// is `json.dumps(w, sort_keys=True, indent=2)` — the default
// ensure_ascii=True so every non-ASCII glyph (`—` U+2014, `β` U+03B2, `§`
// U+00A7; `'` U+0027 stays raw ASCII) serializes as `\uXXXX`. We emit it via
// `py_json2a(wv, 0)` (ensure_ascii=True, byte-identical to CPython
// json.dumps default) and insert every object's keys in SORTED order so the
// keys()-insertion-order walk reproduces sort_keys=True. NO external driver.
//
// BYTE-PARITY: the .py output is byte-stable run-to-run (pure stdlib, fixed
// data structure, deterministic JSON serialization). This port reproduces
// every println line + the witness JSON verbatim; verified vs /tmp/alz.golden.
//
// DISCIPLINES honored:
//   1. shq via json_schema_validator (no local fn shq) — not exercised here.
//   2. fsum / Kahan kept in the std helper set (no float reductions here —
//      the witness is a fixed structure, all numerics are int fda_year).
//   3. fmt / js / jsb / pyb kept standard (table widths not exercised).
//   4. raw UTF-8 preserved in the static banner lines (`—` `·` etc. flow
//      through verbatim); the witness JSON's non-ASCII is emitted as
//      `\uXXXX` by py_json2a exactly as CPython's ensure_ascii default.
//   5. exit(0) on PASS — the witness is a fixed structure, the 7 checks
//      always pass; exit(1) only on an internal contract break.
//   6. no C-stdlib fn-name collisions.
//   7. no `**` operator; `sum(floats)` not exercised.
//   8. deterministic — no discovery / no ordering surface.

import "_hexa_bridge/module/py_json2.hexa"               // py_json2a — ensure_ascii=True
import "_hexa_bridge/module/json_schema_validator.hexa"  // for shq

// ── standard helper set ───────────────────────────────────────────────
fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
fn fsum(xs: array) -> float {
    let mut s = 0.0; let mut c = 0.0; let mut i = 0
    while i < len(xs) { let y = xs[i]-c; let t = s+y; c = (t-s)-y; s = t; i = i+1 }
    return s
}
fn cp_substr(s: string, a: int, b: int) -> string {
    let mut out = ""; let mut cp = 0; let mut i = 0
    while i < len(s) {
        let bv = ord(s.substr(i, 1))
        let is_lead = bv < 128 || bv >= 192
        if is_lead {
            if cp >= b { return out }
            let mut seq = 1
            if bv >= 240 { seq = 4 }
            else if bv >= 224 { seq = 3 }
            else if bv >= 192 { seq = 2 }
            if cp >= a { out = out + s.substr(i, seq) }
            cp = cp + 1
            i = i + seq
        } else {
            i = i + 1
        }
    }
    return out
}

// real null value — `null` is not an assignable literal; lift it out of a
// json_parse'd `[null]`. py_json2a renders it as `null`.
fn jnull() { let n = json_parse("[null]"); return n[0] }

// ── build_portfolio() — re-implemented inline (.py exact data).
// Every map below has its keys ASSIGNED in SORTED order so py_json2a's
// keys()-insertion-order walk reproduces json.dumps(sort_keys=True). ───

// CBER UNPLACED anti-amyloid mAb rows --------------------------------------
fn row_lecanemab() {
    let mut m = json_parse("{}")
    m["axis"] = jnull()
    m["brand"] = "Leqembi"
    m["cber_reason"] = "Monoclonal antibody = biologic — CBER-regulated under PHSA §351 (BLA), NOT NDA under CDER. Per criterion #4 (drug-only/CDER discipline) the hexa-bio axis tree does not register CBER biologics."
    m["drug_name"] = "lecanemab"
    m["drug_precedent_citations"] = json_parse("[]")
    m["drug_precedent_citations"].push("van Dyck CH et al. 2023, N Engl J Med 388:9-21 (CLARITY AD lecanemab phase-3)")
    m["drug_precedent_citations"].push("FDA STN BL 761269 — lecanemab-irmb (Leqembi) accelerated approval 2023-01-06; traditional approval 2023-07-06, CBER")
    m["fda_center"] = "CBER"
    m["fda_year"] = 2023
    m["in_scope"] = false
    m["modality"] = "humanized IgG1 monoclonal antibody — anti-amyloid-β protofibril binder; reduces brain amyloid plaque burden via Fc-mediated microglial clearance"
    m["reason"] = "CBER biologic — criterion #4 drug-only/CDER scope boundary. Implementing an anti-amyloid mAb axis would breach criterion #4 + g8 in-silico-only honesty (immunogenicity, Fc-effector profile, neutralizing-antibody-pre-screen carry claim load that the in-silico axes cannot bound)."
    m["reported_not_run"] = true
    m["sponsor"] = "Eisai / Biogen"
    m["status_note"] = "FDA-approved (traditional approval 2023-07-06, CBER)."
    m["unplaced_precedent_in_repo"] = "AXIS/HIERARCHY.tape @N genetic_medicine_status + @N adc_status — same CBER-scope UNPLACED handling already established (Zolgensma / Casgevy / Comirnaty for gene/cell/mRNA; Enhertu / Kadcyla for ADCs). Anti-amyloid mAbs join the same honesty cohort."
    return m
}
