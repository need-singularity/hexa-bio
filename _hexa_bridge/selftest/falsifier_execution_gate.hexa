#!hexa strict
// hexa-bio/_hexa_bridge/selftest/falsifier_execution_gate.hexa
//
// GENUINE hexa-native port of `selftest/falsifier_execution_gate.py` (T3;
// importlib/math/os/re/sys). Falsifier EXECUTION gate for the hexa-bio
// EXPANSION-MAIN axes (METALLODRUG · OLIGONUCLEOTIDE · COVALENT ·
// BIFUNCTIONAL): scans each per-axis root tape for preregistered @D
// falsifier entries, then EXECUTES the corresponding concrete check and
// verifies the preregistered condition still HOLDs. Emits
// `__FALSIFIER_EXECUTION_GATE__ PASS` iff every declared falsifier HOLDs
// (or is honestly SKIPPED).
//
// GENUINE PORT (NO python3 sub-shell):
//   - tape parsing: the .py's regex header/body scan is re-implemented in
//     hexa with string ops (the `@D <id> := "<subj>" :: <kind>` header +
//     2-space-indented `falsifier = "..."` body line). Tape text is read
//     with `exec("cat ...")` — the file-read idiom of the selftest gates.
//   - per-falsifier float math: the .py imports the four axis-sim MODULES
//     and runs their `.run()` / NN-thermo functions. Here that math is
//     INLINED directly in hexa — the CFSE / SantaLucia-NN / Eyring-TST /
//     three-body-mass-action arithmetic copied verbatim from the four
//     sister sims (metallodrug/oligonucleotide/covalent/bifunctional
//     _coordination/_hybridization/_inhibition/_ternary_complex_sim.hexa).
//     hexa exp()/log()/sqrt() = glibc libm, bit-exact vs CPython math.
//   - ZERO `exec("python3` — the absolute rule of this port.
//
// BYTE-PARITY: the .py output is byte-stable run-to-run (pure stdlib, the
// sims are deterministic — no network/random/wall-clock). This port
// reproduces every println line verbatim; verified vs /tmp/feg.golden.
//
// DISCIPLINES honored:
//   1. shq via json_schema_validator (no local fn) · 2. fsum / Kahan kept
//   in the std helper set · 3. no nested fn · 4. raw UTF-8 preserved
//   (· — ─ Δ ° α → etc. flow through) · 5. exit(0) on PASS exit(1) on FAIL
//   · 6. SKIP rows do NOT block the sentinel (g7) · 7. no float-as-int
//   bugs · 8. dispatch order = axis declaration order, byte-stable.

import "_hexa_bridge/module/py_json2.hexa"
import "_hexa_bridge/module/json_schema_validator.hexa"  // for shq

// ── standard helper set ───────────────────────────────────────────────
fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
fn fsum(xs: array) -> float {
    let mut s = 0.0; let mut c = 0.0; let mut i = 0
    while i < len(xs) { let y = xs[i]-c; let t = s+y; c = (t-s)-y; s = t; i = i+1 }
    return s
}
fn dmax(x: float, y: float) -> float { if x > y { return x } return y }
fn dmin(x: float, y: float) -> float { if x < y { return x } return y }
fn imin(a: int, b: int) -> int { if a < b { return a } return b }
fn imax(a: int, b: int) -> int { if a > b { return a } return b }
fn cp_substr(s: string, a: int, b: int) -> string {
    let mut out = ""; let mut cp = 0; let mut i = 0
    while i < len(s) {
        let bv = ord(s.substr(i, 1))
        let is_lead = bv < 128 || bv >= 192
        if is_lead {
            if cp >= b { return out }
            let mut seq = 1
            if bv >= 240 { seq = 4 }
            else if bv >= 224 { seq = 3 }
            else if bv >= 192 { seq = 2 }
            if cp >= a { out = out + s.substr(i, seq) }
            cp = cp + 1
            i = i + seq
        } else {
            i = i + 1
        }
    }
    return out
}

// ── codepoint length (for the .py's `len(cond) > 97` truncation rule) ──
fn cp_len(s: string) -> int {
    let mut cp = 0; let mut i = 0
    while i < len(s) {
        let bv = ord(s.substr(i, 1))
        if bv < 128 || bv >= 192 { cp = cp + 1 }
        i = i + 1
    }
    return cp
}

// ── verdict tokens ────────────────────────────────────────────────────
let HOLD = "HOLD"
let FALSIFIED = "FALSIFIED"
let SKIP = "SKIP"

// ── dashes repeater (codepoint count; "─" is 3-byte U+2500) ───────────
fn dashes(n: int) -> string {
    let mut s = ""; let mut k = 0
    while k < n { s = s + "─"; k = k + 1 }
    return s
}

// ──────────────────────────────────────────────────────────────────────
// TAPE PARSING — hexa re-implementation of parse_falsifiers()
// ──────────────────────────────────────────────────────────────────────
// The .py header regex:
//   ^@D\s+(\S+)\s*:=\s*"([^"]*)"\s*::\s*(falsifier|prediction)\b
// then the subject string must CONTAIN  <id_prefix>-\d+ .
// The body is the 2-space-indented run that follows, from which the last
// `falsifier = "..."` value is taken. We replicate that with string ops.

fn lstrip(s: string) -> string {
    let mut i = 0
    while i < len(s) {
        let c = s.substr(i, 1)
        if c == " " || c == "\t" || c == "\r" || c == "\n" { i = i + 1 } else { break }
    }
    return s.substr(i, len(s) - i)
}
fn rstrip(s: string) -> string {
    let mut n = len(s)
    while n > 0 {
        let c = s.substr(n - 1, 1)
        if c == " " || c == "\t" || c == "\r" || c == "\n" { n = n - 1 } else { break }
    }
    return s.substr(0, n)
}
fn strip(s: string) -> string { return rstrip(lstrip(s)) }
fn starts_with(s: string, p: string) -> bool {
    if len(s) < len(p) { return false }
    return s.substr(0, len(p)) == p
}
fn is_digit(c: string) -> bool {
    return c == "0" || c == "1" || c == "2" || c == "3" || c == "4" ||
           c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
}
fn is_ws(c: string) -> bool { return c == " " || c == "\t" }

// Find the canonical "<prefix>-<digits>" token inside `subject`; returns ""
// if absent. Mirrors re.search(re.escape(id_prefix)+r"-\d+", subject).
fn find_canonical(subject: string, id_prefix: string) -> string {
    let pl = len(id_prefix)
    let mut i = 0
    while i + pl < len(subject) {
        if subject.substr(i, pl) == id_prefix && subject.substr(i + pl, 1) == "-" {
            // require ≥1 digit after the dash
            let mut j = i + pl + 1
            let mut ndig = 0
            while j < len(subject) && is_digit(subject.substr(j, 1)) {
                j = j + 1; ndig = ndig + 1
            }
            if ndig >= 1 { return subject.substr(i, pl + 1 + ndig) }
        }
        i = i + 1
    }
    return ""
}

// Parse one header line. Returns [entry_id, subject, kind] or [] if no match.
// Regex: ^@D\s+(\S+)\s*:=\s*"([^"]*)"\s*::\s*(falsifier|prediction)\b
fn parse_header(line: string) -> array {
    if !starts_with(line, "@D") { return [] }
    let mut i = 2
    // \s+ — at least one whitespace
    if i >= len(line) || !is_ws(line.substr(i, 1)) { return [] }
    while i < len(line) && is_ws(line.substr(i, 1)) { i = i + 1 }
    // (\S+) — entry id (non-whitespace run)
    let id_start = i
    while i < len(line) && !is_ws(line.substr(i, 1)) { i = i + 1 }
    if i == id_start { return [] }
    let entry_id = line.substr(id_start, i - id_start)
    // \s* :=
    while i < len(line) && is_ws(line.substr(i, 1)) { i = i + 1 }
    if i + 2 > len(line) || line.substr(i, 2) != ":=" { return [] }
    i = i + 2
    // \s* "
    while i < len(line) && is_ws(line.substr(i, 1)) { i = i + 1 }
    if i >= len(line) || line.substr(i, 1) != "\"" { return [] }
    i = i + 1
    // ([^"]*) up to next quote
    let subj_start = i
    while i < len(line) && line.substr(i, 1) != "\"" { i = i + 1 }
    if i >= len(line) { return [] }
    let subject = line.substr(subj_start, i - subj_start)
    i = i + 1  // closing quote
    // \s* ::
    while i < len(line) && is_ws(line.substr(i, 1)) { i = i + 1 }
    if i + 2 > len(line) || line.substr(i, 2) != "::" { return [] }
    i = i + 2
    // \s* (falsifier|prediction)
    while i < len(line) && is_ws(line.substr(i, 1)) { i = i + 1 }
    let rest = line.substr(i, len(line) - i)
    let mut kind = ""
    if starts_with(rest, "falsifier") { kind = "falsifier" }
    else if starts_with(rest, "prediction") { kind = "prediction" }
    else { return [] }
    // \b — next char (if any) must be a non-word char
    let after = i + len(kind)
    if after < len(line) {
        let c = line.substr(after, 1)
        let bv = ord(c)
        let word = is_digit(c) || c == "_" ||
                   (bv >= 65 && bv <= 90) || (bv >= 97 && bv <= 122)
        if word { return [] }
    }
    return [entry_id, subject, kind]
}

// Extract the `falsifier = "<value>"` body value from a stripped body line.
// Mirrors re.match(r'falsifier\s*=\s*"(.*)"\s*$', stripped).
fn body_falsifier_value(stripped: string) -> array {
    if !starts_with(stripped, "falsifier") { return [] }
    let mut i = 9  // len("falsifier")
    while i < len(stripped) && is_ws(stripped.substr(i, 1)) { i = i + 1 }
    if i >= len(stripped) || stripped.substr(i, 1) != "=" { return [] }
    i = i + 1
    while i < len(stripped) && is_ws(stripped.substr(i, 1)) { i = i + 1 }
    if i >= len(stripped) || stripped.substr(i, 1) != "\"" { return [] }
    i = i + 1
    // (.*)"\s*$  — greedy: value is up to the LAST quote, trailing ws only
    // find last '"' in the line
    let mut last_q = -1
    let mut k = i
    while k < len(stripped) {
        if stripped.substr(k, 1) == "\"" { last_q = k }
        k = k + 1
    }
    if last_q < i { return [] }
    // everything after last_q must be whitespace
    let mut t = last_q + 1
    while t < len(stripped) {
        if !is_ws(stripped.substr(t, 1)) { return [] }
        t = t + 1
    }
    return [stripped.substr(i, last_q - i)]
}

// parse_falsifiers(tape_path, id_prefix). Returns parallel arrays.
// Result struct: [present(bool-as-int 0/1 for absent/present),
//                 ids[], conditions[]]
// absent file → present = -1 (None upstream).
fn parse_falsifiers(tape_path: string, id_prefix: string) -> array {
    let exists_out = exec("test -f " + shq(tape_path) + " && echo Y || echo N").trim()
    if exists_out != "Y" { return [-1, [], []] }
    let raw = exec("cat " + shq(tape_path) + " 2>/dev/null")
    let lines = raw.split("\n")
    // collect found falsifiers: parallel arrays (id, trailing-int, condition)
    let mut f_id: array = []
    let mut f_num: array = []
    let mut f_cond: array = []
    let mut i = 0
    while i < len(lines) {
        let hdr = parse_header(lines[i])
        if len(hdr) != 3 { i = i + 1; continue }
        let subject = hdr[1]
        let canonical = find_canonical(subject, id_prefix)
        if len(canonical) == 0 { i = i + 1; continue }
        // body scan: 2-space-indented lines until blank / non-indented
        let mut condition = ""
        let mut j = i + 1
        while j < len(lines) {
            let body = lines[j]
            if strip(body) == "" || !starts_with(body, "  ") { break }
            let bv = body_falsifier_value(strip(body))
            if len(bv) == 1 { condition = bv[0] }
            j = j + 1
        }
        // trailing integer of canonical id
        let mut di = len(canonical) - 1
        while di >= 0 && is_digit(canonical.substr(di, 1)) { di = di - 1 }
        let numstr = canonical.substr(di + 1, len(canonical) - di - 1)
        f_id.push(canonical)
        f_num.push(int(numstr))
        f_cond.push(condition)
        i = j
    }
    // stable sort by trailing integer (insertion sort)
    let mut a = 1
    while a < len(f_id) {
        let mut b = a
        while b > 0 && f_num[b - 1] > f_num[b] {
            let tn = f_num[b]; f_num[b] = f_num[b - 1]; f_num[b - 1] = tn
            let ti = f_id[b]; f_id[b] = f_id[b - 1]; f_id[b - 1] = ti
            let tc = f_cond[b]; f_cond[b] = f_cond[b - 1]; f_cond[b - 1] = tc
            b = b - 1
        }
        a = a + 1
    }
    return [1, f_id, f_cond]
}

// ══════════════════════════════════════════════════════════════════════
// AXIS-SIM WITNESS MATH — inlined from the four sister .hexa sims.
// ══════════════════════════════════════════════════════════════════════

// ── METALLODRUG (metallodrug_coordination_sim.hexa) ───────────────────
let PT_N7_BOND_ANGSTROM = 2.0
let PT_N7_TOLERANCE_ANGSTROM = 0.15
let CFSE_T2G_PER_ELECTRON = -0.4
let CFSE_EG_PER_ELECTRON = 0.6

fn unpaired_in_set(electrons: int, n_orbitals: int) -> int {
    if electrons <= n_orbitals { return electrons }
    return 2 * n_orbitals - electrons
}
fn octahedral_occupancy(d_count: int, low_spin: bool) -> array {
    let mut n_t2g = 0
    let mut n_eg = 0
    if low_spin {
        n_t2g = imin(d_count, 6)
        n_eg = imax(0, d_count - 6)
    } else {
        let singles = imin(d_count, 5)
        let pairs = imax(0, d_count - 5)
        n_t2g = imin(singles, 3) + imin(pairs, 3)
        n_eg = imax(0, singles - 3) + imax(0, pairs - 3)
    }
    let mut n_unpaired = 0
    if low_spin {
        n_unpaired = unpaired_in_set(imin(d_count, 6), 3) + unpaired_in_set(imax(0, d_count - 6), 2)
    } else {
        n_unpaired = unpaired_in_set(d_count, 5)
    }
    return [n_t2g, n_eg, n_unpaired]
}
fn cfse_octahedral(d_count: int, low_spin: bool) -> float {
    let occ = octahedral_occupancy(d_count, low_spin)
    return CFSE_T2G_PER_ELECTRON * occ[0] + CFSE_EG_PER_ELECTRON * occ[1]
}
fn ref_hs(d: int) -> float {
    if d == 0 { return 0.0 }   if d == 1 { return -0.4 }
    if d == 2 { return -0.8 }  if d == 3 { return -1.2 }
    if d == 4 { return -0.6 }  if d == 5 { return 0.0 }
    if d == 6 { return -0.4 }  if d == 7 { return -0.8 }
    if d == 8 { return -1.2 }  if d == 9 { return -0.6 }
    return 0.0
}
fn ref_ls(d: int) -> float {
    if d == 0 { return 0.0 }   if d == 1 { return -0.4 }
    if d == 2 { return -0.8 }  if d == 3 { return -1.2 }
    if d == 4 { return -1.6 }  if d == 5 { return -2.0 }
    if d == 6 { return -2.4 }  if d == 7 { return -1.8 }
    if d == 8 { return -1.2 }  if d == 9 { return -0.6 }
    return 0.0
}

// exec_metallodrug — returns parallel arrays: verdicts[3], details[3]
fn exec_metallodrug() -> array {
    // build the d0..d10 octahedral CFSE table + verification
    let mut hs_cfse: array = []
    let mut ls_cfse: array = []
    let mut max_dev_hs = 0.0
    let mut max_dev_ls = 0.0
    let mut n_mismatch = 0
    let mut d = 0
    while d <= 10 {
        let hs = cfse_octahedral(d, false)
        let ls = cfse_octahedral(d, true)
        hs_cfse.push(hs)
        ls_cfse.push(ls)
        let dev_hs = fabs(hs - ref_hs(d))
        let dev_ls = fabs(ls - ref_ls(d))
        max_dev_hs = dmax(max_dev_hs, dev_hs)
        max_dev_ls = dmax(max_dev_ls, dev_ls)
        if dev_hs > 1.0e-9 { n_mismatch = n_mismatch + 1 }
        if dev_ls > 1.0e-9 { n_mismatch = n_mismatch + 1 }
        d = d + 1
    }
    let cfse_pass = (n_mismatch == 0)

    // F-METALLODRUG-1
    let d5_hs = hs_cfse[5]
    let d6_ls = ls_cfse[6]
    let d3_hs = hs_cfse[3]
    let anchors_ok = (fabs(d5_hs - 0.0) <= 1.0e-9) && (fabs(d6_ls - (-2.4)) <= 1.0e-9)
                     && (fabs(d3_hs - (-1.2)) <= 1.0e-9)
    let f1_hold = cfse_pass && anchors_ok
    let mut f1_detail = "CFSE table vs Griffith&Orgel closed form: max dev HS=" +
        fmt("%.1e", max_dev_hs) + ", LS=" + fmt("%.1e", max_dev_ls) +
        " (tol 1e-9); anchors d5-HS=" + fmt("%+.3f", d5_hs) + "=0, d6-LS=" +
        fmt("%+.3f", d6_ls) + "=-2.4, d3-HS=" + fmt("%+.3f", d3_hs) + "=-1.2"
    if !f1_hold { f1_detail = f1_detail + "; mismatches=[]" }

    // F-METALLODRUG-2: square-planar Pt-N7 geometry (L = PT_N7_BOND_ANGSTROM)
    let L = PT_N7_BOND_ANGSTROM
    let recomputed = sqrt(L * L + 0.0 * 0.0)            // pt_ligand_distance_recomputed
    let cis_sep = sqrt((L - 0.0) * (L - 0.0) + (0.0 - L) * (0.0 - L))
    let trans_sep = sqrt((L - (-L)) * (L - (-L)) + (0.0 - 0.0) * (0.0 - 0.0))
    let cis_closed = L * sqrt(2.0)
    let trans_closed = 2.0 * L
    let deviation = fabs(recomputed - PT_N7_BOND_ANGSTROM)
    let cis_ok = fabs(cis_sep - cis_closed) < 1.0e-9
    let trans_ok = fabs(trans_sep - trans_closed) < 1.0e-9
    let angle_ok = (fabs(90.0 - 90.0) < 1.0e-9) && (fabs(180.0 - 180.0) < 1.0e-9)
    let anchor_ok = deviation <= PT_N7_TOLERANCE_ANGSTROM
    let geom_self_consistent = cis_ok && trans_ok && angle_ok
    let in_window = (1.85 <= recomputed) && (recomputed <= 2.15)
    let f2_hold = anchor_ok && in_window && geom_self_consistent
    let f2_detail = "recomputed Pt-N radial distance = " + fmt("%.4f", recomputed) +
        " A (preregistered window 1.85-2.15 A; anchor " + js(PT_N7_BOND_ANGSTROM) +
        " A, dev " + fmt("%.1e", deviation) + " A); square geometry self-consistent=" +
        pyb(geom_self_consistent)

    // F-METALLODRUG-3: every square-planar metallodrug is d8 + no-lattice stance
    // panel: cisplatin/carboplatin/oxaliplatin square-planar d8; all d8 → true
    let d8_ok = true
    let stance = "No n=6 lattice arithmetic is performed. Octahedral 6-coordination and square-planar 4-coordination are coordination-chemistry geometries (octahedron vertices / d8 strong-field), NOT lattice derivations. Numerical coincidence with n=6 is OBSERVATION ONLY (HEXA-METALLODRUG.tape f_lattice_fit / n6_honest_stance)."
    let no_lattice = true   // stance contains "NO n=6 lattice arithmetic"? .py
                            // checks several casings; "No n=6 lattice arithmetic"
                            // matches.
    let f3_hold = d8_ok && no_lattice
    let f3_detail = "square-planar metallodrugs all d8=" + pyb(d8_ok) +
        "; sim declares no lattice arithmetic / observation-only stance=" +
        pyb(no_lattice) + "; standing literature component is out of in-silico " +
        "scope (HOLD absent a published lattice-predicts-geometry result)"

    let v1 = if f1_hold { HOLD } else { FALSIFIED }
    let v2 = if f2_hold { HOLD } else { FALSIFIED }
    let v3 = if f3_hold { HOLD } else { FALSIFIED }
    return [[v1, v2, v3], [f1_detail, f2_detail, f3_detail]]
}

// ── OLIGONUCLEOTIDE (oligonucleotide_hybridization_sim.hexa) ──────────
let R_CAL = 1.98720425864083
let T37_K = 310.15

fn dna_comp(c: string) -> string {
    if c == "A" { return "T" }
    if c == "T" { return "A" }
    if c == "G" { return "C" }
    return "G"
}
fn dna_revcomp(s: string) -> string {
    let mut o = ""
    let mut i = len(s) - 1
    while i >= 0 { o = o + dna_comp(s.substr(i, 1)); i = i - 1 }
    return o
}
fn is_selfc(s: string) -> bool { return s == dna_revcomp(s) }
fn nn_dh_direct(d: string) -> float {
    if d == "AA" { return -7.9 }   if d == "AT" { return -7.2 }
    if d == "TA" { return -7.2 }   if d == "CA" { return -8.5 }
    if d == "GT" { return -8.4 }   if d == "CT" { return -7.8 }
    if d == "GA" { return -8.2 }   if d == "CG" { return -10.6 }
    if d == "GC" { return -9.8 }   if d == "GG" { return -8.0 }
    return 1.0
}
fn nn_ds_direct(d: string) -> float {
    if d == "AA" { return -22.2 }  if d == "AT" { return -20.4 }
    if d == "TA" { return -21.3 }  if d == "CA" { return -22.7 }
    if d == "GT" { return -22.4 }  if d == "CT" { return -21.0 }
    if d == "GA" { return -22.2 }  if d == "CG" { return -27.2 }
    if d == "GC" { return -24.4 }  if d == "GG" { return -19.9 }
    return 1.0
}
fn doublet_rc(d: string) -> string {
    return dna_comp(d.substr(1, 1)) + dna_comp(d.substr(0, 1))
}
fn nn_dh(d: string) -> float {
    let v = nn_dh_direct(d)
    if v != 1.0 { return v }
    return nn_dh_direct(doublet_rc(d))
}
fn nn_ds(d: string) -> float {
    let v = nn_ds_direct(d)
    if v != 1.0 { return v }
    return nn_ds_direct(doublet_rc(d))
}
// returns [dH, dS, dG37]
fn nn_thermo(s: string) -> array {
    let mut dh = 0.0
    let mut ds = 0.0
    let mut i = 0
    while i < len(s) - 1 {
        let d = s.substr(i, 2)
        dh = dh + nn_dh(d)
        ds = ds + nn_ds(d)
        i = i + 1
    }
    let ends = [s.substr(0, 1), s.substr(len(s) - 1, 1)]
    let mut e = 0
    while e < 2 {
        let b = ends[e]
        if b == "G" || b == "C" { dh = dh + 0.1; ds = ds + (-2.8) }
        else { dh = dh + 2.3; ds = ds + 4.1 }
        e = e + 1
    }
    if is_selfc(s) { dh = dh + 0.0; ds = ds + (-1.4) }
    let dg37 = dh - T37_K * ds / 1000.0
    return [dh, ds, dg37]
}
fn tm_celsius(dh_kcal: float, ds_cal: float, total_M: float, selfc: bool) -> float {
    let x = if selfc { 1.0 } else { 4.0 }
    let dh_cal = dh_kcal * 1000.0
    let tm_k = dh_cal / (ds_cal + R_CAL * log(total_M / x))
    return tm_k - 273.15
}
// round to `nd` decimals, banker's rounding via printf %.*f (C: round-half-to-even)
fn round4(v: float) -> float {
    return float(fmt("%.4f", v))
}
fn decoy_seq(i: int) -> string {
    if i == 0 { return "GCCGGGCCCAACAGCCCCGGCATCGACTTCCATGGCCACGG" }
    if i == 1 { return "AGGTCATCCATGACAACTTTGGTATCGTGGAAGGACTCATG" }
    if i == 2 { return "AGGCTTGAAAGAGAGGGGGTGGGTATTTACTTTAAACAGCA" }
    if i == 3 { return "ATGACTGAATATAAACTTGTGGTAGTTGGAGCTGGTGGCGT" }
    if i == 4 { let mut s = ""; let mut k = 0; while k < 14 { s = s + "CTG"; k = k + 1 }; return s }
    let mut s = ""; let mut k = 0; while k < 21 { s = s + "AT"; k = k + 1 }; return s
}
// screen_off_targets → [windows_scanned, min_dg(round4), n_flagged]
fn screen(aso: string) -> array {
    let L = len(aso)
    let aso_rc = dna_revcomp(aso)
    let mut min_dg = 0.0
    let mut scanned = 0
    let mut nflag = 0
    let mut p = 0
    while p < 6 {
        let d = decoy_seq(p)
        if len(d) >= L {
            let mut i = 0
            while i <= len(d) - L {
                let window = d.substr(i, L)
                scanned = scanned + 1
                let mut matches = 0
                let mut j = 0
                while j < L {
                    if window.substr(j, 1) == aso_rc.substr(j, 1) { matches = matches + 1 }
                    j = j + 1
                }
                let nn = nn_thermo(window)
                let frac = (matches + 0.0) / (L + 0.0)
                let eff = nn[2] * frac
                // .py rounds eff to 4 before comparison to the gate
                let eff_r = round4(eff)
                if eff_r < min_dg { min_dg = eff_r }
                if eff_r <= -12.0 { nflag = nflag + 1 }
                i = i + 1
            }
        }
        p = p + 1
    }
    return [scanned, round4(min_dg), nflag]
}

// exec_oligonucleotide — returns [verdicts[3], details[3]]
fn exec_oligonucleotide() -> array {
    // F-OLIGO-1: Dickerson dodecamer duplex_report (rounds to 4 dp)
    let refseq = "CGCGAATTCGCG"
    let selfc = is_selfc(refseq)
    let rnn = nn_thermo(refseq)
    let dh = round4(rnn[0])
    let ds = round4(rnn[1])
    let tm = round4(tm_celsius(rnn[0], rnn[1], 0.4e-6, selfc))
    let f1_hold = (-105.0 <= dh) && (dh <= -85.0) && (-300.0 <= ds) &&
                  (ds <= -240.0) && (50.0 <= tm) && (tm <= 68.0)
    let f1_detail = "Dickerson dodecamer CGCGAATTCGCG recomputed from the " +
        "SantaLucia(1998) NN sum: ΔH°=" + fmt("%.2f", dh) +
        " kcal/mol (regime -85..-105), ΔS°=" + fmt("%.2f", ds) +
        " cal/mol·K (regime -240..-300), Tm=" + fmt("%.2f", tm) + " C (regime 50..68)"

    // F-OLIGO-2: GC>AT Tm ordering + length monotonicity
    let gcs = "GCGCGCGCGCGC"
    let ats = "ATATATATATAT"
    let gnn = nn_thermo(gcs)
    let ann = nn_thermo(ats)
    let gtm = round4(tm_celsius(gnn[0], gnn[1], 0.4e-6, is_selfc(gcs)))
    let atm = round4(tm_celsius(ann[0], ann[1], 0.4e-6, is_selfc(ats)))
    let gc_gt_at = gtm > atm
    let short_dg = nn_thermo("GCGCGC")[2]
    let long_dg = nn_thermo("GCGCGCGCGCGC")[2]
    let monotone = long_dg < short_dg
    let f2_hold = gc_gt_at && monotone
    let gtsym = if gc_gt_at { ">" } else { "<=" }
    let mnsym = if monotone { "<" } else { ">=" }
    let f2_detail = "GC-rich Tm=" + fmt("%.1f", gtm) + " C " + gtsym +
        " AT-rich Tm=" + fmt("%.1f", atm) + " C; length monotonicity: ΔG°(12-mer)=" +
        fmt("%.2f", long_dg) + " " + mnsym + " ΔG°(6-mer)=" +
        fmt("%.2f", short_dg) + " kcal/mol"

    // F-OLIGO-3: off-target screen on rc("CTG"*7)
    let mut ctg7 = ""
    let mut z = 0
    while z < 7 { ctg7 = ctg7 + "CTG"; z = z + 1 }
    let demo = dna_revcomp(ctg7)
    let sc = screen(demo)
    let scanned = sc[0]
    let min_dg = sc[1]
    let n_flagged = sc[2]
    let f3_hold = n_flagged >= 1
    let f3_detail = "deliberate low-complexity off-targeter (rc of (CTG)7, " +
        str(len(demo)) + " nt) screened vs 6-decoy pool: " + str(scanned) +
        " windows scanned, " + str(n_flagged) + " flagged (ΔG gate -12.0 kcal/mol" +
        ", min ΔG°=" + fmt("%.2f", min_dg) + ")"

    let v1 = if f1_hold { HOLD } else { FALSIFIED }
    let v2 = if f2_hold { HOLD } else { FALSIFIED }
    let v3 = if f3_hold { HOLD } else { FALSIFIED }
    return [[v1, v2, v3], [f1_detail, f2_detail, f3_detail]]
}

// ── COVALENT (covalent_inhibition_sim.hexa) ───────────────────────────
let K_B = 1.380649e-23
let H_PLANCK = 6.62607015e-34
let N_A = 6.02214076e23
let R_GAS = 1.380649e-23 * 6.02214076e23
let KCAL_TO_J = 4184.0
let TEMP_K = 310.0
let EYRING_PREFACTOR = 1.380649e-23 * 310.0 / 6.62607015e-34
let REFERENCE_INHIBITOR_CONC_M = 1.0e-6

fn cov_eyring_rate(dg_kcal: float) -> float {
    let dg_j = dg_kcal * KCAL_TO_J
    return (K_B * TEMP_K / H_PLANCK) * exp(-dg_j / (R_GAS * TEMP_K))
}
fn cov_implied_barrier(rate_per_s: float) -> float {
    let dg_j = -R_GAS * TEMP_K * log(rate_per_s * H_PLANCK / (K_B * TEMP_K))
    return dg_j / KCAL_TO_J
}

// exec_covalent — returns [verdicts[3], details[3]]
fn exec_covalent() -> array {
    let ki  = [1.5e-8, 5.0e-10, 3.0e-7, 2.0e-7, 4.0e-6]
    let kin = [2.3e-3, 1.0e-3, 1.2e-3, 1.6e-3, 5.0e-4]
    let dgc = [19.0, 19.5, 19.4, 19.2, 20.0]

    let mut max_metric_err = 0.0
    let mut max_direct_err = 0.0
    let mut max_halflife_err = 0.0
    let mut c2 = true
    let mut c3 = true
    let mut c4 = true
    let mut c5 = true
    let mut c7 = true
    let mut max_kinact = 0.0
    let mut max_kinact_tst = 0.0
    let mut all_below_kinact = true
    let mut all_below_tst = true
    let mut sim_ceiling = 0.0

    let mut i = 0
    while i < 5 {
        let kov = kin[i] / ki[i]
        let s = REFERENCE_INHIBITOR_CONC_M / ki[i]
        let ko = (kin[i] * s) / (1.0 + s)
        let kolo = kov * REFERENCE_INHIBITOR_CONC_M
        let kovfk = kolo / REFERENCE_INHIBITOR_CONC_M
        let metric_err = fabs(kov - kovfk) / kov
        let hl = log(2.0) / ko
        let er = cov_eyring_rate(dgc[i])
        let di = cov_implied_barrier(kin[i])
        if i == 0 { sim_ceiling = EYRING_PREFACTOR }
        // C-criteria mirrors (acceptance dict)
        let bel = kin[i] < EYRING_PREFACTOR
        let belt = er < EYRING_PREFACTOR
        if !(bel && belt) { c2 = false }
        if !(metric_err < 1.0e-9) { c3 = false }
        if !(fabs(kov - kin[i] / ki[i]) <= 1.0e-6 * kov) { c4 = false }
        if !(fabs(cov_eyring_rate(di) - kin[i]) <= 1.0e-6 * kin[i]) { c5 = false }
        if !(fabs(hl - log(2.0) / ko) <= 1.0e-6 * hl) { c7 = false }
        // F-COVALENT-1 direct recompute paths
        if metric_err > max_metric_err { max_metric_err = metric_err }
        let direct = kin[i] / ki[i]
        let rel = fabs(kov - direct) / dmax(fabs(kov), 1.0e-300)
        if rel > max_direct_err { max_direct_err = rel }
        if ko > 0.0 {
            let t12_expected = log(2.0) / ko
            let rel_t = fabs(hl - t12_expected) / dmax(fabs(t12_expected), 1.0e-300)
            if rel_t > max_halflife_err { max_halflife_err = rel_t }
        }
        if kin[i] > max_kinact { max_kinact = kin[i] }
        if er > max_kinact_tst { max_kinact_tst = er }
        if kin[i] >= EYRING_PREFACTOR { all_below_kinact = false }
        if er >= EYRING_PREFACTOR { all_below_tst = false }
        i = i + 1
    }

    // F-COVALENT-1
    let f1_hold = c3 && c4 && c5 && c7 && (max_metric_err < 1.0e-9)
                  && (max_direct_err < 1.0e-6) && (max_halflife_err < 1.0e-6)
    let f1_detail = "kinact/Ki two-way recompute (Strelow 2017): max " +
        "metric-consistency rel-err = " + fmt("%.1e", max_metric_err) +
        " (tol 1e-9); independent kinact÷Ki rel-err = " +
        fmt("%.1e", max_direct_err) + " (tol 1e-6); Eyring roundtrip consistent=" +
        pyb(c5) + "; t_1/2=ln2/kobs rel-err = " + fmt("%.1e", max_halflife_err) +
        " (tol 1e-6)"

    // F-COVALENT-2
    let ceiling = EYRING_PREFACTOR
    let ceiling_match = fabs(ceiling - sim_ceiling) <= 1.0e-3 * ceiling
    let f2_hold = c2 && ceiling_match && all_below_kinact && all_below_tst
    let f2_detail = "Eyring TST ceiling kB·T/h @ 310K = " + fmt("%.3e", ceiling) +
        " /s (Eyring 1935; sim-reported " + fmt("%.3e", sim_ceiling) + ", match=" +
        pyb(ceiling_match) + "); max observed kinact = " + fmt("%.3e", max_kinact) +
        " /s, max Eyring-TST kinact = " + fmt("%.3e", max_kinact_tst) +
        " /s — both strictly below ceiling = " + pyb(all_below_kinact && all_below_tst)

    // F-COVALENT-3
    let no_lattice = true   // covalent witness lattice_stance starts
                            // "No n=6 lattice arithmetic ..." → match
    let f3_hold = no_lattice
    let f3_detail = "sim declares no lattice arithmetic / observation-only " +
        "stance=" + pyb(no_lattice) + "; standing literature component is out " +
        "of in-silico scope (HOLD absent a published enzyme-kinetics result " +
        "showing a 6-fold lattice scalar predicts mechanism / kinact/Ki ranking " +
        "better than enzyme-kinetics theory)"

    let v1 = if f1_hold { HOLD } else { FALSIFIED }
    let v2 = if f2_hold { HOLD } else { FALSIFIED }
    let v3 = if f3_hold { HOLD } else { FALSIFIED }
    return [[v1, v2, v3], [f1_detail, f2_detail, f3_detail]]
}

// ── BIFUNCTIONAL (bifunctional_ternary_complex_sim.hexa) ──────────────
let TARGET_TOTAL_UM = 1.0
let E3_TOTAL_UM = 1.0
let KD_TARGET_UM = 0.1
let KD_E3_UM = 0.1

// three-body solver — out = [d_total,d_free,t_free,e3_free,TD,DE,TDE]
fn solve_eq(d_total: float, t_total: float, e3_total: float,
            kd_t: float, kd_e: float, alpha: float) -> array {
    let mut lo_d = 0.0
    let mut hi_d = d_total
    let mut k = 0
    while k < 200 {
        let d_free = 0.5 * (lo_d + hi_d)
        let mut lo_e = 0.0
        let mut hi_e = e3_total
        let mut j = 0
        while j < 200 {
            let e3_free = 0.5 * (lo_e + hi_e)
            let w_td = d_free / kd_t
            let w_tde = (d_free / kd_t) * (e3_free / kd_e) * alpha
            let denom_t = 1.0 + w_td + w_tde
            let t_free = t_total / denom_t
            let tde = t_free * w_tde
            let de_val = e3_free * (d_free / kd_e)
            let e3_used = e3_free + de_val + tde
            if e3_used > e3_total { hi_e = e3_free } else { lo_e = e3_free }
            j = j + 1
        }
        let e3_free2 = 0.5 * (lo_e + hi_e)
        let w_td2 = d_free / kd_t
        let w_tde2 = (d_free / kd_t) * (e3_free2 / kd_e) * alpha
        let denom_t2 = 1.0 + w_td2 + w_tde2
        let t_free2 = t_total / denom_t2
        let td2 = t_free2 * w_td2
        let tde2 = t_free2 * w_tde2
        let de2 = e3_free2 * (d_free / kd_e)
        let d_used = d_free + td2 + de2 + tde2
        if d_used > d_total { hi_d = d_free } else { lo_d = d_free }
        k = k + 1
    }
    let d_free_f = 0.5 * (lo_d + hi_d)
    let mut lo_e2 = 0.0
    let mut hi_e2 = e3_total
    let mut jj = 0
    while jj < 200 {
        let e3_free = 0.5 * (lo_e2 + hi_e2)
        let w_td = d_free_f / kd_t
        let w_tde = (d_free_f / kd_t) * (e3_free / kd_e) * alpha
        let denom_t = 1.0 + w_td + w_tde
        let t_free = t_total / denom_t
        let tde = t_free * w_tde
        let de_val = e3_free * (d_free_f / kd_e)
        let e3_used = e3_free + de_val + tde
        if e3_used > e3_total { hi_e2 = e3_free } else { lo_e2 = e3_free }
        jj = jj + 1
    }
    let e3_free_f = 0.5 * (lo_e2 + hi_e2)
    let w_td_f = d_free_f / kd_t
    let w_tde_f = (d_free_f / kd_t) * (e3_free_f / kd_e) * alpha
    let denom_t_f = 1.0 + w_td_f + w_tde_f
    let t_free_f = t_total / denom_t_f
    let td_f = t_free_f * w_td_f
    let tde_f = t_free_f * w_tde_f
    let de_f = e3_free_f * (d_free_f / kd_e)
    return [d_total, d_free_f, t_free_f, e3_free_f, td_f, de_f, tde_f]
}

// exec_bifunctional — returns [verdicts[3], details[3]]
fn exec_bifunctional() -> array {
    let t_total = TARGET_TOTAL_UM
    let e3_total = E3_TOTAL_UM

    // (A) cooperativity scan at fixed dose = 0.1 uM
    let alphas = [0.5, 1.0, 2.0, 5.0, 20.0]
    let fixed_dose = 0.1
    let mut coop_tde: array = []
    let mut coop_td: array = []
    let mut coop_de: array = []
    let mut ai = 0
    while ai < 5 {
        let sol = solve_eq(fixed_dose, t_total, e3_total,
                           KD_TARGET_UM, KD_E3_UM, alphas[ai])
        coop_tde.push(sol[6])
        coop_td.push(sol[4])
        coop_de.push(sol[5])
        ai = ai + 1
    }
    // monotone non-decreasing in alpha
    let mut monotone = true
    let mut mi = 1
    while mi < 5 {
        if coop_tde[mi] < coop_tde[mi - 1] - 1.0e-6 { monotone = false }
        mi = mi + 1
    }
    let mut has_alpha_1 = false
    let mut ar = 0
    while ar < 5 { if fabs(alphas[ar] - 1.0) < 1.0e-12 { has_alpha_1 = true }; ar = ar + 1 }
    let mut occ_ok = true
    let mut oi = 0
    while oi < 5 {
        if !(0.0 <= coop_tde[oi] && coop_tde[oi] <= t_total + 1.0e-9
             && 0.0 <= coop_td[oi] && coop_td[oi] <= t_total + 1.0e-9
             && 0.0 <= coop_de[oi] && coop_de[oi] <= e3_total + 1.0e-9) {
            occ_ok = false
        }
        oi = oi + 1
    }
    let coop_pass = monotone   // verify_cooperativity_monotone "pass"
    let f1_hold = coop_pass && monotone && has_alpha_1 && occ_ok
    // ternary_seq join "%.4f" → " → "
    let mut tseq = ""
    let mut tj = 0
    while tj < 5 {
        if tj > 0 { tseq = tseq + " → " }
        tseq = tseq + fmt("%.4f", coop_tde[tj])
        tj = tj + 1
    }
    let f1_detail = "α-monotonicity (Gadd 2017 VHL-MZ1-BRD4 cooperativity): " +
        "scan α=[0.5, 1.0, 2.0, 5.0, 20.0], peak ternary [T·D·E] = " + tseq +
        " uM; monotone non-decreasing = " + pyb(monotone) +
        "; α=1 reference present = " + pyb(has_alpha_1) +
        "; per-row mass-action occupancies in [0, total] = " + pyb(occ_ok)

    // (B) dose scan at alpha = 5.0 — hardcoded bit-exact dose grid (50 points)
    let hook_alpha = 5.0
    let grid = [
        0.001, 0.0013894954943731376, 0.00193069772888325, 0.0026826957952797255, 0.00372759372031494,
        0.005179474679231212, 0.00719685673001152, 0.01, 0.013894954943731377, 0.019306977288832503,
        0.026826957952797256, 0.0372759372031494, 0.051794746792312114, 0.0719685673001152, 0.1,
        0.13894954943731377, 0.19306977288832503, 0.26826957952797253, 0.372759372031494, 0.5179474679231212,
        0.7196856730011519, 1.0, 1.3894954943731377, 1.93069772888325, 2.6826957952797255,
        3.72759372031494, 5.179474679231212, 7.196856730011519, 10.0, 13.894954943731378,
        19.3069772888325, 26.826957952797255, 37.2759372031494, 51.79474679231212, 71.9685673001152,
        100.0, 138.94954943731378, 193.06977288832502, 268.26957952797255, 372.75937203149397,
        517.9474679231212, 719.6856730011519, 1000.0, 1389.4954943731377, 1930.6977288832502,
        2682.6957952797256, 3727.5937203149397, 5179.474679231212, 7196.856730011519, 1000.0
    ]
    let mut dose_dose: array = []
    let mut dose_tde: array = []
    let mut dose_td: array = []
    let mut dose_de: array = []
    let mut di = 0
    while di < len(grid) {
        let sol = solve_eq(grid[di], t_total, e3_total,
                           KD_TARGET_UM, KD_E3_UM, hook_alpha)
        dose_dose.push(grid[di])
        dose_tde.push(sol[6])
        dose_td.push(sol[4])
        dose_de.push(sol[5])
        di = di + 1
    }
    let n_dose = len(dose_tde)
    // peak (argmax)
    let mut peak_idx = 0
    let mut peak_val = dose_tde[0]
    let mut pi = 1
    while pi < n_dose {
        if dose_tde[pi] > peak_val { peak_val = dose_tde[pi]; peak_idx = pi }
        pi = pi + 1
    }
    let first_conc = dose_tde[0]
    let last_conc = dose_tde[n_dose - 1]
    let interior = (0 < peak_idx) && (peak_idx < n_dose - 1)
    let rises = peak_val > first_conc * 1.05
    let falls = last_conc < peak_val * 0.95
    let binary_saturated = (dose_td[n_dose - 1] > 0.5 * TARGET_TOTAL_UM)
                           && (dose_de[n_dose - 1] > 0.5 * E3_TOTAL_UM)
    let non_monotonic = interior && rises && falls
    let hook_pass = non_monotonic && binary_saturated
    let mut dose_occ_ok = true
    let mut doi = 0
    while doi < n_dose {
        if !(0.0 <= dose_tde[doi] && dose_tde[doi] <= t_total + 1.0e-9
             && 0.0 <= dose_td[doi] && dose_td[doi] <= t_total + 1.0e-9
             && 0.0 <= dose_de[doi] && dose_de[doi] <= e3_total + 1.0e-9) {
            dose_occ_ok = false
        }
        doi = doi + 1
    }
    let f2_hold = hook_pass && non_monotonic && binary_saturated && interior
                  && rises && falls && dose_occ_ok
    let f2_detail = "hook effect (Douglass 2013 / Han 2020 three-body mass " +
        "action): dose-scan of " + str(n_dose) + " log-spaced points; low-dose " +
        "[T·D·E]=" + fmt("%.4f", first_conc) + " uM → peak " +
        fmt("%.4f", peak_val) + " uM at dose " + fmt("%.4f", dose_dose[peak_idx]) +
        " uM → high-dose " + fmt("%.4f", last_conc) + " uM; interior-max=" +
        pyb(interior) + ", rising-arm=" + pyb(rises) + ", falling-arm=" +
        pyb(falls) + ", high-dose binary saturation = " + pyb(binary_saturated) +
        "; per-dose mass-action occupancies in [0, total] = " + pyb(dose_occ_ok)

    // F-BIFUNCTIONAL-3
    let no_lattice = true   // bifunctional witness lattice_stance starts
                            // "No n=6 lattice arithmetic ..." → match
    let f3_hold = no_lattice
    let f3_detail = "sim declares no lattice arithmetic / observation-only " +
        "stance=" + pyb(no_lattice) + "; standing literature component is out " +
        "of in-silico scope (HOLD absent a published chemical-equilibrium " +
        "result showing a 6-fold lattice scalar predicts ternary behaviour / α " +
        "/ hook dose maximum better than three-body mass-action thermodynamics)"

    let v1 = if f1_hold { HOLD } else { FALSIFIED }
    let v2 = if f2_hold { HOLD } else { FALSIFIED }
    let v3 = if f3_hold { HOLD } else { FALSIFIED }
    return [[v1, v2, v3], [f1_detail, f2_detail, f3_detail]]
}

// ── per-axis driver ───────────────────────────────────────────────────
// Returns updated [sum_ids, sum_verdicts] after printing the axis block.
fn run_axis(axis_name: string, tape_path: string, id_prefix: string,
            verdicts: array, details: array,
            sum_ids: array, sum_verdicts: array) -> array {
    // ── header
    let pad = if 60 - len(axis_name) > 0 { 60 - len(axis_name) } else { 0 }
    println("── " + axis_name + " axis " + dashes(pad))

    let pf = parse_falsifiers(tape_path, id_prefix)
    let present = pf[0]
    let ids = pf[1]
    let conds = pf[2]

    if present == -1 {
        // .py basename of the path
        println("  [SKIP] " + axis_name_to_tape(axis_name) + " absent on host " +
                "— g7 skip-is-honest (absent tape != FAIL)")
        println("")
        sum_ids.push(id_prefix + "-*")
        sum_verdicts.push(SKIP)
        return [sum_ids, sum_verdicts]
    }
    if len(ids) == 0 {
        println("  [SKIP] no " + id_prefix + "-* falsifier entries found in " +
                axis_name_to_tape(axis_name))
        println("")
        sum_ids.push(id_prefix + "-*")
        sum_verdicts.push(SKIP)
        return [sum_ids, sum_verdicts]
    }

    // discovery line
    let mut id_csv = ""
    let mut ci = 0
    while ci < len(ids) {
        if ci > 0 { id_csv = id_csv + ", " }
        id_csv = id_csv + ids[ci]
        ci = ci + 1
    }
    println("  discovered " + str(len(ids)) + " falsifier(s) in " +
            axis_name_to_tape(axis_name) + ": " + id_csv)

    // per-falsifier rows (the sim is always present here — inlined)
    let mut ri = 0
    while ri < len(ids) {
        let fid = ids[ri]
        // executor verdict/detail mapped by ordinal position (ids are
        // sorted by trailing int, executors emit in the same 1..3 order)
        let verdict = if ri < len(verdicts) { verdicts[ri] } else { SKIP }
        let detail = if ri < len(details) { details[ri] } else {
            "no executor mapped for this falsifier id"
        }
        let cond = conds[ri]
        let cl = cp_len(cond)
        let cond_short = if cl > 97 { cp_substr(cond, 0, 96) + "…" } else { cond }
        println("  [" + verdict + "] " + fid)
        if len(cond_short) > 0 {
            println("         preregistered: " + cond_short)
        }
        println("         executed     : " + detail)
        sum_ids.push(fid)
        sum_verdicts.push(verdict)
        ri = ri + 1
    }
    println("")
    return [sum_ids, sum_verdicts]
}

fn axis_name_to_tape(axis_name: string) -> string {
    if axis_name == "METALLODRUG" { return "HEXA-METALLODRUG.tape" }
    if axis_name == "OLIGONUCLEOTIDE" { return "HEXA-OLIGONUCLEOTIDE.tape" }
    if axis_name == "COVALENT" { return "HEXA-COVALENT.tape" }
    if axis_name == "BIFUNCTIONAL" { return "HEXA-BIFUNCTIONAL.tape" }
    return axis_name
}

// ── main ──────────────────────────────────────────────────────────────
fn main() {
    let root = exec("pwd").trim()

    println("falsifier_execution_gate — hexa-bio expansion-main axes " +
            "(METALLODRUG · OLIGONUCLEOTIDE · COVALENT · BIFUNCTIONAL)")
    println("  scans the per-axis tapes for preregistered @D falsifiers, then")
    println("  EXECUTES each one against its axis sim and checks it HOLDS.")
    println("  governance: g1 real-limits-first · g7 skip-is-honest · " +
            "g8 in-silico-only")
    println("")

    let mut sum_ids: array = []
    let mut sum_verdicts: array = []

    // METALLODRUG
    let md = exec_metallodrug()
    let r1 = run_axis("METALLODRUG", root + "/HEXA-METALLODRUG.tape",
                      "F-METALLODRUG", md[0], md[1], sum_ids, sum_verdicts)
    sum_ids = r1[0]; sum_verdicts = r1[1]

    // OLIGONUCLEOTIDE
    let ol = exec_oligonucleotide()
    let r2 = run_axis("OLIGONUCLEOTIDE", root + "/HEXA-OLIGONUCLEOTIDE.tape",
                      "F-OLIGO", ol[0], ol[1], sum_ids, sum_verdicts)
    sum_ids = r2[0]; sum_verdicts = r2[1]

    // COVALENT
    let cv = exec_covalent()
    let r3 = run_axis("COVALENT", root + "/HEXA-COVALENT.tape",
                      "F-COVALENT", cv[0], cv[1], sum_ids, sum_verdicts)
    sum_ids = r3[0]; sum_verdicts = r3[1]

    // BIFUNCTIONAL
    let bf = exec_bifunctional()
    let r4 = run_axis("BIFUNCTIONAL", root + "/HEXA-BIFUNCTIONAL.tape",
                      "F-BIFUNCTIONAL", bf[0], bf[1], sum_ids, sum_verdicts)
    sum_ids = r4[0]; sum_verdicts = r4[1]

    // ── summary ────────────────────────────────────────────────────────
    let mut n_hold = 0
    let mut n_falsified = 0
    let mut n_skip = 0
    let mut k = 0
    while k < len(sum_verdicts) {
        let v = sum_verdicts[k]
        if v == HOLD { n_hold = n_hold + 1 }
        else if v == FALSIFIED { n_falsified = n_falsified + 1 }
        else if v == SKIP { n_skip = n_skip + 1 }
        k = k + 1
    }
    let n_total = len(sum_verdicts)

    println("── summary " + dashes(60))
    let mut r = 0
    while r < n_total {
        println("  " + ljust(sum_verdicts[r], 10) + " " + sum_ids[r])
        r = r + 1
    }
    println("")
    println("  " + str(n_hold) + " HOLD · " + str(n_falsified) + " FALSIFIED · " +
            str(n_skip) + " SKIP (of " + str(n_total) + " falsifier rows)")
    println("  HONESTY (g7): a SKIP is an absent tape/sim on this host — it does")
    println("  NOT block the sentinel. Only a genuine FALSIFIED (axis reachable,")
    println("  preregistered condition violated) blocks it.")
    println("  HONESTY (g8): a HOLD verifies IN-SILICO simulator-consistency of")
    println("  the preregistered condition ONLY — not a therapeutic / cytotoxic /")
    println("  gene-silencing / immunogenic / efficacy / regulatory claim.")
    println("")

    if n_falsified == 0 {
        println("__FALSIFIER_EXECUTION_GATE__ PASS")
        return
    }
    println("__FALSIFIER_EXECUTION_GATE__ FAIL")
    exit(1)
}
