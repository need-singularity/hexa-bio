fn cmd_ribozyme(args: [str]) {
    println("hexa-bio " + MODULE + " " + VERSION + " — RNA-catalyst primitive")
    println("")

    let mut mode = "skeleton"
    let mut t_end = "600"
    let mut audit_no_emit = false
    let mut audit_quiet = false
    let mut i = 0
    while i < args.len() {
        let a = args[i]
        if a == "--kinetics-mvp" { mode = "kinetics" }
        if a == "--c2-aml" { mode = "c2-aml" }
        if a == "--c2-scd" { mode = "c2-scd" }
        if a == "--c2-pancov" { mode = "c2-pancov" }
        if a == "--c2-senolytic" { mode = "c2-senolytic" }
        if a == "--bayesian-audit" { mode = "bayesian-audit" }
        if a == "--no-emit" { audit_no_emit = true }
        if a == "--quiet" { audit_quiet = true }
        if a == "--t-end" {
            if i + 1 < args.len() { t_end = args[i + 1] }
        }
        i = i + 1
    }

    if mode == "skeleton" {
        _print_status()
        println("")
        _print_n6_lattice()
        println("")
        _print_falsifiers()
        println("")
        println("usage: hexa-bio ribozyme [--kinetics-mvp [--t-end <seconds>]")
        println("                          | --c2-aml")
        println("                          | --bayesian-audit [--no-emit] [--quiet]]")
        println("[ribozyme] no action specified — printed lattice + falsifier table only")
        println("__HEXA_BIO_RIBOZYME__ PASS")
        return
    }

    if mode == "c2-aml" {
        println("--- C2 cell R·α (RIBOZYME × α=AML, FLT3-ITD targeted candidate) ---")
        run_c2_aml()
        println("")
        _print_n6_lattice()
        println("")
        println("__HEXA_BIO_RIBOZYME__ PASS")
        return
    }

    if mode == "c2-scd" {
        println("--- C2 cell R·β (RIBOZYME × β=SCD, HBB pre-mRNA candidate) ---")
        run_c2_scd()
        println("")
        println("__HEXA_BIO_RIBOZYME__ PASS")
        return
    }

    if mode == "c2-pancov" {
        println("--- C2 cell R·γ (RIBOZYME × γ=pancov) ---")
        run_c2_pancov()
        println("")
        println("__HEXA_BIO_RIBOZYME__ PASS")
        return
    }

    if mode == "c2-senolytic" {
        println("--- C2 cell R·δ (RIBOZYME × δ=senolytic) ---")
        run_c2_senolytic()
        println("")
        println("__HEXA_BIO_RIBOZYME__ PASS")
        return
    }

    if mode == "kinetics" {
        println("--- F-RB-4 kinetics MVP (hammerhead-minimal 12-nt 4-state, t_end=" + t_end + "s) ---")
        run_kinetics(t_end)
        println("")
        _print_n6_lattice()
        println("")
        println("__HEXA_BIO_RIBOZYME__ PASS")
        return
    }

    if mode == "bayesian-audit" {
        println("--- F-RB-2 Bayesian audit (n=30 catalytic-RNA primitives, C0c) ---")
        run_bayesian_audit(audit_no_emit, audit_quiet)
        println("")
        _print_n6_lattice()
        println("")
        println("__HEXA_BIO_RIBOZYME__ PASS")
    }
}

fn main() {
    let raw = args()
    let mut user: [str] = []
    let mut sidx = -1
    let mut i = 0
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut start = 1
    if sidx >= 0 { start = sidx + 1 }
    let mut k = start
    while k < raw.len() {
        user = user + [raw[k]]
        k = k + 1
    }
    cmd_ribozyme(user)
}
