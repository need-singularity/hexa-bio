{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/dancinlab/hexa-bio/case_studies/drug_redesign_sandbox/sandbox_v1.schema.json",
  "title": "Drug-redesign sandbox witness (v1) — SARS-CoV-2 Mpro / nirmatrelvir",
  "description": "In-silico simulator-consistency witness for the drug-redesign SANDBOX (one target = SARS-CoV-2 Mpro). The sandbox explores the modality SPACE around a SINGLE FDA-approved drug (nirmatrelvir / Paxlovid, Pfizer; FDA EUA 2022, full approval 2023) by running four axis sims against the same target. The artefact is an HONEST MODALITY-SPACE MAP, NOT a redesign recommendation, NOT a ranking, NOT a clinical claim, NOT an efficacy prediction. The ORIGINAL drug (nirmatrelvir) is the clinically-validated truth; the three ALTERNATIVE lenses (irreversible covalent, PROTAC, PPI) are illustrative research-pattern projections, each carrying `illustrative_only = true` and `not_a_redesign_recommendation = true`. Honesty constants are encoded as schema constants so the witness shape itself enforces the framing (g8 / f2 / g3 / f1). Echoes the A5 cross's `illustrative_only` caveat pattern.",
  "type": "object",
  "required": [
    "schema_version",
    "case_study_id",
    "ts",
    "target",
    "original_drug",
    "lenses",
    "honesty",
    "acceptance",
    "sentinel"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "drug_redesign_sandbox_v1"},
    "case_study_id":  {"type": "string", "const": "drug_redesign_sandbox.v1"},
    "ts":             {"type": "string", "minLength": 1},
    "target": {
      "type": "object",
      "required": ["name", "uniprot_class", "organism", "function"],
      "additionalProperties": true,
      "properties": {
        "name": {"type": "string", "const": "SARS-CoV-2 Mpro"},
        "uniprot_class": {"type": "string"},
        "organism": {"type": "string"},
        "function": {"type": "string"}
      }
    },
    "original_drug": {
      "type": "object",
      "required": [
        "drug", "brand", "sponsor", "fda_year", "fda_center",
        "modality", "is_clinically_validated", "drug_precedent_refs"
      ],
      "additionalProperties": true,
      "properties": {
        "drug":    {"type": "string", "const": "nirmatrelvir"},
        "brand":   {"type": "string"},
        "sponsor": {"type": "string"},
        "fda_year": {"type": "integer", "minimum": 1970, "maximum": 2100},
        "fda_center": {"type": "string", "const": "CDER"},
        "modality": {"type": "string"},
        "is_clinically_validated": {"const": true},
        "drug_precedent_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      }
    },
    "lenses": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/definitions/lens_row"}
    },
    "honesty": {
      "type": "object",
      "required": [
        "in_silico_only",
        "comparison_is_ranking",
        "not_a_redesign_recommendation",
        "original_drug_remains_the_clinical_truth",
        "all_alternative_lenses_illustrative",
        "no_fork_of_sister_sims",
        "no_lattice_derivation",
        "core_5_unchanged",
        "one_target_sandbox_not_200_disease_remap",
        "statement"
      ],
      "additionalProperties": true,
      "properties": {
        "in_silico_only":                            {"const": true},
        "comparison_is_ranking":                     {"const": false},
        "not_a_redesign_recommendation":             {"const": true},
        "original_drug_remains_the_clinical_truth":  {"const": true},
        "all_alternative_lenses_illustrative":       {"const": true},
        "no_fork_of_sister_sims":                    {"const": true},
        "no_lattice_derivation":                     {"const": true},
        "core_5_unchanged":                          {"const": true},
        "one_target_sandbox_not_200_disease_remap":  {"const": true},
        "statement": {"type": "string", "minLength": 1}
      }
    },
    "cross_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "module", "note"],
        "additionalProperties": true,
        "properties": {
          "id":     {"type": "string"},
          "module": {"type": "string"},
          "note":   {"type": "string"}
        }
      }
    },
    "acceptance": {
      "type": "object",
      "required": ["criteria", "pass_count", "total", "verdict"],
      "additionalProperties": true,
      "properties": {
        "verdict": {"type": "string", "enum": ["PASS", "FAIL"]}
      }
    },
    "sentinel": {
      "type": "string",
      "enum": ["__DRUG_REDESIGN_SANDBOX__ PASS", "__DRUG_REDESIGN_SANDBOX__ FAIL"]
    }
  },
  "definitions": {
    "lens_row": {
      "type": "object",
      "required": [
        "lens_id",
        "lens_name",
        "axis_mapping",
        "is_status_quo",
        "sim_module",
        "real_limit_anchor",
        "real_limit_citations",
        "modality_precedent_citations",
        "model_signature",
        "illustrative_only",
        "not_a_redesign_recommendation"
      ],
      "additionalProperties": true,
      "properties": {
        "lens_id":   {"type": "string", "enum": ["L1", "L2", "L3", "L4"]},
        "lens_name": {"type": "string", "minLength": 1},
        "axis_mapping": {
          "type": "object",
          "required": ["axis", "parent_axis", "axis_layer"],
          "additionalProperties": true,
          "properties": {
            "axis":        {"type": "string", "minLength": 1},
            "parent_axis": {"type": "string"},
            "axis_layer":  {"type": "string"}
          }
        },
        "is_status_quo":                {"type": "boolean"},
        "sim_module":                   {"type": "string", "minLength": 1},
        "real_limit_anchor":            {"type": "string", "minLength": 1},
        "real_limit_citations": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "modality_precedent_citations": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "model_signature":              {"type": "object"},
        "illustrative_only":            {"const": true},
        "not_a_redesign_recommendation":{"const": true}
      }
    }
  }
}
