{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/dancinlab/hexa-bio/case_studies/kras_g12c_portfolio/portfolio_v1.schema.json",
  "title": "KRAS-G12C portfolio case-study witness (v1)",
  "description": "In-silico simulator-consistency witness for the KRAS-G12C portfolio case study — a one-disease pilot composing two existing axis sims (COVALENT expansion-main + CRYPTIC-POCKET :> QUANTUM sub-axis) for two FDA-approved CDER drugs (sotorasib / Lumakras and adagrasib / Krazati — both acrylamide-warhead, Cys12-targeting, switch-II cryptic-pocket). The schema deliberately separates `in_scope_drugs` (axis-mapped CDER drugs) from `research_stage_negatives` (research-stage modalities): an honest portfolio acknowledges what it does NOT model. NEVER a therapeutic, clinical, oncology, efficacy, regulatory, or portfolio-recommendation claim (g8 / f2). NOT the deferred 200-disease re-mapping.",
  "type": "object",
  "required": [
    "schema_version",
    "case_study_id",
    "ts",
    "disease",
    "in_scope_drugs",
    "research_stage_negatives",
    "cross_axis_touch_points",
    "honesty",
    "acceptance",
    "sentinel"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "kras_g12c_portfolio_v1"},
    "case_study_id":  {"type": "string", "const": "kras_g12c_portfolio.v1"},
    "ts":             {"type": "string", "minLength": 1},
    "disease": {
      "type": "object",
      "required": ["name", "abbreviation"],
      "additionalProperties": true,
      "properties": {
        "name": {"type": "string"},
        "abbreviation": {"type": "string", "const": "KRAS-G12C"},
        "target_protein": {"type": "string"},
        "targeted_residue": {"type": "string"}
      }
    },
    "in_scope_drugs": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"$ref": "#/definitions/in_scope_drug"}
    },
    "research_stage_negatives": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/definitions/research_stage_negative"}
    },
    "cross_axis_touch_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "module", "note"],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string"},
          "module": {"type": "string"},
          "note": {"type": "string"}
        }
      }
    },
    "honesty": {
      "type": "object",
      "required": [
        "in_silico_only",
        "core_5_unchanged",
        "no_fork_of_sister_sims",
        "one_disease_pilot_not_200_disease_remap",
        "research_stage_negatives_listed_honestly",
        "no_lattice_derivation",
        "statement"
      ],
      "additionalProperties": true,
      "properties": {
        "in_silico_only": {"const": true},
        "core_5_unchanged": {"const": true},
        "no_fork_of_sister_sims": {"const": true},
        "one_disease_pilot_not_200_disease_remap": {"const": true},
        "research_stage_negatives_listed_honestly": {"const": true},
        "no_lattice_derivation": {"const": true},
        "statement": {"type": "string", "minLength": 1}
      }
    },
    "acceptance": {
      "type": "object",
      "required": ["criteria", "pass_count", "total", "verdict"],
      "additionalProperties": true,
      "properties": {
        "verdict": {"type": "string", "enum": ["PASS", "FAIL"]}
      }
    },
    "sentinel": {
      "type": "string",
      "enum": ["__KRAS_G12C_PORTFOLIO__ PASS", "__KRAS_G12C_PORTFOLIO__ FAIL"]
    }
  },
  "definitions": {
    "in_scope_drug": {
      "type": "object",
      "required": [
        "drug", "brand", "sponsor", "fda_year", "fda_center",
        "modality", "axis_mapping", "real_limit_anchor",
        "drug_precedent_refs", "sim_run", "in_silico_only"
      ],
      "additionalProperties": true,
      "properties": {
        "drug": {"type": "string", "minLength": 1},
        "brand": {"type": "string", "minLength": 1},
        "sponsor": {"type": "string", "minLength": 1},
        "fda_year": {"type": "integer", "minimum": 1970, "maximum": 2100},
        "fda_center": {"type": "string", "const": "CDER"},
        "fda_application": {"type": "string"},
        "modality": {"type": "string"},
        "axis_mapping": {
          "type": "object",
          "required": ["axis", "parent_axis", "axis_layer"],
          "additionalProperties": true,
          "properties": {
            "axis": {"type": "string", "const": "COVALENT"},
            "parent_axis": {"type": "string"},
            "axis_layer": {"type": "string"},
            "cryptic_touch_axis": {"type": "string"},
            "cryptic_touch_parent_axis": {"type": "string"},
            "cryptic_touch_axis_layer": {"type": "string"}
          }
        },
        "real_limit_anchor": {"type": "string", "minLength": 1},
        "drug_precedent_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "sim_run": {
          "type": "object",
          "required": ["covalent_step", "cryptic_pocket"],
          "additionalProperties": true,
          "properties": {
            "covalent_step": {"type": "object"},
            "cryptic_pocket": {"type": "object"}
          }
        },
        "in_silico_only": {"const": true}
      }
    },
    "research_stage_negative": {
      "type": "object",
      "required": [
        "candidate_class", "fda_approved", "status",
        "reason", "in_scope", "reported_not_run"
      ],
      "additionalProperties": true,
      "properties": {
        "candidate_class": {"type": "string"},
        "axis_in_repo": {"type": ["string", "null"]},
        "fda_approved": {"const": false},
        "fda_center_if_filed": {"type": "string"},
        "status": {"type": "string"},
        "reason": {"type": "string"},
        "in_scope": {"const": false},
        "reported_not_run": {"const": true},
        "unplaced_precedent_in_repo": {"type": "string"}
      }
    }
  }
}
