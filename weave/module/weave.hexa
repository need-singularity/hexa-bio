    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[weave] HEXA_BIO_WITH_NUMPY != 1 — C2 W·α candidate skipped")
        println("[weave] (set HEXA_BIO_WITH_NUMPY=1 to run weave_aml_modular_construct_candidate.py)")
        println("[weave] cached cycle-25 result (C2 cell W·α):")
        println("[weave]   surface markers (public AB DB catalogued): CD33, CD3")
        println("[weave]   topology: tandem-scFv 2-binding-module construct")
        println("[weave]   modules: anti_cd33_VH/VL + linker_GS_15 + anti_cd3_VH/VL (5 modules)")
        println("[weave]   verification: F-TP5-b weave_compose() PASS 6/6 (P=10, N=50, target=aml)")
        println("[weave]   in-silico-only — no clinical / therapeutic claim")
        return "skipped-no-opt-in"
    }
    let script = _python_path("weave_aml_modular_construct_candidate.py")
    if _file_exists(script) == false {
        eprintln("[weave] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let cmd = "python3 " + _shq(script) + " 2>&1"
    let raw = exec(cmd)
    println(raw.trim())
    return "ran"
}

