fn run_bayesian_audit() -> str {
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[weave] HEXA_BIO_WITH_NUMPY != 1 — Bayesian audit skipped")
        println("[weave] (set HEXA_BIO_WITH_NUMPY=1 to run polyhedral_cage_bayesian_audit.py)")
        println("[weave] cached corpus result (cycle 22):")
        println("[weave]   posterior(STRUCTURAL-EXACT) = 0.9668  (>= 0.95 RESOLVED)")
        println("[weave]   log Bayes factor H1/H0     = 3.37    (decisive per Jeffreys 1961)")
        println("[weave]   vertex==12 in CK subset    = 32/32   (σ(6)=12 base preservation 1.0000)")
        return "skipped-no-opt-in"
    }
    let script = _python_path("polyhedral_cage_bayesian_audit.py")
    if _file_exists(script) == false {
        eprintln("[weave] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let cmd = "python3 " + _shq(script) + " 2>&1"
    let raw = exec(cmd)
    println(raw.trim())
    return "ran"
}

fn cmd_weave(args: [str]) {
    println("hexa-bio " + MODULE + " " + VERSION + " — protein cage / polyhedral self-assembly")
    println("")

    let mut mode = "skeleton"
    let mut t_end = "1000"
    let mut compose_p = "10"
    let mut compose_n = "50"
    let mut compose_seed = "42"
    let mut compose_target = "aml"
    let mut i = 0
    while i < args.len() {
        let a = args[i]
        if a == "--cage-assembly" { mode = "cage-assembly" }
        if a == "--bayesian-audit" { mode = "bayesian-audit" }
        if a == "--compose" { mode = "compose" }
        if a == "--c2-aml" { mode = "c2-aml" }
        if a == "--c2-scd" { mode = "c2-scd" }
        if a == "--c2-pancov" { mode = "c2-pancov" }
        if a == "--c2-senolytic" { mode = "c2-senolytic" }
        if a == "--all" { mode = "all" }
        if a == "--t-end" {
            if i + 1 < args.len() { t_end = args[i + 1] }
        }
        if a == "--P" {
            if i + 1 < args.len() { compose_p = args[i + 1] }
        }
        if a == "--N" {
            if i + 1 < args.len() { compose_n = args[i + 1] }
        }
        if a == "--seed" {
            if i + 1 < args.len() { compose_seed = args[i + 1] }
        }
        if a == "--target" {
            if i + 1 < args.len() { compose_target = args[i + 1] }
        }
        i = i + 1
    }

    if mode == "skeleton" {
        println("usage: hexa-bio weave [--cage-assembly | --bayesian-audit | --compose | --all] [--t-end N] [--P N --N N --seed N --target {aml|scd|pancov|senolytic}]")
        println("")
        _print_n6_lattice()
        println("")
        _print_falsifiers()
        println("")
        println("[weave] no action specified — printed lattice + falsifier table only")
        println("[weave] for empirical paths, set HEXA_BIO_WITH_NUMPY=1 and re-run with --cage-assembly or --bayesian-audit")
        println("__HEXA_BIO_WEAVE__ PASS")
        return
    }

    let mut ran_assembly = ""
    let mut ran_audit = ""
    let mut ran_compose = ""
    if mode == "cage-assembly" || mode == "all" {
        println("--- cage-assembly ODE (4-state Zlotnick model, t-end=" + t_end + ") ---")
        ran_assembly = run_cage_assembly(t_end)
        println("")
    }
    if mode == "bayesian-audit" || mode == "all" {
        println("--- Bayesian audit (Caspar-Klug n=34 corpus + Beta(1,1) prior) ---")
        ran_audit = run_bayesian_audit()
        println("")
    }
    if mode == "compose" || mode == "all" {
        println("--- F-TP5-b weave_compose() MVP (P=" + compose_p + " N=" + compose_n + " seed=" + compose_seed + " target=" + compose_target + ") ---")
        ran_compose = run_compose(compose_p, compose_n, compose_seed, compose_target)
        println("")
    }
    if mode == "c2-aml" {
        println("--- C2 cell W·α (WEAVE × α=AML, modular construct candidate) ---")
        run_c2_aml()
        println("")
    }
    if mode == "c2-scd" {
        println("--- C2 cell W·β (WEAVE × β=SCD) ---")
        run_c2_scd()
        println("")
    }
    if mode == "c2-pancov" {
        println("--- C2 cell W·γ (WEAVE × γ=pancov) ---")
        run_c2_pancov()
        println("")
    }
    if mode == "c2-senolytic" {
        println("--- C2 cell W·δ (WEAVE × δ=senolytic) ---")
        run_c2_senolytic()
        println("")
    }

    _print_n6_lattice()
    println("")
    _print_falsifiers()
    println("")
    println("__HEXA_BIO_WEAVE__ PASS")
}

fn main() {
    let raw = args()
    let mut user: [str] = []
    let mut i = 0
    let mut sidx = -1
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut start = 1
    if sidx >= 0 { start = sidx + 1 }
    let mut k = start
    while k < raw.len() {
        user = user + [raw[k]]
        k = k + 1
    }
    cmd_weave(user)
}
