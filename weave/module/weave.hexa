#!hexa strict
// weave/module/weave.hexa — WEAVE verb (HEXA-family axis 1/4)
//
// Cage-assembly + polyhedral-cage Bayesian audit primitive.
// Imports from sister python_bridge_aux (raw#9 .own N opt-out for
// numpy/scipy heavy lifting; pure-hexa default uses python stdlib only).
//
// Provenance: extracted from nexus/sim_bridge/weave/ on 2026-05-04
//             (canonical-from cycle 24, 2026-04-29).
// Concept: n6-architecture/domains/biology/hexa-weave/hexa-weave.md
//          empirical companion. Caspar-Klug 1962 + Zlotnick 2003 polyhedral
//          protein cage self-assembly ODE + Bayesian σ(6)=12 STRUCTURAL-EXACT
//          audit. T=1 60-subunit icosahedral cage as reference target.
//
// HEXA-family role: composition (write-side multi-strand weave). The 4-sister
// tetrahedron is composition (weave) + actuation (nanobot) + catalysis
// (ribozyme) + assembly (virocapsid). Weave is the only axis with full
// numerical empirical sandbox at v1.0.0.
//
// Falsifiers (raw#71 preregister, carried forward from cycle 22):
//   F-CAGE-MVP-1     — yield 0.95 미달이 3 independent calibration
//                       (HBV/CCMV/STNV) 에서 reproducible → calibration gap
//                       확정 (deadline 2026-07-28).
//   F-VIROCAPSID-2   — live-PDB scrape n>=100 cages 에서 posterior >= 0.95
//                       재현 → STRUCTURAL-EXACT 입증 강화 (deadline 2027-04-28).
//   F-NEXUS-IMPORT-NUMPY — 외부 numpy/scipy 의존성 도입 시 raw#14 ext-ssot
//                       위반 → 거부 (deadline open-ended).
//   F-TP5-b          — 90-day MVP gate: end-to-end weave_compose() with
//                       P>=10 strand bundles x N>=50 trials. PASS via
//                       _python_bridge/module/weave_composition.py (cycle 24
//                       C0b deliverable; deadline 2026-07-28).
//
// n=6 invariant matching:
//   σ(6) = 12 STRUCTURAL-EXACT (cage vertex count, posterior 0.97 입증)
//   τ(6) = 4   4-state ladder (free CP / pentamer / hexamer / closed cage)
//   φ(6) = 2   free vs assembled dichotomy
//   J₂   = 24  octahedral O ⊂ icosahedral I subgroup
//   σ·φ = n·τ = 12·2 = 6·4 = 24 master identity.
//
// raw#10 honest C3:
//   - python stdlib only by default (HEXA_BIO_WITH_NUMPY=1 → numpy/scipy
//     opt-in for empirical-sandbox path).
//   - cage_assembly yield 0.68 plateau is calibration gap (k_close >= 5e-9
//     ODE stiffness; full F-CAGE-MVP-1 deferred to GPU-sandbox cycle 24+).
//   - vertex=12 invariant is geometric tautology (Euler V−E+F=2);
//     Bayesian audit proves textbook consistency, not independent refutation.

let VERSION = "1.0.0"
let MODULE  = "weave"

fn _root() -> str {
    let r = env("HEXA_BIO_ROOT")
    if r.len() > 0 { return r }
    // Layout (canonical 2026-05-05): <root>/weave/module/weave.hexa
    // → 3× dirname pops {weave.hexa, module/, weave/} to reach <root>.
    let inferred = exec("dirname \"$(dirname \"$(dirname \"$0\")\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return env("HOME") + "/.hexa-bio"  // @allow-devpath
}

fn _shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _python_path(script: str) -> str {
    let root = _root()
    return root + "/_python_bridge/module/" + script
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + _shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _print_n6_lattice() {
    println("  n=6 invariant binding (weave):")
    println("    σ(6) = 12  STRUCTURAL-EXACT (cage vertex count, posterior 0.97)")
    println("    τ(6) = 4   4-state ladder (free / pentamer / hexamer / cage)")
    println("    φ(6) = 2   free vs assembled dichotomy")
    println("    J₂   = 24  octahedral O ⊂ icosahedral I subgroup")
    println("    identity: σ·φ = n·τ = 12·2 = 6·4 = 24")
}

fn _print_falsifiers() {
    println("  falsifiers (raw#71 preregister):")
    println("    F-CAGE-MVP-1            yield ≥ 0.95 across 3 calibrations  (deadline 2026-07-28)")
    println("    F-VIROCAPSID-2-LIVE-PDB live-PDB n≥100 posterior ≥ 0.95     (deadline 2027-04-28)")
    println("    F-NEXUS-IMPORT-NUMPY    no numpy/scipy w/o opt-in flag      (deadline open-ended)")
    println("    F-TP5-b                 weave_compose() P≥10 N≥50 MVP run  (deadline 2026-07-28, C0b)")
}

fn run_cage_assembly(t_end: str) -> str {
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[weave] HEXA_BIO_WITH_NUMPY != 1 — empirical sandbox skipped")
        println("[weave] (set HEXA_BIO_WITH_NUMPY=1 to run cage_assembly_simulation.py)")
        println("[weave] pure-hexa skeleton: 4-state ladder { free, pentamer, hexamer, cage }")
        return "skipped-no-opt-in"
    }
    let script = _python_path("cage_assembly_simulation.py")
    if _file_exists(script) == false {
        eprintln("[weave] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let cmd = "python3 " + _shq(script) + " --t-end " + _shq(t_end) + " 2>&1"
    let raw = exec(cmd)
    println(raw.trim())
    return "ran"
}

fn run_compose(p_str: str, n_str: str, seed_str: str, target: str) -> str {
    // F-TP5-b 90d MVP weave_compose() runner (C0b). Opt-in gated like
    // run_cage_assembly: HEXA_BIO_WITH_NUMPY=1 enables Python bridge.
    // Composition script is stdlib-only (no numpy/scipy/networkx) but the
    // env flag is the canonical signal that local python3 is available —
    // it skips the Python path under docker hard-landing.
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[weave] HEXA_BIO_WITH_NUMPY != 1 — weave_compose() skipped")
        println("[weave] (set HEXA_BIO_WITH_NUMPY=1 to run weave_composition.py)")
        println("[weave] cached F-TP5-b result (cycle 24, P=10 N=50):")
        println("[weave]   target: W-alpha (AML) — 12-strand built-in catalogue")
        println("[weave]   trials run = 500 (10 bundles x 50 trials)")
        println("[weave]   landauer pass:           500/500  (1e6 kT budget)")
        println("[weave]   pi_p2 pass:              500/500  (k=4 jaccard < 0.5)")
        println("[weave]   bundles with >=1 landauer pass: 10/10")
        println("[weave]   bundles with >=1 pi_p2 pass:    10/10")
        println("[weave]   PASS 6/6 (n6 invariant / P>=10 / N>=50 / per-bundle landauer /")
        println("[weave]            per-bundle pi_p2 / registry rows == P*N + 1)")
        return "skipped-no-opt-in"
    }
    let script = _python_path("weave_composition.py")
    if _file_exists(script) == false {
        eprintln("[weave] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let cmd = ("python3 " + _shq(script)
               + " --P " + _shq(p_str)
               + " --N " + _shq(n_str)
               + " --seed " + _shq(seed_str)
               + " --target " + _shq(target)
               + " 2>&1")
    let raw = exec(cmd)
    println(raw.trim())
    return "ran"
}

