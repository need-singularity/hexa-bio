{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/weave/spec/weave_compose_row_v1.schema.json",
  "title": "raw_77_weave_compose_v1 wrapper row schema (trial OR aggregate)",
  "description": "Wrapper schema for the raw_77_weave_compose_v1 rows emitted by _python_bridge/module/weave_composition.py. row_kind discriminates between 'trial' (per-bundle×trial witness) and 'aggregate' (per-run summary). Optional composition_output field landed iter-24 (post-cycle-24 emits will carry it; pre-cycle-25 7014 rows do not).",
  "type": "object",
  "required": [
    "schema",
    "ts",
    "cycle",
    "phase",
    "domain",
    "falsifier",
    "run_id",
    "row_kind",
    "n6_invariant",
    "pass_evaluation",
    "raw_77_append_only"
  ],
  "properties": {
    "schema": {"type": "string", "const": "raw_77_weave_compose_v1"},
    "ts": {"type": "string", "format": "date-time"},
    "cycle": {"type": "integer", "minimum": 1},
    "phase": {"type": "string"},
    "domain": {"type": "string"},
    "falsifier": {"type": "string"},
    "run_id": {"type": "string"},
    "row_kind": {"type": "string", "enum": ["trial", "aggregate"]},
    "n6_invariant": {"type": "object"},
    "pass_evaluation": {"type": "object"},
    "raw_77_append_only": {"type": "boolean"},

    "bundle_idx": {"type": "integer", "minimum": 0},
    "trial_idx": {"type": "integer", "minimum": 0},
    "n_strands_in_bundle": {"type": "integer", "minimum": 0},
    "strand_ids": {"type": "array"},
    "target_context": {"type": "object"},
    "landauer_gate": {"type": "object"},
    "pi_p2_verifier": {"type": "object"},
    "inverse_search": {"type": "object"},
    "metrics": {"type": "object"},
    "composition_output": {"type": "object"},
    "composition_output_schema_validated": {"type": "boolean"},

    "config": {"type": "object"},
    "totals": {"type": "object"},
    "elapsed_seconds": {"type": "number", "minimum": 0},

    "raw_138_sentinel": {"type": "string"},
    "raw_91_c3_disclose": {"type": "string"},
    "raw_9_hexa_only": {"type": "string"},
    "raw_47_cross_repo": {"type": "string"}
  }
}
