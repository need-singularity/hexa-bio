#!/usr/bin/env tape
# ══════════════════════════════════════════════════════════════════════
# .tape v1.2 — grammar primer (cold-read by any LLM / agent / human)
# ══════════════════════════════════════════════════════════════════════
# Form: each entry is `@<type> <id> := "<subject>" :: <kind> [<grades>]`
#       optionally followed by body lines (2-space indent) — key=value,
#       edges (<- -> => …), or quoted prose.
#
# ENTRY TYPES (17):
#   Runtime (10): @S session  @U user  @A assistant  @T tool-call  @R result
#                 @H hook  @D decision  @K cost  @P provider  @? anomaly
#   Foundation:   @I identity-claim
#   Declarative:  @X external-citation  @F forbidden-pattern  @N note
#                 @C config  @L layout  @V spec-version
#
# EDGES (12, on body lines, 2-space indent):
#   Causal:     <- caused-by   -> triggers   == continues
#               ~> supersedes  !! aborts     |> verified-by
#   Effect:     => produces (followed by quoted natural-language)
#   Structural: <: specializes  :> generalizes  ?> soft-depends
#               !> conflicts-with  @> projects-to (e.g. @> AGENTS.md)
#
# GRADE TAGS (in [...] on entry header):
#   Delivery:   ok · err · denied · cancelled · partial · superseded
#   Governance: required · recommended · optional · draft · active · deprecated
#   Scoped:     allow:<x> · deny:<x>
#   Time/index: T<n> (turn)  N<n> (wall-sec)  d=<YYYY-MM-DD>
#
# PAYLOAD SYNTAX (body lines):
#   key = "value"           single-line string
#   key = [a, b, c]         array literal
#   key <<~EOF              heredoc (multi-line; ends with EOF on own line)
#     multi-line text
#   EOF
#   "see [@x1] §3"          inline citation by entry id
#   `cmd or path`           backtick code-span (inline only)
#
# Full spec: ~/core/tape/spec/tape.md (or github.com/dancinlab/tape)
# ══════════════════════════════════════════════════════════════════════


# ══════════════════════════════════════════════════════════════
# DOLPHIN.log.tape — append-only event history (v1.2 split)
# Sibling: DOLPHIN.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite_real_science := "DOLPHIN.tape rewritten — lattice-tautology stub → real cetacean science SSOT" :: rewrite [ok d=2026-05-16]
  origin = "DOLPHIN.tape was a lattice-tautology stub (hexa-bio mass-split 153b5a2): ~380 lines of `@D row_*` entries mapping Korean-labeled columns to σ/τ/φ/J₂/n=6 values with no biological content and no real citations. Every 'sonar resolution', 'frequency band', 'BCI channel' entry was derived from lattice arithmetic — a governance violation of @F f1 (AGENTS.tape) and @D g1/g2 (real-limits-first / lattice-is-tool)."
  rewrite-scope = "Full replacement from @I id001 onward. Preserved: top grammar primer, @V spec entry, banner comment, sibling-log reference. Deleted: all lattice-tautology @D row_* / @D b_* content. Added: real cetacean biology across 11 sections (~260 lines)."
  content-added = "§1 Taxonomy (Thewissen fossil series · Odontoceti/Mysticeti split · Delphinidae ~36 spp.); §2 Anatomy (fusiform body, horizontal flukes, blowhole, melon, dorsal fin, blubber); §3 Echolocation (40–150 kHz clicks · mandibular fat pad reception · range estimation; Au textbook); §4 Cognition (MSR: Reiss & Marino 2001 PNAS 98:5937-5942; signature whistles: Janik & Sayigh 2013 J Comp Physiol A 199:479-489; fission-fusion societies; orca matrilines; cultural transmission: Krützen et al 2005 PNAS 102:8939-8943); §5 Sleep (USWS: Lyamin et al 2008 Neurosci Biobehav Rev 32:1451-1484); §6 Conservation (Maui dolphin/vaquita IUCN; bycatch; ship strike; PCB pollution: Jepson et al 2016 Sci Rep 6:18573); §7 Real-limits (anthropomorphism floor · captive-vs-wild generalization · genetic bottleneck · chronic noise); §8 Lattice stance (@F f_lattice_fit + @N n6_honest_stance); §9 Predictions (3 falsifiable @D tp_*); §10–11 Cross-links + citations (9 @X :: literature entries)."
  n6-stance = "Declined as a derivation tool. @N n6_honest_stance + @F f_lattice_fit state plainly: cetacean biology has no natural n=6 invariant. Delphinidae species count, echolocation frequency range, population sizes, and all biological quantities are empirical measurements / IUCN estimates — not lattice-derived. This honesty IS the corrective for the audited lattice-tautology violation."
  citations = "Confident (full bibliographic): Reiss & Marino 2001 PNAS · Krützen et al 2005 PNAS · Janik & Sayigh 2013 J Comp Physiol A · Lyamin et al 2008 Neurosci Biobehav Rev · Jepson et al 2016 Sci Rep. Author/era-flagged (intentionally uncertain): Thewissen cetacean fossil series (~1994–2007, multiple papers) · Au 'The Sonar of Dolphins' textbook (~1993) · Janik 2009 chapter. Institutional: IUCN Red List (Cetacean Specialist Group, species-specific assessments)."
  lint = "python3 selftest/tape_lattice_honesty_lint.py /Users/ghost/core/hexa-bio/DOLPHIN.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true; 2 deriv_warnings = tolerated provenance lines in honest-stance body quoting forbidden phrasing, not live derivation claims)."
  governance = "Complies with hexa-bio AGENTS.tape @D g1 (real-limits-first) · @D g2 (lattice-is-tool) · @D g8 (in-silico-only-claim-scope) · @F f1 (lattice-fit-on-external-entity). Clinical/conservation disclaimer (@N scope_disclaimer) added — knowledge SSOT, not veterinary or conservation-management prescription."
