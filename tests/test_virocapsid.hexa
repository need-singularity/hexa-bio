#!hexa strict
// tests/test_virocapsid.hexa — VIROCAPSID stub smoke test
//
// Pass criterion: __HEXA_BIO_VIROCAPSID__ PASS sentinel present.
// Cost: $0 (stub module; T=1 sub-axis grounded via weave).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "virocapsid/module/virocapsid.hexa"
    if root.len() > 0 { p = root + "/virocapsid/module/virocapsid.hexa" }

    let raw = exec("hexa run " + p + " 2>&1")
    if raw.contains("__HEXA_BIO_VIROCAPSID__ PASS") {
        println("test_virocapsid: PASS")
        return
    }
    println("test_virocapsid: FAIL")
    println(raw.trim())
    exit(1)
}
