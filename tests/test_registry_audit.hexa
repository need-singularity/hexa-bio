#!hexa strict
// tests/test_registry_audit.hexa — registry integrity auditor smoke test.
//
// Runs the python3 audit utility in --no-emit mode (so the test is itself
// non-mutating against the registry) and asserts the __REGISTRY_AUDIT__
// PASS sentinel appears in stdout, indicating all 7 integrity checks
// passed against the current registry snapshot.
//
// Pass criterion:
//   __REGISTRY_AUDIT__ PASS sentinel present.
//
// Cost: $0 (pure stdlib python3, < 1s wall-clock against the 500-row
// registry).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut script = "_python_bridge/module/audit_registry_integrity.py"
    if root.len() > 0 {
        script = root + "/_python_bridge/module/audit_registry_integrity.py"
    }

    let raw = exec("python3 " + script + " --no-emit --quiet 2>&1")

    if raw.contains("__REGISTRY_AUDIT__ PASS") {
        println("test_registry_audit: PASS")
        return
    }
    println("test_registry_audit: FAIL")
    println(raw.trim())
    exit(1)
}
