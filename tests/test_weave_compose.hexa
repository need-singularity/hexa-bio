#!hexa strict
// tests/test_weave_compose.hexa — WEAVE F-TP5-b C0b weave_compose() smoke test.
//
// Pass criterion (stub-skip path, no HEXA_BIO_WITH_NUMPY):
//   __HEXA_BIO_WEAVE__ PASS sentinel present after --compose dispatch
//   (cached result printed; Python bridge not invoked).
//
// Pass criterion (full path, HEXA_BIO_WITH_NUMPY=1):
//   BOTH sentinels present:
//     __WEAVE_MVP_RESULT__ PASS  (6/6 deterministic gates from
//                                 weave_composition.py)
//     __HEXA_BIO_WEAVE__ PASS    (verb dispatcher closure)
//
// Cost: $0 (pure stdlib python3, ~0.3s wall-clock at default P=10 N=50).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "weave/module/weave.hexa"
    if root.len() > 0 { p = root + "/weave/module/weave.hexa" }

    let raw = exec("hexa run " + p + " --compose --P 10 --N 50 --seed 42 --target aml 2>&1")

    let module_ok = raw.contains("__HEXA_BIO_WEAVE__ PASS")

    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy == "1" {
        // Full compose path: require BOTH sentinels.
        let compose_ok = raw.contains("__WEAVE_MVP_RESULT__ PASS")
        if module_ok && compose_ok {
            println("test_weave_compose: PASS (full compose path, 6/6)")
            return
        }
        println("test_weave_compose: FAIL (full compose path)")
        println(raw.trim())
        exit(1)
    }

    // Stub-skip path: only WEAVE module sentinel required.
    if module_ok {
        println("test_weave_compose: PASS (stub-skip path; set HEXA_BIO_WITH_NUMPY=1 for full compose)")
        return
    }
    println("test_weave_compose: FAIL")
    println(raw.trim())
    exit(1)
}
