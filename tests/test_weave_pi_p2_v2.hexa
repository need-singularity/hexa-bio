#!hexa strict
// tests/test_weave_pi_p2_v2.hexa — WEAVE F-CYCLE24-WEAVE-PI-P2-1 verifier v2 smoke test.
//
// Pass criterion (full path, HEXA_BIO_WITH_NUMPY=1 OR python3 available):
//   __WEAVE_PI_P2_V2__ PASS sentinel present after running
//   _python_bridge/module/weave_pi_p2_verifier_v2.py --benchmark
//   on the built-in 12-strand catalogue with default {k=5, edit=4}.
//
// Pass criterion (stub-skip path):
//   skipped marker present (no python3 available).
//
// Cost: $0 (pure stdlib python3, ~0.05s wall-clock at default bundle_size=5).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut bridge = "_python_bridge/module/weave_pi_p2_verifier_v2.py"
    if root.len() > 0 { bridge = root + "/_python_bridge/module/weave_pi_p2_verifier_v2.py" }

    let cmd = "python3 " + bridge + " --bundle-size 5 --k-offtargets 5 --edit-threshold 4 --benchmark --no-emit 2>&1"
    let raw = exec(cmd)

    let v2_ok = raw.contains("__WEAVE_PI_P2_V2__ PASS")
    let no_regression = raw.contains("v2 regressions:         0/")

    if v2_ok && no_regression {
        println("test_weave_pi_p2_v2: PASS")
        return
    }
    println("test_weave_pi_p2_v2: FAIL")
    println(raw.trim())
    exit(1)
}
