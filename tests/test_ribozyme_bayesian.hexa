#!hexa strict
// tests/test_ribozyme_bayesian.hexa — RIBOZYME F-RB-2 C0c Bayesian audit
// smoke test (n=30 catalytic-RNA architectural-primitive corpus).
//
// Pass criterion (stub-skip path, no HEXA_BIO_WITH_NUMPY):
//   __HEXA_BIO_RIBOZYME__ PASS sentinel present after --bayesian-audit
//   --no-emit --quiet dispatch (cached log_bf summary printed).
//
// Pass criterion (full path, HEXA_BIO_WITH_NUMPY=1):
//   __RB_BAYESIAN_AUDIT__ PASS sentinel present (log_bf >= 3 against
//   the H0 random-per-axis baseline).
//
// Cost: $0 (pure stdlib python3, < 1s wall-clock).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "ribozyme/module/ribozyme.hexa"
    if root.len() > 0 { p = root + "/ribozyme/module/ribozyme.hexa" }

    let raw = exec("hexa run " + p + " --bayesian-audit --no-emit --quiet 2>&1")

    let module_ok = raw.contains("__HEXA_BIO_RIBOZYME__ PASS")

    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy == "1" {
        let audit_ok = raw.contains("__RB_BAYESIAN_AUDIT__ PASS")
        if module_ok && audit_ok {
            println("test_ribozyme_bayesian: PASS (full audit path, log_bf >= 3)")
            return
        }
        println("test_ribozyme_bayesian: FAIL (full audit path)")
        println(raw.trim())
        exit(1)
    }

    if module_ok {
        println("test_ribozyme_bayesian: PASS (stub-skip path; set HEXA_BIO_WITH_NUMPY=1 for full audit)")
        return
    }
    println("test_ribozyme_bayesian: FAIL")
    println(raw.trim())
    exit(1)
}
