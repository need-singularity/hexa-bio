#!hexa strict
// tests/test_virocapsid_multi_t.hexa — V-R2 stretch multi-T smoke test
//
// Pass criterion: __HEXA_BIO_VIROCAPSID__ PASS sentinel present in
//                 `virocapsid --multi-t` output. When HEXA_BIO_WITH_NUMPY=1
//                 the python bridge runs and the inner script must also
//                 emit __VIROCAPSID_MULTI_T__ PASS (T=3 yield ≥ 0.85 AND
//                 T=4 yield ≥ 0.85). When HEXA_BIO_WITH_NUMPY != 1 the
//                 dispatcher prints cached cycle-25 result and the verb-
//                 level sentinel still PASS-es.
//
// Cost: $0 (stdlib python; ~70-80s when HEXA_BIO_WITH_NUMPY=1).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "virocapsid/module/virocapsid.hexa"
    if root.len() > 0 { p = root + "/virocapsid/module/virocapsid.hexa" }

    let raw = exec("hexa run " + p + " --multi-t --t-number all 2>&1")

    if raw.contains("__HEXA_BIO_VIROCAPSID__ PASS") == false {
        println("test_virocapsid_multi_t: FAIL (verb sentinel missing)")
        println(raw.trim())
        exit(1)
    }

    // If python bridge gate is on, also assert the inner script PASS.
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy == "1" {
        if raw.contains("__VIROCAPSID_MULTI_T__ PASS") == false {
            println("test_virocapsid_multi_t: FAIL (multi-t sentinel missing under HEXA_BIO_WITH_NUMPY=1)")
            println(raw.trim())
            exit(1)
        }
    }

    println("test_virocapsid_multi_t: PASS")
}
