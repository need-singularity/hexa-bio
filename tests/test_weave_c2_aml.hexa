#!hexa strict
// tests/test_weave_c2_aml.hexa — C2 cell W·α (WEAVE × α=AML) smoke test
//
// Two-path mirror of test_weave_compose.hexa:
//   - Without HEXA_BIO_WITH_NUMPY=1: stub-skip path, expects cached print + sentinel.
//   - With HEXA_BIO_WITH_NUMPY=1: full modular construct candidate verification
//     via F-TP5-b weave_compose pipeline; expects __W_ALPHA_AML_C2__ PASS.
//
// Pass criterion: __HEXA_BIO_WEAVE__ PASS sentinel always present;
// when env opt-in, __W_ALPHA_AML_C2__ PASS sentinel additionally present.

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "weave/module/weave.hexa"
    if root.len() > 0 { p = root + "/weave/module/weave.hexa" }

    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    let raw = exec("hexa run " + p + " --c2-aml 2>&1")

    if raw.contains("__HEXA_BIO_WEAVE__ PASS") == false {
        println("test_weave_c2_aml: FAIL (skeleton sentinel missing)")
        println(raw.trim())
        exit(1)
    }

    if with_numpy == "1" {
        if raw.contains("__W_ALPHA_AML_C2__ PASS") {
            println("test_weave_c2_aml: PASS (full candidate path)")
            return
        }
        println("test_weave_c2_aml: FAIL (candidate sentinel missing under opt-in)")
        println(raw.trim())
        exit(1)
    }

    if raw.contains("CD33") {
        println("test_weave_c2_aml: PASS (stub-skip path; set HEXA_BIO_WITH_NUMPY=1 for full candidate)")
        return
    }
    println("test_weave_c2_aml: FAIL (cached print missing)")
    println(raw.trim())
    exit(1)
}
