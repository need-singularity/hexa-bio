#!hexa strict
// tests/test_quantum.hexa — QUANTUM axis smoke test
//
// Pass criterion: __HEXA_BIO_QUANTUM__ PASS sentinel present in
// `hexa run quantum/module/quantum.hexa status` stdout.
//
// Cost: $0 (axis dispatcher; no external system invocation; no qmirror
// cli round-trip; only string concatenation and stdout).
//
// What this does NOT test:
//   - Phase 1 / B1 / B2 / B3 / B4 numerical results — those are tested by
//     `_python_bridge/module/quantum_*.py --selftest` runs (Python-side,
//     port to hexa native is happening in a separate session per user
//     directive 2026-05-07).
//   - Pilot smokes (Boltz-2 / ProteinMPNN / RhoFold+ / chain) — those
//     require their respective installs and are validated by
//     `quantum/module/external_pilot_runner.hexa` (see test_pilot_runner
//     placeholder below if added in future cycles).
//   - n=6 invariant binding numerics — printed in status but no
//     numerical assertion here. Numerics are covered in the .roadmap.quantum
//     witness rows under registry.jsonl.

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "quantum/module/quantum.hexa"
    if root.len() > 0 { p = root + "/quantum/module/quantum.hexa" }

    let raw = exec("hexa run " + p + " status 2>&1")
    if raw.contains("__HEXA_BIO_QUANTUM__ PASS") {
        println("test_quantum: PASS")
        return
    }
    println("test_quantum: FAIL")
    println(raw.trim())
    exit(1)
}
