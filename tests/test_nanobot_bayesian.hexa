#!hexa strict
// tests/test_nanobot_bayesian.hexa — NANOBOT F-NB-2 Bayesian audit smoke
// test (C0c per .roadmap.nanobot, deadline 2026-09-28).
//
// Pass criterion (stub-skip path, no HEXA_BIO_WITH_NUMPY):
//   __HEXA_BIO_NANOBOT__ PASS sentinel after --bayesian-audit dispatch.
//
// Pass criterion (full path, HEXA_BIO_WITH_NUMPY=1):
//   __NB_BAYESIAN_AUDIT__ {PASS|MARGINAL|FAIL} sentinel present (audit
//   ran to completion). Honest verdict reported per spec — sub-threshold
//   FAIL is acceptable (STRUCTURAL-APPROXIMATE remains).
//
// Cost: $0 (pure stdlib python3, ~10ms wall-clock — closed-form Beta-Binomial
//       Bayes factor with regularized incomplete-beta via Lentz CF).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "nanobot/module/nanobot.hexa"
    if root.len() > 0 { p = root + "/nanobot/module/nanobot.hexa" }

    let raw = exec("hexa run " + p + " --bayesian-audit --no-emit 2>&1")

    let module_ok = raw.contains("__HEXA_BIO_NANOBOT__ PASS")

    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy == "1" {
        // Full audit path: require BOTH the module sentinel AND the audit
        // sentinel (any of PASS / MARGINAL / FAIL — honest verdict).
        let audit_ran = (raw.contains("__NB_BAYESIAN_AUDIT__ PASS")
                        || raw.contains("__NB_BAYESIAN_AUDIT__ MARGINAL")
                        || raw.contains("__NB_BAYESIAN_AUDIT__ FAIL"))
        if module_ok && audit_ran {
            println("test_nanobot_bayesian: PASS (full audit path; honest verdict reported)")
            return
        }
        println("test_nanobot_bayesian: FAIL (full audit path)")
        println(raw.trim())
        exit(1)
    }

    // Stub-skip path: only HEXA module sentinel required.
    if module_ok {
        println("test_nanobot_bayesian: PASS (stub-skip path; set HEXA_BIO_WITH_NUMPY=1 for full audit)")
        return
    }
    println("test_nanobot_bayesian: FAIL")
    println(raw.trim())
    exit(1)
}
