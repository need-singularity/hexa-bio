#!hexa strict
// tests/test_weave.hexa — WEAVE module smoke test
//
// Pass criterion: __HEXA_BIO_WEAVE__ PASS sentinel present.
// Cost: $0 (no opt-in flag — pure-hexa skeleton path).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "weave/module/weave.hexa"
    if root.len() > 0 { p = root + "/weave/module/weave.hexa" }

    let raw = exec("hexa run " + p + " 2>&1")
    if raw.contains("__HEXA_BIO_WEAVE__ PASS") {
        println("test_weave: PASS")
        return
    }
    println("test_weave: FAIL")
    println(raw.trim())
    exit(1)
}
