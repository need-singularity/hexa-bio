#!hexa strict
// tests/test_nanobot.hexa — NANOBOT stub smoke test
//
// Pass criterion: __HEXA_BIO_NANOBOT__ PASS sentinel present.
// Cost: $0 (stub module).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "modules/nanobot.hexa"
    if root.len() > 0 { p = root + "/modules/nanobot.hexa" }

    let raw = exec("hexa run " + p + " 2>&1")
    if raw.contains("__HEXA_BIO_NANOBOT__ PASS") {
        println("test_nanobot: PASS")
        return
    }
    println("test_nanobot: FAIL")
    println(raw.trim())
    exit(1)
}
