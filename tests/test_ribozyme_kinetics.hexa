#!hexa strict
// tests/test_ribozyme_kinetics.hexa — RIBOZYME F-RB-4 C0b kinetics MVP smoke test.
//
// Pass criterion (stub-skip path, no HEXA_BIO_WITH_NUMPY):
//   __HEXA_BIO_RIBOZYME__ PASS sentinel present after --kinetics-mvp dispatch.
//
// Pass criterion (full path, HEXA_BIO_WITH_NUMPY=1):
//   __RIBOZYME_MVP_RESULT__ PASS sentinel present (6/6 deterministic
//   criteria from ribozyme_kinetics_simulation.py).
//
// Cost: $0 (pure stdlib python3, ~2s wall-clock for default t_end=600s).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "ribozyme/module/ribozyme.hexa"
    if root.len() > 0 { p = root + "/ribozyme/module/ribozyme.hexa" }

    let raw = exec("hexa run " + p + " --kinetics-mvp --t-end 10 2>&1")

    let module_ok = raw.contains("__HEXA_BIO_RIBOZYME__ PASS")

    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy == "1" {
        // Full kinetics path: require BOTH sentinels.
        let kinetics_ok = raw.contains("__RIBOZYME_MVP_RESULT__ PASS")
        if module_ok && kinetics_ok {
            println("test_ribozyme_kinetics: PASS (full kinetics path, 6/6)")
            return
        }
        println("test_ribozyme_kinetics: FAIL (full kinetics path)")
        println(raw.trim())
        exit(1)
    }

    // Stub-skip path: only HEXA module sentinel required.
    if module_ok {
        println("test_ribozyme_kinetics: PASS (stub-skip path; set HEXA_BIO_WITH_NUMPY=1 for full kinetics)")
        return
    }
    println("test_ribozyme_kinetics: FAIL")
    println(raw.trim())
    exit(1)
}
