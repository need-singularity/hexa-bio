#!hexa strict
// tests/test_ribozyme.hexa — RIBOZYME stub smoke test
//
// Pass criterion: __HEXA_BIO_RIBOZYME__ PASS sentinel present.
// Cost: $0 (stub module).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "ribozyme/module/ribozyme.hexa"
    if root.len() > 0 { p = root + "/ribozyme/module/ribozyme.hexa" }

    let raw = exec("hexa run " + p + " 2>&1")
    if raw.contains("__HEXA_BIO_RIBOZYME__ PASS") {
        println("test_ribozyme: PASS")
        return
    }
    println("test_ribozyme: FAIL")
    println(raw.trim())
    exit(1)
}
