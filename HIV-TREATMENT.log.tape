@V := "tape" :: spec [active]
  version = "1.2"

# §Log
#
# Append-only history of events for the `hiv-treatment` domain.
# Sibling architecture: `HIV-TREATMENT.tape`. See ~/core/tape/spec/tape.md
# §"Authoring guide — `<DOMAIN>.log.tape`".
#
# Entries chronological, oldest first.

@A rewrite := "HIV-TREATMENT.tape rewritten from lattice-tautology stub to real-science SSOT" :: rewrite [ok d=2026-05-16]
  origin = "HIV-TREATMENT.tape was a fabricated lattice-tautology stub (created in the hexa-bio mass-split, commit 153b5a2). It 'derived' HIV/ART claims (95% bnAb coverage 'because phi=2 doubling', resistance 'ECL n/phi=3 combination', rebound '86% because sigma-x-phi', PI monomer length '99 aa ≈ sigma·sopfr·phi=120 within 17% error', PrEP burden 'sigma/phi=6배 down', BT-461~470 '6접점/n=6/sigma=12/tau=4 同時 타격' rows, '잠정 40/50 ≈ 80% EXACT' verdicts) FROM n=6 lattice numbers (sigma=12 / tau=4 / phi=2 / J2=24 / sopfr) — a direct LATTICE_POLICY g1/g2 + f1 violation. Every row_* / b_* / BT-461~470 entry deleted."
  authored = "Hand-written with real HIV virology + landmark clinical citations. Replaces ZERO biology with: HIV-1/HIV-2 virology and genome (Barré-Sinoussi 1983 isolation), Env trimer (gp120 + gp41) entry through CD4 + CCR5/CXCR4, reverse transcription / integration / latent provirus (Chun 1995/1997), accessory factors (Tat/Rev/Nef/Vif/Vpu/Vpr/Vpx). Drug-class taxonomy (NRTI/NNRTI/INSTI/PI/entry/capsid/long-acting) with literature class examples — listed for in-silico modeling context, NOT prescribing. Treatment-strategy landmarks paraphrased from literature: Palella 1998 NEJM HAART-era mortality shift; INSIGHT START 2015 NEJM immediate-vs-deferred ART; Grant 2010 NEJM iPrEx oral TDF/FTC PrEP; Rodger PARTNER 2016 JAMA / PARTNER2 2019 Lancet U=U evidence base; Connor 1994 NEJM ACTG 076 maternal-AZT MTCT prevention. Cure-direction literature: Chun latent-reservoir lineage; Hütter 2009 NEJM Berlin patient; Gupta 2019 Nature London patient; bnAb discovery era (Burton/Mascola/Walker — primary-author/era only); bnAb passive-transfer trials (Caskey/Nussenzweig era — primary-author/era only); shock-and-kill / block-and-lock / gene-therapy / immunotherapy research-strategy taxonomy. 6 real-limit anchors: latent-reservoir HARD WALL ([@lim_reservoir]), drug-resistance SOFT WALL ([@lim_resistance]), adherence + access BEHAVIORAL/ECONOMIC ([@lim_adherence_access]), immune-reconstitution ceiling on late-presenting BIOLOGICAL ([@lim_immune_reconstitution]), structural/stigma SOCIAL/STRUCTURAL ([@lim_structural_social]), CCR5-Δ32 donor-specificity STRUCTURAL/EPIDEMIOLOGIC ([@lim_ccr5_donor]). 3 falsifiable predictions with falsifiers + sourced (TP-1 ATI rebound from reservoir; TP-2 U=U; TP-3 Berlin/London non-generalisability gate). 14 real @X :: literature citations."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: HIV virology exposes NO natural n=6 invariant. 9 viral gene products, 2 species (HIV-1/HIV-2), 2-receptor entry (CD4 + co-receptor), Env trimer, gp41 six-helix bundle (structural fact, NOT a derivation source for treatment claims), an open and expanding drug-class list. Numerical coincidence with sigma/tau/phi/J2 values is OBSERVATION only, never derivation. This honesty IS the corrective for the audited lattice-tautology stub."
  governance = "Complies with hexa-bio AGENTS.tape g1 (real-limits-first — 6 real-limit anchors), g2 (lattice-is-tool — declined as derivation), g3 (honesty-obligation-external — Pasteur / NIH / WHO / DHHS / EACS / IAS-USA / UNAIDS cited per their own institutional invariants, not lattice-fitted), g8 (in-silico-only-claim-scope — @N scope_disclaimer added: not prescribing guidance, not a treatment regimen, real HIV care requires a licensed infectious-disease clinician), f1 (no lattice-fit), f2 (no in-silico→clinical/therapeutic/efficacy claim — trial outcomes paraphrased qualitatively from published literature for modeling context only), f3 (no shadow-implementation — references real virology/pharmacology/clinical-trial literature, not a sister-repo reimplementation). Provenance recorded in @I id001 rewritten-from key."
  honesty-caveats = "No fabricated numbers/citations. Trial outcomes paraphrased qualitatively (direction + intent + landmark trial) rather than asserted as specific percentages; exact figures live in the cited primary papers. Five references flagged primary-author/era only — exact volume/page NOT asserted: x_mitsuya_broder_1985 (PNAS, 1985 AZT in-vitro era — volume not asserted), x_chun_1995 (Nature Medicine 1995 — exact volume not asserted), x_rodger_partner_2016 (PARTNER JAMA 2016 — paraphrased), x_burton_mascola_walker_era (multi-paper 2009–2014+ bnAb discovery era across Science/Nature/Cell/PNAS/J Virol — exact volumes not asserted), x_caskey_bnab_era (Caskey/Nussenzweig mid-2010s passive-transfer trials — exact volumes not asserted). Confident citations carry exact author-year-journal-volume-page: x_barre_sinoussi_1983 (Science 220:868–871), x_palella_1998 (NEJM 338:853–860), x_chun_1997 (Nature 387:183–188 / PNAS 94:13193–13197), x_hutter_2009 (NEJM 360:692–698), x_gupta_2019 (Nature 568:244–248), x_insight_start_2015 (NEJM 373:795–807), x_grant_2010 (NEJM 363:2587–2599), x_rodger_partner2_2019 (Lancet 393:2428–2438), x_connor_1994 (NEJM 331:1173–1180). U=U paraphrased as the published serodifferent-couple finding, NOT as a personal medical assurance. Berlin/London cure cases explicitly framed by the donor-specificity / allograft-indication real-limits gate ([@lim_ccr5_donor]) to prevent over-generalisation. cART / HAART regimen choice / sequencing / dosing not asserted — defers explicitly to current treatment guidelines (DHHS / EACS / WHO / IAS-USA) and to a licensed infectious-disease clinician."
  lint = "python3 selftest/tape_lattice_honesty_lint.py HIV-TREATMENT.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true, deriv_warnings=[] — zero lattice-derivation lines remain; all row_* / b_* / BT-461~470 lattice-tautology garbage deleted)."
