#!/usr/bin/env tape
# ══════════════════════════════════════════════════════════════════════
# .tape v1.2 — grammar primer (cold-read by any LLM / agent / human)
# ══════════════════════════════════════════════════════════════════════
# Form: each entry is `@<type> <id> := "<subject>" :: <kind> [<grades>]`
#       optionally followed by body lines (2-space indent) — key=value,
#       edges (<- -> => …), or quoted prose.
#
# ENTRY TYPES (17):
#   Runtime (10): @S session  @U user  @A assistant  @T tool-call  @R result
#                 @H hook  @D decision  @K cost  @P provider  @? anomaly
#   Foundation:   @I identity-claim
#   Declarative:  @X external-citation  @F forbidden-pattern  @N note
#                 @C config  @L layout  @V spec-version
#
# EDGES (12, on body lines, 2-space indent):
#   Causal:     <- caused-by   -> triggers   == continues
#               ~> supersedes  !! aborts     |> verified-by
#   Effect:     => produces (followed by quoted natural-language)
#   Structural: <: specializes  :> generalizes  ?> soft-depends
#               !> conflicts-with  @> projects-to (e.g. @> AGENTS.md)
#
# GRADE TAGS (in [...] on entry header):
#   Delivery:   ok · err · denied · cancelled · partial · superseded
#   Governance: required · recommended · optional · draft · active · deprecated
#   Scoped:     allow:<x> · deny:<x>
#   Time/index: T<n> (turn)  N<n> (wall-sec)  d=<YYYY-MM-DD>
#
# PAYLOAD SYNTAX (body lines):
#   key = "value"           single-line string
#   key = [a, b, c]         array literal
#   key <<~EOF              heredoc (multi-line; ends with EOF on own line)
#     multi-line text
#   EOF
#   "see [@x1] §3"          inline citation by entry id
#   `cmd or path`           backtick code-span (inline only)
#
# Full spec: ~/core/tape/spec/tape.md (or github.com/dancinlab/tape)
# ══════════════════════════════════════════════════════════════════════


# ══════════════════════════════════════════════════════════════
# MICROPLASTICS.log.tape — append-only event history (v1.2 split)
# Sibling: MICROPLASTICS.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite_lattice_tautology_stub := "MICROPLASTICS.tape full real-science rewrite from lattice-tautology stub" :: rewrite [ok d=2026-05-16]
  origin = "MICROPLASTICS.tape was a lattice-tautology stub generated by the hexa-bio mass-split (commit 153b5a2). The stub contained ~330 lines of @D row_* entries with fields x=\"σ=12\" / x=\"EXACT\" / hexa=\"**90**\" / n_6=\"σ·(σ-φ)/2\" / n_6=\"n=6\" / n_6=\"σ(6)=12\" — fabricated lattice-derivation numbers (e.g. '분해 효율 90% because σ·(σ-φ)/2') with zero environmental or health-science content. No real citations, no real limits, no honest n=6 stance, no @F guard. Would have FAILed tape_lattice_honesty_lint.py on all three contracts (guard, stance, citation)."
  rewrite = "Full rewrite 2026-05-16. Preserved: top .tape v1.2 grammar primer, banner, @V :: spec. Replaced all stub @D row_* and lattice-tautology entries with real microplastics/nanoplastics environmental science. Zero stub lines retained."
  content = "14 sections: §1 definition + coining (Thompson et al 2004 — <5 mm threshold, 'microplastics' term, 'nanoplastics' emergence); §2 sources primary vs secondary (microbeads, nurdles, textile fibres, tire wear, UV photodegradation, mechanical abrasion); §3 polymer composition and density-driven partitioning (PET, PE, PP, PS, PVC; surface vs sediment fate; biofouling density shift; persistence); §4 marine accumulation (5 subtropical gyres — physical oceanography; GPGP Lebreton et al 2018 ~79,000 t, ~1.6M km²); §5 detection methods (FTIR, Raman, pyrolysis-GC/MS for nanoplastics — Hartmann era; nanoplastics methods still immature); §6 biological exposure invertebrates (Cole et al 2013 zooplankton uptake, filter-feeder ingestion; evidence-grade qualified); §7 biological exposure seabirds (Wilcox et al 2015 PNAS — 186 species, 99% projection); §8 trophic transfer (laboratory demonstrated, biomagnification in field not established — honest); §9 human exposure (Schwabl et al 2019 — human stool first detection; Leslie et al 2022 — human blood landmark; other matrices noted); §10 health effects — HONEST evidence-grade: well-documented=exposure ubiquity; in vitro inflammation/oxidative stress established; animal high-dose data; human causal evidence at environmental doses LIMITED/EMERGING; WHO 2019 data-insufficient conclusion; §11 mitigation (US Microbead-Free Waters Act 2015; UK ban 2018; tire/textile reduction debate; biodegradable greenwashing critique); §12 five real-limits (nanoplastics detection HARD; human-health causality SOFT/evidence gap; environmental persistence HARD; ocean cleanup infeasibility HARD engineering; ecological causality vs correlation SOFT); §13 @F f_lattice_fit + @N n6_honest_stance; §14 three falsifiable predictions (GPGP size distribution, density partitioning surface enrichment, Wilcox seabird projection); §15-§16 cross-links and 8 @X :: literature / institutional entries."
  citations = "Confident (full bibliographic detail asserted): Thompson et al 2004 Science 304:838 (microplastics coining); Cole et al 2013 Environ Sci Technol 47:6646-6655 (zooplankton uptake); Lebreton et al 2018 Sci Rep 8:4666 (GPGP characterisation); Wilcox et al 2015 PNAS 112:11899-11904 (seabird plastic); Schwabl et al 2019 Ann Intern Med 171:453-457 (human stool); Leslie et al 2022 Environ Int 163:107199 (human blood detection)."
  author-era-institution = "WHO 2019 Microplastics in drinking-water (institutional report, full citation asserted with caveat); US Microbead-Free Waters Act 2015 (Pub L 114-114, legislative); UK microbead ban 2018 (regulatory, primary authority/era cited, exact statutory instrument subject to verification); Hartmann group pyrolysis-GC/MS nanoplastics-detection era (~2010s–2020s, body of work, not single article asserted)."
  evidence-grade-discipline = "Honesty: environmental persistence, food-chain entry, marine accumulation = well-documented (Thompson/Cole/Lebreton/Wilcox). Human body burden = documented (Schwabl/Leslie). Specific human-health CAUSAL claims at environmental doses = LIMITED/EMERGING — this tape does not assert them. WHO 2019 'insufficient for quantitative risk characterisation' is cited accurately. In vitro and high-dose animal data are characterised as mechanism-plausible, not dose-equivalent. This is the core honesty discipline requested."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: microplastics science has no natural n=6 invariant. Ocean gyres = 5 (physical oceanography). Major polymer types = commonly 5 (not 6). WHO conclusion = evidence-based, not lattice-constrained. <5 mm threshold = operational field definition. This honesty IS the corrective for the audited lattice-tautology stub."
  governance = "Complies with hexa-bio AGENTS.tape @D g1 (real-limits-first), @D g2 (lattice-is-tool), @D g8 (in-silico-only-claim-scope), @F f1 (lattice-fit-on-external-entity). Knowledge-scope + evidence-grade disclaimer (@N scope_disclaimer) added."
  lint = "python3 selftest/tape_lattice_honesty_lint.py MICROPLASTICS.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true; no live derivation lines — all @D entries cite real @X literature via |> edges or explicit citation text; zero stub-pattern lines retained)."
