#!/usr/bin/env tape
# ══════════════════════════════════════════════════════════════════════
# .tape v1.2 — grammar primer (cold-read by any LLM / agent / human)
# ══════════════════════════════════════════════════════════════════════
# Form: each entry is `@<type> <id> := "<subject>" :: <kind> [<grades>]`
#       optionally followed by body lines (2-space indent) — key=value,
#       edges (<- -> => …), or quoted prose.
#
# ENTRY TYPES (17):
#   Runtime (10): @S session  @U user  @A assistant  @T tool-call  @R result
#                 @H hook  @D decision  @K cost  @P provider  @? anomaly
#   Foundation:   @I identity-claim
#   Declarative:  @X external-citation  @F forbidden-pattern  @N note
#                 @C config  @L layout  @V spec-version
#
# EDGES (12, on body lines, 2-space indent):
#   Causal:     <- caused-by   -> triggers   == continues
#               ~> supersedes  !! aborts     |> verified-by
#   Effect:     => produces (followed by quoted natural-language)
#   Structural: <: specializes  :> generalizes  ?> soft-depends
#               !> conflicts-with  @> projects-to (e.g. @> AGENTS.md)
#
# GRADE TAGS (in [...] on entry header):
#   Delivery:   ok · err · denied · cancelled · partial · superseded
#   Governance: required · recommended · optional · draft · active · deprecated
#   Scoped:     allow:<x> · deny:<x>
#   Time/index: T<n> (turn)  N<n> (wall-sec)  d=<YYYY-MM-DD>
#
# PAYLOAD SYNTAX (body lines):
#   key = "value"           single-line string
#   key = [a, b, c]         array literal
#   key <<~EOF              heredoc (multi-line; ends with EOF on own line)
#     multi-line text
#   EOF
#   "see [@x1] §3"          inline citation by entry id
#   `cmd or path`           backtick code-span (inline only)
#
# Full spec: ~/core/tape/spec/tape.md (or github.com/dancinlab/tape)
# ══════════════════════════════════════════════════════════════════════


# ══════════════════════════════════════════════════════════════
# GENETICS.log.tape — append-only event history (v1.2 split)
# Sibling: GENETICS.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite_lattice_to_real_science := "GENETICS.tape full real-science rewrite from lattice-tautology stub" :: rewrite [ok d=2026-05-16]
  origin = "Pre-rewrite GENETICS.tape (153b5a2 mass-split) was a lattice-tautology stub: `@D row_x_*` / `@D row_tp_*` / `@D row_core_*` entries deriving genetics quantities (99% variant detection, 144× sequencing depth, 4-hr analysis time, 6 core indicators) from n=6 arithmetic (σ=12, τ=4, φ=2, J₂=24, sopfr=5) — no real citations, no real-limits anchors, no PASS-contract honesty guard."
  what-was-removed = "All @D row_* lattice-tautology entries (performance tables, σ·sopfr/10 derivations, σ·φ=n·τ tautology rows, OEIS A000005/A000010/A000203 lattice provenance, 'EXACT %' coefficients, Korean-language ASCII section stubs, 13/13 PASS predictions). None of these carried citable genetics science."
  what-was-added = "14 sections of real genetics: Mendelian foundations (Mendel 1866 Verhandlungen 4:3-47) and 1900 rediscovery (de Vries / Correns / Tschermak); chromosome theory (Sutton 1902 / Boveri 1902-1904); Morgan fruit-fly genetics + Sturtevant 1913 first linkage map + Morgan 1933 Nobel; DNA as genetic material (Griffith 1928 transforming principle phenomenology → Avery, MacLeod & McCarty 1944 J Exp Med 79:137-158 chemical identity → Hershey & Chase 1952 J Gen Physiol 36:39-56 phage labeling confirmation); molecular era (Chargaff base composition; Watson & Crick 1953 Nature 171:737-738; central dogma Crick 1958/1970 Nature 227:561-563; genetic code Nirenberg/Khorana/Holley 1968 Nobel); genome era (Sanger 1977 PNAS 74:5463-5467; HGP Lander 2001 Nature 409:860-921 + Venter 2001 Science 291:1304-1351; NGS Solexa/Illumina/PacBio/Nanopore era); population genetics (Hardy-Weinberg 1908; Wright/Fisher/Haldane founding era; F-statistics; genetic drift); quantitative genetics & missing heritability (Manolio 2009 Nature 461:747-753); polygenic risk scores (Khera 2018 Nat Genet era); epigenetics (DNA methylation, histone code, imprinting) and X-inactivation (Lyon 1961 era); single-cell genomics (Linnarsson era; Tang 2009; Drop-seq/10x; spatial transcriptomics); clinical/consumer genetic testing modalities (Mendelian panels, carrier screening, NIPT/PGT, pharmacogenomics, DTC)."
  real-limits = "5 @D lim_* :: real-limit [ok required] entries: missing-heritability HARD WALL (PRS captures fraction of family-history risk); pleiotropy + epistasis SOFT WALL (single-variant interpretation complicated); GxE interaction SOFT WALL (genetic effects environment-conditional); ancestry bias in genomic databases HARD WALL (overwhelmingly European-ancestry; Sirugo 2019 era; PRS portability problem); ethical + privacy REGULATORY/ETHICAL WALL (GINA 2008 era; GDPR 2018 special category; familial re-identification informational footprint)."
  honesty = "Zero fabricated numbers or citations. Uncertain bibliographic details are primary-author + era only with explicit 'not asserted in this entry' flags (Sutton/Boveri chromosome theory; Sturtevant 1913 first linkage map; Griffith 1928; Nirenberg/Khorana/Holley 1968 Nobel; Lyon 1961 X-inactivation; Khera 2018 PRS; Sirugo 2019 ancestry-bias; HGP T2T Nurk 2022; NGS founding-publication details). n=6 observation-not-derivation: @F f_lattice_fit + @N n6_honest_stance state plainly that genetics has no natural n=6 invariant (human karyotype 46 / varies 2 to >600 across eukaryotes; 64 codons = 4³ combinatorics; 20 amino acids empirical; Mendel 3:1 and 9:3:3:1 combinatorial; HWE p² + 2pq + q² = 1 algebraic identity; GWAS threshold ~5×10⁻⁸ from multiple-testing). No derivation lines in the final tape."
  predictions = "3 @D tp_* :: prediction [ok] entries with falsifiers grounded in real sources: TP-1 PRS portability degrades outside discovery-ancestry (falsifier: cross-ancestry validation shows no loss); TP-2 missing-heritability gap shrinks with cohort size (falsifier: 10× larger GWAS yields no additional captured heritability); TP-3 HWE deviation flags assumption violation (falsifier: deviating loci correspond to none of population-structure/inbreeding/selection/assay artefact)."
  lint = "python3 selftest/tape_lattice_honesty_lint.py /Users/ghost/core/hexa-bio/GENETICS.tape --json → __TAPE_LATTICE_HONESTY__ PASS (verdict=PASS, has_guard=true, has_stance=true, grounded=true, deriv_warnings=[])."
  citations-confident = [Mendel 1866 Verhandlungen 4:3-47, Avery/MacLeod/McCarty 1944 J Exp Med 79:137-158, Hershey & Chase 1952 J Gen Physiol 36:39-56, Watson & Crick 1953 Nature 171:737-738, Crick 1970 Nature 227:561-563, Sanger 1977 PNAS 74:5463-5467, Lander 2001 Nature 409:860-921, Venter 2001 Science 291:1304-1351, WTCCC 2007 Nature 447:661-678, Manolio 2009 Nature 461:747-753]
  citations-author-era = [Sutton 1902 / Boveri 1902-1904 chromosome theory, Morgan 1933 Nobel + Sturtevant 1913 first linkage map, Griffith 1928 transforming principle, Nirenberg/Khorana/Holley 1968 Nobel, Lyon 1961 X-inactivation, Khera 2018 Nat Genet PRS era, Sirugo 2019 ancestry bias, T2T Nurk 2022, Hardy 1908 / Weinberg 1908, Wright/Fisher/Haldane founding era]
  governance = "Complies with hexa-bio AGENTS.tape @D g1 (real-limits-first) · @D g2 (lattice-is-tool) · @D g8 (in-silico-only-claim-scope) · @F f1 (lattice-fit-on-external-entity) · @F f2 (wet-lab-clinical-claim-from-in-silico). PASS contract: @F f_lattice_fit guard present; @N n6_honest_stance present; ≥1 @X :: literature with ref= present (18 such entries). Clinical-scope disclaimer (@N scope_disclaimer) added — knowledge SSOT, NOT clinical/diagnostic advice."
