# ─── §13 External citations (real, landmark literature) ──────────────
# Where a specific bibliographic detail is not asserted with confidence,
# the entry names the primary author + era only and says so explicitly.

@X x_au_sonar_textbook := "Au — The Sonar of Dolphins (textbook, ~1993)" :: literature [active]
  ref = "Whitlow W.L. Au. 'The Sonar of Dolphins.' Springer, 1993. Canonical textbook-era reference for click-frequency characterisation, source levels, beamwidth, interclick intervals, psychoacoustic discrimination performance (range, size, material), and biosonar signal processing in odontocetes. Author and approximate publication year asserted; full bibliographic details are textbook-standard. Cross-cited in DOLPHIN.tape §3."

@X x_payne_mcvay_1971 := "Payne & McVay 1971 — humpback whale songs" :: literature [active]
  ref = "Payne RS, McVay S. Songs of humpback whales. Science 1971;173(3997):585–597. Landmark paper establishing that humpback whale (Megaptera novaeangliae) vocalisations are hierarchically structured 'songs'; documented unit–phrase–theme–song hierarchy and population-wide cultural transmission. Volume, issue, and page range are well-established and asserted with confidence."

@X x_noad_2000 := "Noad et al 2000 — revolutionary song change" :: literature [active]
  ref = "Noad MJ, Cato DH, Bryden MM, Jenner MN, Jenner KC. Cultural revolution in whale songs. Nature 2000;408(6812):537. Documents the rapid displacement of the East Australian humpback song by a new song type imported from Western Australia — the most dramatic non-human cultural transmission event on record. Volume and page confirmed."

@X x_caldwell_caldwell_1965 := "Caldwell & Caldwell 1965 — signature whistles" :: literature [active]
  ref = "Caldwell MC, Caldwell DK. Individualized whistle contours in bottlenosed dolphins (Tursiops truncatus). Nature 1965;207:434–435. First publication establishing individually distinctive signature whistle contours in bottlenose dolphins. Volume and page asserted; primary-author/era well-documented."

@X x_king_janik_2013 := "King & Janik 2013 — vocal labels" :: literature [active]
  ref = "King SL, Janik VM. Bottlenose dolphins can use learned vocal labels to address each other. Proc Natl Acad Sci USA 2013;110(32):13216–13221. Demonstrates that bottlenose dolphins respond preferentially to playback of their own signature whistle — evidence that signature whistles function as learned vocal labels in directed social communication. Volume, issue, and page range asserted with confidence."

@X x_janik_slater_1997 := "Janik & Slater 1997 — vocal learning functional significance (era)" :: literature [active]
  ref = "Janik VM, Slater PJB. Vocal learning in mammals. Adv Study Behav 1997;26:59–99. Reviews the functional significance of vocal learning across mammals, including cetacean signature whistle acquisition and copying. Author/era flagged; chapter-level citation with approximate volume."

@X x_janik_2000 := "Janik 2000 — whistle matching in wild dolphins" :: literature [active]
  ref = "Janik VM. Whistle matching in wild bottlenose dolphins (Tursiops truncatus). Science 2000;289(5483):1355–1357. Demonstrates call copying / whistle matching in free-ranging wild dolphins — social-bonding context. Volume and page asserted."

@X x_ford_1991 := "Ford 1991 — orca vocal traditions" :: literature [active]
  ref = "Ford JKB. Vocal traditions among resident killer whales (Orcinus orca) in coastal waters of British Columbia, Canada. Can J Zool 1991;69(6):1454–1483. Landmark documentation of pod-specific discrete call types and multi-decade stability of orca vocal dialects in NE Pacific resident and transient populations. Volume, issue, and page range asserted with confidence."

@X x_pamguard_institutional := "PAMGuard — open-source PAM software (institutional citation)" :: literature [active]
  ref = "PAMGuard — passive acoustic monitoring software. Gillespie D and colleagues (University of St Andrews / SMRU Consulting); open-source project; https://www.pamguard.org/. Institutional/software citation; no single journal paper captures the full platform. Widely adopted for cetacean PAM research and real-time monitoring."

@X x_tyack_noise_era := "Tyack and colleagues — anthropogenic noise impacts on cetaceans (era)" :: literature [active]
  ref = "Tyack PL and colleagues — a series of research publications (approximately 2000–2015) examining anthropogenic noise effects on cetacean communication, behaviour, and physiology, including chronic shipping noise masking, sonar-associated strandings, and population-level acoustic impacts. Primary-author/era flagged; specific papers include Tyack PL. Implications for marine mammals of large-scale changes in the marine acoustic environment. J Mammal 2008;89:549–558 (volume confirmed) and collaborative work on beaked-whale responses."

@X x_deruiter_2013 := "DeRuiter et al 2013 — beaked whale sonar response" :: literature [active]
  ref = "DeRuiter SL, Southall BL, Calambokidis J, Zimmer WMX, Sadykova D, Falcone EA, Friedlaender AS, Joseph JE, Moretti D, Schorr GS, Thomas L, Tyack PL. First direct measurements of behavioural responses by Cuvier's beaked whales to mid-frequency active sonar. Biol Lett 2013;9(4):20130223. Documents avoidance and aberrant diving behaviour in tagged beaked whales during sonar exposure — key causal mechanistic evidence for sonar-stranding link. Volume, issue, and article ID asserted with confidence."
