#!/usr/bin/env tape

# ══════════════════════════════════════════════════════════════
# IMMUNOLOGY.log.tape — append-only event history (v1.2 split)
# Sibling: IMMUNOLOGY.tape (architecture-current, editable)
# ══════════════════════════════════════════════════════════════

@V := "tape" :: spec [active]
  version = "1.2"

# §Log — entries chronological, oldest first.

@A rewrite := "IMMUNOLOGY.tape rewritten from lattice-tautology stub to real-science SSOT" :: rewrite [ok d=2026-05-16]
  origin = "IMMUNOLOGY.tape was a fabricated lattice-tautology stub (created in the hexa-bio mass-split, commit 153b5a2). It 'derived' immunology facts (방어율=99%, 면역기억=6개월/60, 자가면역=1%, 진단지표=12, 실패율=1%, EXACT 비율=93%) from n=6 lattice numbers (σ=12/τ=4/φ=2/J₂=24/sopfr=5/μ=1) with x=\"EXACT\" — a direct LATTICE_POLICY g1/g2 + f1 violation. Every row_* / b_* / tp_* stub entry deleted."
  authored = "Hand-written with real immunology biology + landmark Nobel-laureate / RCT citations. Replaces ZERO biology with: clonal selection (Burnet 1957, Nobel 1960; Jerne 1955 precursor); innate immunity (TLRs / Beutler 2011 Nobel, complement 3-pathway, NK/ILC subsets, NLRP3 inflammasome / Tschopp era, dendritic cells / Steinman 2011 Nobel); adaptive immunity (V(D)J / Tonegawa 1987 Nobel, MHC restriction / Doherty & Zinkernagel 1996 Nobel, TCR / Mak & Davis 1984 era, germinal-center affinity maturation, T-cell subsets); checkpoint biology (CTLA-4 / Allison, PD-1 / Honjo → 2018 Nobel) and clinical translation (ipilimumab / Hodi 2010, MSI/dMMR / Le 2015); antibody therapeutics (trastuzumab / Slamon 2001, rituximab anti-CD20, ipi/nivo/pembro checkpoint mAbs); autoimmunity & tolerance (central — AIRE / Anderson 2002 era, peripheral, molecular mimicry, HLA-B*27 / DRB1 associations); immunodeficiency (SCID, CGD, CVID) and immune evasion (tumour + chronic-virus). 6 real-limit anchors: tolerance breakdown (HARD), immunosenescence (BIOLOGICAL), checkpoint durable-response minority (SOFT, biomarker-modulated; cross-links CANCER-THERAPY), chronic-pathogen evasion (HARD, pathogen-specific; cross-links VACCINE), adjuvant trade-off (SOFT; cross-links VACCINE), rare-but-severe irAEs (PHYSICAL/BIOLOGICAL rate-floor; cross-links CANCER-THERAPY). 3 falsifiable predictions with falsifiers + sourced (checkpoint biology-bound vs platform-bound; thymic-involution-gated naive responses; irAE-rate scaling with checkpoint depth). 16 real @X :: literature citations including 5 Nobel-anchored summaries with their underlying primary work (Beutler/TLR4/Poltorak 1998; Steinman/DC/1973 J Exp Med; Tonegawa/Hozumi 1976 PNAS; Doherty-Zinkernagel/1974 Nature; Allison-Honjo/Leach 1996 Science + Ishida 1992 EMBO J)."
  n6-stance = "Declined as a derivation tool. @F f_lattice_fit + @N n6_honest_stance state plainly: immunology exposes NO natural n=6 invariant. Numerical coincidences are documented as observation only (2 MHC classes vs φ=2; 4 IgG subclasses vs τ=4; 5 antibody isotypes vs sopfr=5) and explicitly framed as OBSERVATION, never derivation. TLR family is open/expanding (not a closed 6-tuple), T-helper polarization taxonomy is still-refined, complement has 3 (not 6) activation pathways. This honesty IS the corrective for the audited lattice-tautology stub."
  governance = "Complies with hexa-bio AGENTS.tape g1 (real-limits-first — 6 real-limit anchors), g2 (lattice-is-tool — declined as derivation), g8 (in-silico-only-claim-scope — @N scope_disclaimer added: NOT clinical advice, NOT diagnostic protocol, NOT substitute for licensed clinician), f1 (no lattice-fit), f2 (no in-silico→clinical/efficacy claim — figures paraphrased from published literature for modeling context only). Provenance recorded in @I id001 rewritten-from key. Mirrors CANCER-THERAPY.tape and VACCINE.tape precedent commits (dd2c828, a8d24d0)."
  honesty-caveats = "No fabricated numbers/citations — exact response-fraction magnitudes kept qualitative (direction + biomarker stratification + landmark trial); precise percentages avoided where not certain. Several references flagged primary-author/era only: x_burnet_1957 (Aust J Sci 1957, pages per original short note — pages stated honestly but era flagged); x_jerne_1955 (PNAS precursor — primary-author/era); x_beutler_nobel_2011 (Nobel summary + Poltorak 1998 Science primary work cited); x_steinman_nobel_2011 (Nobel summary + 1973 J Exp Med primary work cited); x_tonegawa_nobel_1987 (Nobel summary + Hozumi-Tonegawa 1976 PNAS primary work cited); x_doherty_zinkernagel_nobel_1996 (Nobel summary + 1974 Nature primary work cited); x_mak_davis_tcr_1984_era (parallel Nature 1984 papers Yanagi/Mak and Hedrick/Davis cited with primary-author/era framing); x_allison_honjo_nobel_2018 (Nobel summary + Leach 1996 Science / Ishida 1992 EMBO J primary work cited); x_anderson_aire_2002_era (Anderson et al. Science 2002 cited with primary-author/era framing); x_tschopp_nlrp3_era (Martinon-Burns-Tschopp 2002 Mol Cell + later 2006 Nature on urate-crystal NLRP3 cited with primary-author/era); x_janeway_textbook (textbook — edition not asserted, mirrors VACCINE.tape discipline). x_hodi_2010, x_le_2015, x_slamon_2001 cross-referenced from CANCER-THERAPY.tape with confirmed NEJM volume/page from that committed precedent."
  cross-links = "Two sibling-tape @X entries: x_cancer_therapy_sibling (checkpoint clinical translation, antibody therapeutics shared with tx_immune_checkpoint/tx_targeted/cmp_immuno/lim_no_universal_cure) and x_vaccine_sibling (humoral/cellular memory mechanism shared with mech_humoral/mech_memory; adjuvant trade-off and chronic-pathogen evasion shared with adj_overview/lim_pathogen_specific_failures/lim_waning). Immunology is the substrate; vaccinology is the engineered-input layer; cancer immunotherapy is the clinical-application layer — each lives in its own tape with sibling cross-references rather than duplication."
  lint = "python3 selftest/tape_lattice_honesty_lint.py IMMUNOLOGY.tape --json → __TAPE_LATTICE_HONESTY__ PASS (has_guard=true, has_stance=true, grounded=true, deriv_warnings limited to guard/stance provenance only — zero lattice-derivation lines remain; all row_* / b_* / tp_* stub garbage deleted)."
